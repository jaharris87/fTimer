   subroutine build_single_timer_summary(timer, summary, ierr)
      type(ftimer_t), intent(out) :: timer
      type(ftimer_summary_t), intent(out) :: summary
      integer, intent(out) :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)
      call timer%get_summary(summary, ierr=ierr)
   end subroutine build_single_timer_summary

   subroutine delete_if_exists(path)
      character(len=*), intent(in) :: path
      integer :: io
      integer :: unit

      open (newunit=unit, file=path, status='old', iostat=io)
      if (io == 0) close (unit, status='delete')
   end subroutine delete_if_exists

   subroutine write_raw_text_without_newline(path, text)
      character(len=*), intent(in) :: path
      character(len=*), intent(in) :: text
      integer :: io
      integer :: unit

      open (newunit=unit, file=path, status='replace', access='stream', form='unformatted', &
            action='write', iostat=io)
      @assertEqual(0, io)
      write (unit, iostat=io) text
      @assertEqual(0, io)
      close (unit)
   end subroutine write_raw_text_without_newline

   subroutine rewrite_lf_text_as_crlf(path)
      character(len=*), intent(in) :: path
      character(len=:), allocatable :: text
      integer :: i
      integer :: io
      integer :: unit

      text = read_file_text(path)

      open (newunit=unit, file=path, status='replace', access='stream', form='unformatted', &
            action='write', iostat=io)
      @assertEqual(0, io)
      do i = 1, len(text)
         if (text(i:i) == new_line('a')) then
            write (unit, iostat=io) achar(13)//new_line('a')
         else
            write (unit, iostat=io) text(i:i)
         end if
         @assertEqual(0, io)
      end do
      close (unit, iostat=io)
      @assertEqual(0, io)
   end subroutine rewrite_lf_text_as_crlf

   subroutine capture_raw_file_text(path, text)
      character(len=*), intent(in) :: path
      character(len=:), allocatable, intent(out) :: text
      integer :: file_size
      integer :: io
      integer :: unit
      logical :: exists

      inquire (file=path, exist=exists, size=file_size)
      @assertTrue(exists)

      if (file_size <= 0) then
         text = ''
         return
      end if

      allocate (character(len=file_size) :: text)
      open (newunit=unit, file=path, status='old', access='stream', form='unformatted', &
            action='read', iostat=io)
      @assertEqual(0, io)
      read (unit, iostat=io) text
      @assertEqual(0, io)
      close (unit, iostat=io)
      @assertEqual(0, io)
   end subroutine capture_raw_file_text

   subroutine assert_raw_file_unchanged(path, expected)
      character(len=*), intent(in) :: path
      character(len=*), intent(in) :: expected
      character(len=:), allocatable :: actual
      logical :: unchanged

      call capture_raw_file_text(path, actual)
      unchanged = actual == expected
      @assertTrue(unchanged)
   end subroutine assert_raw_file_unchanged

   function expected_single_timer_output(summary) result(text)
      type(ftimer_summary_t), intent(in) :: summary
      character(len=:), allocatable :: text
      character(len=256) :: line

      write (line, '(a,f0.6)') 'Total time (s) : ', summary%total_time
      text = trim(line)//new_line('a')//new_line('a')
      text = text//'Timer name  Inclusive (s)     Self (s)    Calls   % Total'//new_line('a')
      text = text//'---------------------------------------------------------'//new_line('a')
      text = text//'A               4.000000      4.000000         1    100.00'//new_line('a')
   end function expected_single_timer_output

   subroutine assert_real_close(actual, expected)
      real(wp), intent(in) :: actual
      real(wp), intent(in) :: expected
      real(wp) :: diff

      diff = abs(actual - expected)
      @assertTrue(diff < 1.0e-12_wp)
   end subroutine assert_real_close

   integer function csv_logical_record_count(text) result(count)
      character(len=*), intent(in) :: text
      integer :: i
      logical :: in_quotes

      count = 0
      in_quotes = .false.
      i = 1
      do while (i <= len(text))
         if (text(i:i) == '"') then
            if (in_quotes .and. (i < len(text)) .and. (text(i + 1:i + 1) == '"')) then
               i = i + 1
            else
               in_quotes = .not. in_quotes
            end if
         else if ((text(i:i) == new_line('a')) .and. (.not. in_quotes)) then
            count = count + 1
         end if
         i = i + 1
      end do

      if ((len(text) > 0) .and. (text(len(text):len(text)) /= new_line('a'))) count = count + 1
   end function csv_logical_record_count

   function csv_logical_record_at(text, target_record) result(record)
      character(len=*), intent(in) :: text
      integer, intent(in) :: target_record
      character(len=:), allocatable :: record
      integer :: current_record
      integer :: i
      integer :: record_start
      logical :: in_quotes

      record = ''
      if (target_record <= 0) return

      current_record = 1
      record_start = 1
      in_quotes = .false.
      i = 1
      do while (i <= len(text))
         if (text(i:i) == '"') then
            if (in_quotes .and. (i < len(text)) .and. (text(i + 1:i + 1) == '"')) then
               i = i + 1
            else
               in_quotes = .not. in_quotes
            end if
         else if ((text(i:i) == new_line('a')) .and. (.not. in_quotes)) then
            if (current_record == target_record) then
               if (i > record_start) record = text(record_start:i - 1)
               return
            end if
            current_record = current_record + 1
            record_start = i + 1
         end if
         i = i + 1
      end do

      if (current_record == target_record) record = text(record_start:)
   end function csv_logical_record_at

   integer function count_csv_header_records(text, header) result(count)
      character(len=*), intent(in) :: text
      character(len=*), intent(in) :: header
      character(len=:), allocatable :: line
      integer :: i

      count = 0
      do i = 1, csv_record_count(text)
         line = csv_line_at(text, i)
         if (line == header) count = count + 1
      end do
   end function count_csv_header_records

   integer function csv_field_count_local(line) result(count)
      character(len=*), intent(in) :: line
      integer :: i
      integer :: text_len
      logical :: in_quotes

      count = 1
      in_quotes = .false.
      text_len = len_trim(line)
      i = 1
      do while (i <= text_len)
         if (line(i:i) == '"') then
            if (in_quotes .and. (i < text_len) .and. (line(i + 1:i + 1) == '"')) then
               i = i + 1
            else
               in_quotes = .not. in_quotes
            end if
         else if ((line(i:i) == ',') .and. (.not. in_quotes)) then
            count = count + 1
         end if
         i = i + 1
      end do
   end function csv_field_count_local

end module test_file_output
