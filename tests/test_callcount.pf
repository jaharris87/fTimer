module test_callcount
   use pfunit
   use, intrinsic :: iso_fortran_env, only: int64
   use ftimer_core, only: ftimer_t, ftimer_test_set_call_count, ftimer_test_state_t
   use ftimer_summary, only: format_summary
   use ftimer_types, only: FTIMER_SUCCESS, ftimer_call_stack_t, ftimer_summary_t, wp
   use test_support, only: attach_mock_clock, begin_stderr_capture, build_stack, csv_line_at, end_stderr_capture, &
                           fake_time, find_context_idx, snapshot_timer
   implicit none

contains

   @test
   subroutine test_multiple_calls_increment_same_context_count()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      integer :: id_a
      integer :: ctx
      integer :: count
      type(ftimer_call_stack_t) :: root_stack

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%stop("A", ierr=ierr)
      fake_time = 2.0_wp
      call timer%start("A", ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      id_a = timer%lookup("A", ierr=ierr)
      call snapshot_timer(timer, state)
      ctx = find_context_idx(state, id_a, root_stack)
      count = state%segments(id_a)%call_count(ctx)

      @assertEqual(2, count)
   end subroutine test_multiple_calls_increment_same_context_count

   @test
   subroutine test_call_counts_are_tracked_per_context()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      integer :: id_work
      integer :: ctx_a
      integer :: ctx_b
      integer :: count_a
      integer :: count_b

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      call timer%start("work", ierr=ierr)
      fake_time = 1.0_wp
      call timer%stop("work", ierr=ierr)
      call timer%stop("A", ierr=ierr)

      fake_time = 2.0_wp
      call timer%start("B", ierr=ierr)
      call timer%start("work", ierr=ierr)
      fake_time = 3.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 4.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 5.0_wp
      call timer%stop("work", ierr=ierr)
      call timer%stop("B", ierr=ierr)

      id_work = timer%lookup("work", ierr=ierr)
      call snapshot_timer(timer, state)

      ctx_a = find_context_idx(state, id_work, build_stack([1]))
      ctx_b = find_context_idx(state, id_work, build_stack([3]))
      count_a = state%segments(id_work)%call_count(ctx_a)
      count_b = state%segments(id_work)%call_count(ctx_b)

      @assertEqual(1, count_a)
      @assertEqual(2, count_b)
   end subroutine test_call_counts_are_tracked_per_context

   @test
   subroutine test_call_counts_preserve_int64_range_in_runtime_summary()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_summary_t) :: summary
      type(ftimer_call_stack_t) :: root_stack
      character(len=:), allocatable :: header_line
      character(len=:), allocatable :: report_text
      character(len=:), allocatable :: row_line
      character(len=:), allocatable :: separator_line
      character(len=32) :: expected_count_text
      integer :: calls_header_pos
      integer :: count_row_pos
      integer :: pct_header_pos
      integer :: ierr
      integer :: id_hot
      integer :: ctx
      integer(int64) :: big_count
      integer(int64) :: stored_count
      integer(int64) :: summary_count
      logical :: avg_time_matches
      logical :: formatted_count_matches
      logical :: formatted_count_not_starred
      logical :: runtime_count_matches
      logical :: row_count_aligned
      logical :: separator_matches_header
      logical :: summary_count_matches

      big_count = int(huge(0), int64) + 5_int64
      write (expected_count_text, '(i0)') big_count

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call timer%start("hot", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 10.0_wp
      call timer%stop("hot", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_hot = timer%lookup("hot", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(timer, state)
      ctx = find_context_idx(state, id_hot, root_stack)

      call ftimer_test_set_call_count(timer, id_hot, ctx, big_count, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, state)
      stored_count = state%segments(id_hot)%call_count(ctx)
      runtime_count_matches = stored_count == big_count
      @assertTrue(runtime_count_matches)

      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, summary%num_entries)

      summary_count = summary%entries(1)%call_count
      summary_count_matches = summary_count == big_count
      avg_time_matches = abs(summary%entries(1)%avg_time - 10.0_wp/real(big_count, wp)) < 1.0e-18_wp
      @assertTrue(summary_count_matches)
      @assertTrue(avg_time_matches)

      call format_summary(summary, report_text)
      header_line = csv_line_at(report_text, 3)
      separator_line = csv_line_at(report_text, 4)
      row_line = csv_line_at(report_text, 5)
      calls_header_pos = index(header_line, 'Calls')
      pct_header_pos = index(header_line, '% Total')
      count_row_pos = index(row_line, trim(expected_count_text))
      formatted_count_matches = count_row_pos > 0
      formatted_count_not_starred = index(report_text, '********') == 0
      separator_matches_header = len_trim(separator_line) == len_trim(header_line)
      row_count_aligned = (calls_header_pos > 0) .and. (count_row_pos > 0) .and. &
                          (count_row_pos < pct_header_pos)
      @assertTrue(formatted_count_matches)
      @assertTrue(formatted_count_not_starred)
      @assertTrue(separator_matches_header)
      @assertTrue(row_count_aligned)
   end subroutine test_call_counts_preserve_int64_range_in_runtime_summary

   @test
   subroutine test_active_snapshot_formats_int64_call_count_layout()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_summary_t) :: summary
      type(ftimer_call_stack_t) :: root_stack
      character(len=:), allocatable :: header_line
      character(len=:), allocatable :: report_text
      character(len=:), allocatable :: row_line
      character(len=:), allocatable :: separator_line
      character(len=32) :: expected_count_text
      integer :: active_header_pos
      integer :: active_row_pos
      integer :: calls_header_pos
      integer :: count_row_pos
      integer :: pct_header_pos
      integer :: ctx
      integer :: id_hot
      integer :: ierr
      integer(int64) :: big_count
      logical :: active_column_aligned
      logical :: count_column_aligned
      logical :: has_active_snapshot
      logical :: no_starred_columns
      logical :: separator_matches_header

      big_count = int(huge(0), int64) + 7_int64
      write (expected_count_text, '(i0)') big_count

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      fake_time = 0.0_wp
      call timer%start("active-hot", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_hot = timer%lookup("active-hot", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(timer, state)
      ctx = find_context_idx(state, id_hot, root_stack)
      call ftimer_test_set_call_count(timer, id_hot, ctx, big_count, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 2.0_wp
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      has_active_snapshot = summary%has_active_timers
      @assertTrue(has_active_snapshot)

      call format_summary(summary, report_text)
      header_line = csv_line_at(report_text, 5)
      separator_line = csv_line_at(report_text, 6)
      row_line = csv_line_at(report_text, 7)
      calls_header_pos = index(header_line, 'Calls')
      active_header_pos = index(header_line, 'Active')
      pct_header_pos = index(header_line, '% Total')
      count_row_pos = index(row_line, trim(expected_count_text))
      active_row_pos = index(row_line, 'yes')
      count_column_aligned = (calls_header_pos > 0) .and. (count_row_pos > 0) .and. &
                             (count_row_pos < pct_header_pos)
      active_column_aligned = (active_header_pos > 0) .and. (active_row_pos >= active_header_pos)
      no_starred_columns = index(report_text, '********') == 0
      separator_matches_header = len_trim(separator_line) == len_trim(header_line)

      @assertTrue(count_column_aligned)
      @assertTrue(active_column_aligned)
      @assertTrue(no_starred_columns)
      @assertTrue(separator_matches_header)

      fake_time = 3.0_wp
      call timer%stop("active-hot", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_active_snapshot_formats_int64_call_count_layout

   @test
   subroutine test_test_set_call_count_warns_without_ierr_on_setup_error()
      type(ftimer_t) :: timer
      character(len=*), parameter :: stderr_path = 'test_set_call_count_stderr.txt'
      character(len=:), allocatable :: captured
      integer :: capture_ierr
      integer :: saved_fd
      logical :: warning_emitted

      call begin_stderr_capture(stderr_path, saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      call ftimer_test_set_call_count(timer, 1, 1, 1_int64)

      call end_stderr_capture(stderr_path, saved_fd, captured, capture_ierr)
      @assertEqual(0, capture_ierr)
      warning_emitted = index(captured, 'ftimer test_set_call_count before init') > 0
      @assertTrue(warning_emitted)
   end subroutine test_test_set_call_count_warns_without_ierr_on_setup_error

end module test_callcount
