module test_scoped_guard
   use, intrinsic :: iso_c_binding, only: c_ptr
   use pfunit
   use ftimer, only: ftimer_default_instance, ftimer_finalize, ftimer_get_summary, ftimer_init, ftimer_lookup, &
                     ftimer_scope, ftimer_scope_id
   use ftimer_core, only: ftimer_core_scope => ftimer_scope, ftimer_core_scope_id => ftimer_scope_id, &
                          ftimer_guard_t, ftimer_t, ftimer_test_state_t
   use ftimer_types, only: FTIMER_ERR_MISMATCH, FTIMER_ERR_NOT_INIT, FTIMER_EVENT_START, FTIMER_EVENT_STOP, &
                           FTIMER_MISMATCH_REPAIR, FTIMER_SUCCESS, ftimer_call_stack_t, ftimer_summary_t, wp
   use test_support, only: attach_mock_clock, begin_stderr_capture, end_stderr_capture, fake_time, find_context_idx, &
                           snapshot_timer
   implicit none

   integer, parameter :: max_events = 8
   integer, save :: callback_count = 0
   integer, save :: callback_events(max_events) = 0
   real(wp), save :: callback_timestamps(max_events) = 0.0_wp

contains

   @test
   subroutine test_oop_guard_stops_on_block_exit()
      type(ftimer_t), target :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: root_stack
      integer :: ctx
      integer :: ierr
      logical :: active
      real(wp) :: elapsed

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "scoped", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         active = guard%is_active()
         @assertTrue(active)

         fake_time = 2.5_wp
      end block

      call snapshot_timer(timer, state)
      ctx = find_context_idx(state, 1, root_stack)
      elapsed = state%segments(1)%time(ctx)

      @assertEqual(0, state%call_stack%depth)
      @assertEqual(2.5_wp, elapsed)
      @assertEqual(1, state%segments(1)%call_count(ctx))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_oop_guard_stops_on_block_exit

   @test
   subroutine test_oop_guard_stops_on_early_block_exit()
      type(ftimer_t), target :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: root_stack
      integer :: ctx
      integer :: ierr
      logical :: left_block
      real(wp) :: elapsed

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      left_block = .false.
      early_exit: block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "early", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 4.0_wp
         left_block = .true.
         exit early_exit
      end block early_exit

      call snapshot_timer(timer, state)
      ctx = find_context_idx(state, 1, root_stack)
      elapsed = state%segments(1)%time(ctx)

      @assertTrue(left_block)
      @assertEqual(0, state%call_stack%depth)
      @assertEqual(4.0_wp, elapsed)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_oop_guard_stops_on_early_block_exit

   @test
   subroutine test_guard_is_inactive_when_start_fails()
      type(ftimer_t), target :: timer
      integer :: ierr
      logical :: active

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "missing init", ierr)
         active = guard%is_active()

         @assertEqual(FTIMER_ERR_NOT_INIT, ierr)
         @assertFalse(active)
      end block
   end subroutine test_guard_is_inactive_when_start_fails

   @test
   subroutine test_guard_explicit_stop_prevents_finalizer_double_stop()
      type(ftimer_t), target :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: root_stack
      integer :: ctx
      integer :: ierr
      logical :: active
      real(wp) :: elapsed

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "manual", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 2.0_wp
         call guard%stop(ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         active = guard%is_active()
         @assertFalse(active)
         fake_time = 5.0_wp
      end block

      call snapshot_timer(timer, state)
      ctx = find_context_idx(state, 1, root_stack)
      elapsed = state%segments(1)%time(ctx)

      @assertEqual(0, state%call_stack%depth)
      @assertEqual(2.0_wp, elapsed)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_guard_explicit_stop_prevents_finalizer_double_stop

   @test
   subroutine test_nested_oop_guards_preserve_context_and_self_time()
      type(ftimer_t), target :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr
      logical :: child_name_matches
      logical :: root_name_matches

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      block
         type(ftimer_guard_t) :: outer_guard

         call start_oop_scope(timer, outer_guard, "outer", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 1.0_wp

         block
            type(ftimer_guard_t) :: inner_guard

            call start_oop_scope(timer, inner_guard, "inner", ierr)
            @assertEqual(FTIMER_SUCCESS, ierr)
            fake_time = 4.0_wp
         end block

         fake_time = 7.0_wp
      end block

      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, summary%num_entries)
      root_name_matches = trim(summary%entries(1)%name) == "outer"
      child_name_matches = trim(summary%entries(2)%name) == "inner"
      @assertTrue(root_name_matches)
      @assertTrue(child_name_matches)
      @assertEqual(0, summary%entries(1)%depth)
      @assertEqual(1, summary%entries(2)%depth)
      @assertEqual(summary%entries(1)%node_id, summary%entries(2)%parent_id)
      @assertEqual(7.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(4.0_wp, summary%entries(1)%self_time)
      @assertEqual(3.0_wp, summary%entries(2)%inclusive_time)
      @assertFalse(summary%has_active_timers)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_nested_oop_guards_preserve_context_and_self_time

   @test
   subroutine test_scope_id_stops_cached_timer_on_block_exit()
      type(ftimer_t), target :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: root_stack
      integer :: ctx
      integer :: id
      integer :: ierr
      real(wp) :: elapsed

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      id = timer%lookup("cached", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope_id(timer, guard, id, ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 3.5_wp
      end block

      call snapshot_timer(timer, state)
      ctx = find_context_idx(state, id, root_stack)
      elapsed = state%segments(id)%time(ctx)

      @assertEqual(0, state%call_stack%depth)
      @assertEqual(3.5_wp, elapsed)
      @assertEqual(1, state%segments(id)%call_count(ctx))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_scope_id_stops_cached_timer_on_block_exit

   @test
   subroutine test_explicit_guard_stop_mismatch_returns_error_without_repair()
      type(ftimer_t), target :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      logical :: active

      call timer%init(mismatch_mode=FTIMER_MISMATCH_REPAIR, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call reset_callback_log()
      call timer%set_callback(record_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "A", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 1.0_wp
         call timer%start("B", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         call guard%stop(ierr=ierr)
         active = guard%is_active()

         @assertEqual(FTIMER_ERR_MISMATCH, ierr)
         @assertTrue(active)
         @assertEqual(2, callback_count)
         @assertEqual(FTIMER_EVENT_START, callback_events(1))
         @assertEqual(FTIMER_EVENT_START, callback_events(2))
         call snapshot_timer(timer, state)
         @assertEqual(2, state%call_stack%depth)
         @assertEqual(2, state%call_stack%top())

         fake_time = 3.0_wp
         call timer%stop("B", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 5.0_wp
         call guard%stop(ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         @assertEqual(4, callback_count)
         @assertEqual(FTIMER_EVENT_STOP, callback_events(3))
         @assertEqual(FTIMER_EVENT_STOP, callback_events(4))
      end block

      call snapshot_timer(timer, state)
      @assertEqual(0, state%call_stack%depth)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_explicit_guard_stop_mismatch_returns_error_without_repair

   @test
   subroutine test_same_name_inner_activation_does_not_satisfy_outer_guard()
      type(ftimer_t), target :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      logical :: active

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "A", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 1.0_wp
         call timer%start("A", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         call guard%stop(ierr=ierr)
         active = guard%is_active()

         @assertEqual(FTIMER_ERR_MISMATCH, ierr)
         @assertTrue(active)
         call snapshot_timer(timer, state)
         @assertEqual(2, state%call_stack%depth)
         @assertEqual(1, state%call_stack%top())

         fake_time = 3.0_wp
         call timer%stop("A", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 5.0_wp
         call guard%stop(ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end block

      call snapshot_timer(timer, state)
      @assertEqual(0, state%call_stack%depth)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_same_name_inner_activation_does_not_satisfy_outer_guard

   @test
   subroutine test_stale_guard_does_not_stop_later_matching_timer()
      type(ftimer_t), target :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "A", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 1.0_wp
         call timer%stop("A", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         fake_time = 2.0_wp
         call timer%start("A", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         call guard%stop(ierr=ierr)

         @assertEqual(FTIMER_ERR_MISMATCH, ierr)
         call snapshot_timer(timer, state)
         @assertEqual(1, state%call_stack%depth)

         fake_time = 4.0_wp
         call timer%stop("A", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end block

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_stale_guard_does_not_stop_later_matching_timer

   @test
   subroutine test_assigned_active_guard_is_left_inactive()
      type(ftimer_t), target :: timer
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: ierr
      integer :: saved_fd
      logical :: copy_active
      logical :: has_warning

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      block
         type(ftimer_guard_t) :: guard
         type(ftimer_guard_t) :: guard_copy

         call start_oop_scope(timer, guard, "A", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         call begin_stderr_capture('test_assigned_active_guard_is_left_inactive.err', saved_fd, capture_ierr)
         @assertEqual(0, capture_ierr)

         guard_copy = guard

         call end_stderr_capture('test_assigned_active_guard_is_left_inactive.err', saved_fd, stderr_text, &
                                 capture_ierr)
         @assertEqual(0, capture_ierr)

         copy_active = guard_copy%is_active()
         has_warning = index(stderr_text, 'ftimer scoped guards are not copyable') > 0

         @assertFalse(copy_active)
         @assertTrue(has_warning)

         fake_time = 2.0_wp
         call guard%stop(ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end block

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_assigned_active_guard_is_left_inactive

   @test
   subroutine test_assignment_to_active_guard_is_ignored()
      type(ftimer_t), target :: timer
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: ierr
      integer :: saved_fd
      logical :: has_warning
      logical :: original_active

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      block
         type(ftimer_guard_t) :: guard
         type(ftimer_guard_t) :: inactive_guard

         call start_oop_scope(timer, guard, "A", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 1.0_wp

         call begin_stderr_capture('test_assignment_to_active_guard_is_ignored.err', saved_fd, capture_ierr)
         @assertEqual(0, capture_ierr)

         guard = inactive_guard

         call end_stderr_capture('test_assignment_to_active_guard_is_ignored.err', saved_fd, stderr_text, &
                                 capture_ierr)
         @assertEqual(0, capture_ierr)

         original_active = guard%is_active()
         has_warning = index(stderr_text, 'assignment to active guard ignored') > 0

         @assertTrue(original_active)
         @assertTrue(has_warning)

         fake_time = 5.0_wp
      end block

      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, summary%num_entries)
      @assertEqual(5.0_wp, summary%entries(1)%inclusive_time)
      @assertFalse(summary%has_active_timers)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_assignment_to_active_guard_is_ignored

   @test
   subroutine test_guard_stops_on_procedure_return()
      type(ftimer_t), target :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call timed_procedure_return(timer, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, summary%num_entries)
      @assertEqual(2.0_wp, summary%entries(1)%inclusive_time)
      @assertFalse(summary%has_active_timers)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_guard_stops_on_procedure_return

   @test
   subroutine test_procedural_scope_uses_default_instance()
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      block
         type(ftimer_guard_t) :: guard

         call ftimer_scope(guard, "procedural", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 1.25_wp
      end block

      call ftimer_get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, summary%num_entries)
      @assertEqual("procedural", trim(summary%entries(1)%name))
      @assertEqual(1.25_wp, summary%entries(1)%inclusive_time)
      @assertFalse(summary%has_active_timers)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_scope_uses_default_instance

   @test
   subroutine test_procedural_scope_id_uses_default_instance()
      type(ftimer_summary_t) :: summary
      integer :: id
      integer :: ierr

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      id = ftimer_lookup("procedural_id", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      block
         type(ftimer_guard_t) :: guard

         call ftimer_scope_id(guard, id, ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 2.75_wp
      end block

      call ftimer_get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, summary%num_entries)
      @assertEqual("procedural_id", trim(summary%entries(1)%name))
      @assertEqual(1, summary%entries(1)%call_count)
      @assertEqual(2.75_wp, summary%entries(1)%inclusive_time)
      @assertFalse(summary%has_active_timers)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_scope_id_uses_default_instance

   @test
   subroutine test_scoped_guard_callbacks_are_normal_start_stop_events()
      type(ftimer_t), target :: timer
      integer :: ierr
      logical :: first_event_is_start
      logical :: second_event_is_stop

      call reset_callback_log()
      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call timer%set_callback(record_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "callback", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 6.0_wp
      end block

      first_event_is_start = callback_events(1) == FTIMER_EVENT_START
      second_event_is_stop = callback_events(2) == FTIMER_EVENT_STOP

      @assertEqual(2, callback_count)
      @assertTrue(first_event_is_start)
      @assertTrue(second_event_is_stop)
      @assertEqual(0.0_wp, callback_timestamps(1))
      @assertEqual(6.0_wp, callback_timestamps(2))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_scoped_guard_callbacks_are_normal_start_stop_events

   @test
   subroutine test_explicit_guard_stop_fires_single_stop_callback()
      type(ftimer_t), target :: timer
      integer :: ierr
      logical :: first_event_is_start
      logical :: second_event_is_stop

      call reset_callback_log()
      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call timer%set_callback(record_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "callback_explicit", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 2.0_wp
         call guard%stop(ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 5.0_wp
      end block

      first_event_is_start = callback_events(1) == FTIMER_EVENT_START
      second_event_is_stop = callback_events(2) == FTIMER_EVENT_STOP

      @assertEqual(2, callback_count)
      @assertTrue(first_event_is_start)
      @assertTrue(second_event_is_stop)
      @assertEqual(0.0_wp, callback_timestamps(1))
      @assertEqual(2.0_wp, callback_timestamps(2))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_explicit_guard_stop_fires_single_stop_callback

   @test
   subroutine test_finalizer_mismatch_warns_without_repairing()
      type(ftimer_t), target :: timer
      type(ftimer_test_state_t) :: state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: ierr
      integer :: saved_fd
      logical :: has_warning

      call timer%init(mismatch_mode=FTIMER_MISMATCH_REPAIR, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call reset_callback_log()
      call timer%set_callback(record_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call begin_stderr_capture('test_finalizer_mismatch_warns_without_repairing.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      block
         type(ftimer_guard_t) :: guard

         call start_oop_scope(timer, guard, "A", ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 1.0_wp
         call timer%start("B", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 3.0_wp
      end block

      call end_stderr_capture('test_finalizer_mismatch_warns_without_repairing.err', saved_fd, stderr_text, &
                              capture_ierr)
      @assertEqual(0, capture_ierr)

      has_warning = index(stderr_text, 'ftimer scoped guard finalizer could not stop A because top of stack is B') > 0
      @assertTrue(has_warning)
      @assertEqual(2, callback_count)
      @assertEqual(FTIMER_EVENT_START, callback_events(1))
      @assertEqual(FTIMER_EVENT_START, callback_events(2))

      call snapshot_timer(timer, state)
      @assertEqual(2, state%call_stack%depth)
      @assertEqual(2, state%call_stack%top())

      call timer%stop("B", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%stop("A", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_finalizer_mismatch_warns_without_repairing

   subroutine record_callback(timer_id, context_idx, event, timestamp, user_data)
      integer, intent(in) :: timer_id
      integer, intent(in) :: context_idx
      integer, intent(in) :: event
      real(wp), intent(in) :: timestamp
      type(c_ptr), intent(in) :: user_data
      integer :: slot

      if (callback_count >= max_events) error stop 1

      slot = callback_count + 1
      callback_count = slot
      callback_events(slot) = event
      callback_timestamps(slot) = timestamp
   end subroutine record_callback

   subroutine reset_callback_log()
      callback_count = 0
      callback_events = 0
      callback_timestamps = 0.0_wp
   end subroutine reset_callback_log

   subroutine start_oop_scope(timer, guard, name, ierr)
      type(ftimer_t), target, intent(inout) :: timer
      type(ftimer_guard_t), intent(inout) :: guard
      character(len=*), intent(in) :: name
      integer, intent(out) :: ierr
      type(ftimer_t), pointer :: timer_ptr

      timer_ptr => timer
      call ftimer_core_scope(timer_ptr, guard, name, ierr=ierr)
   end subroutine start_oop_scope

   subroutine start_oop_scope_id(timer, guard, id, ierr)
      type(ftimer_t), target, intent(inout) :: timer
      type(ftimer_guard_t), intent(inout) :: guard
      integer, intent(in) :: id
      integer, intent(out) :: ierr
      type(ftimer_t), pointer :: timer_ptr

      timer_ptr => timer
      call ftimer_core_scope_id(timer_ptr, guard, id, ierr=ierr)
   end subroutine start_oop_scope_id

   subroutine timed_procedure_return(timer, ierr)
      type(ftimer_t), target, intent(inout) :: timer
      integer, intent(out) :: ierr
      type(ftimer_guard_t) :: guard

      call start_oop_scope(timer, guard, "procedure", ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 2.0_wp
      return
   end subroutine timed_procedure_return

end module test_scoped_guard
