module test_summary
   use, intrinsic :: iso_c_binding, only: c_ptr
   use pfunit
   use ftimer_core, only: ftimer_t
   use ftimer_summary, only: build_summary, format_mpi_summary, format_mpi_union_summary, format_summary
   use ftimer_types, only: FTIMER_EVENT_START, FTIMER_EVENT_STOP, FTIMER_MISMATCH_REPAIR, FTIMER_NAME_LEN, &
                           FTIMER_SUCCESS, &
                           ftimer_call_stack_t, ftimer_metadata_t, ftimer_mpi_summary_t, ftimer_mpi_union_summary_t, &
                           ftimer_segment_t, ftimer_summary_entry_t, &
                           ftimer_summary_t, wp
   use test_support, only: attach_mock_clock, begin_stderr_capture, build_stack, end_stderr_capture, fake_time, &
                           mock_clock, reset_mock_clock_state, read_unit_text
   implicit none

   integer, save :: snapshot_callback_count = 0

contains

   @test
   subroutine test_get_summary_returns_structured_entries()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr
      integer :: entry_count
      integer :: trimmed_start
      integer :: trimmed_end
      logical :: first_name_matches
      logical :: second_name_matches
      logical :: third_name_matches
      real(wp) :: total_time
      real(wp) :: first_pct
      real(wp) :: second_pct
      real(wp) :: third_pct
      real(wp) :: pct_diff

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 2.0_wp
      call timer%start("B", ierr=ierr)
      fake_time = 9.0_wp
      call timer%stop("B", ierr=ierr)
      fake_time = 10.0_wp
      call timer%stop("A", ierr=ierr)

      call timer%start("C", ierr=ierr)
      fake_time = 15.0_wp
      call timer%stop("C", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)

      entry_count = summary%num_entries
      total_time = summary%total_time
      trimmed_start = len_trim(summary%start_date)
      trimmed_end = len_trim(summary%end_date)
      first_name_matches = trim(summary%entries(1)%name) == 'A'
      second_name_matches = trim(summary%entries(2)%name) == 'B'
      third_name_matches = trim(summary%entries(3)%name) == 'C'
      first_pct = 100.0_wp*10.0_wp/15.0_wp
      second_pct = 100.0_wp*7.0_wp/15.0_wp
      third_pct = 100.0_wp*5.0_wp/15.0_wp

      @assertEqual(3, entry_count)
      @assertEqual(15.0_wp, total_time)
      @assertFalse(summary%has_active_timers)
      @assertTrue(trimmed_start > 0)
      @assertTrue(trimmed_end > 0)
      @assertTrue(first_name_matches)
      @assertTrue(second_name_matches)
      @assertTrue(third_name_matches)
      call assert_node_ids_are_unique(summary)
      @assertEqual(0, summary%entries(1)%depth)
      @assertEqual(1, summary%entries(2)%depth)
      @assertEqual(0, summary%entries(3)%depth)
      call assert_entry_parent(summary, 1, 0)
      call assert_entry_parent(summary, 2, 1)
      call assert_entry_parent(summary, 3, 0)
      @assertEqual(10.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(7.0_wp, summary%entries(2)%inclusive_time)
      @assertEqual(5.0_wp, summary%entries(3)%inclusive_time)
      @assertEqual(3.0_wp, summary%entries(1)%self_time)
      @assertEqual(7.0_wp, summary%entries(2)%self_time)
      @assertEqual(5.0_wp, summary%entries(3)%self_time)
      @assertEqual(1, summary%entries(1)%call_count)
      @assertEqual(1, summary%entries(2)%call_count)
      @assertEqual(1, summary%entries(3)%call_count)
      @assertEqual(10.0_wp, summary%entries(1)%avg_time)
      @assertEqual(7.0_wp, summary%entries(2)%avg_time)
      @assertEqual(5.0_wp, summary%entries(3)%avg_time)

      pct_diff = abs(summary%entries(1)%pct_time - first_pct)
      @assertTrue(pct_diff < 1.0e-12_wp)
      pct_diff = abs(summary%entries(2)%pct_time - second_pct)
      @assertTrue(pct_diff < 1.0e-12_wp)
      pct_diff = abs(summary%entries(3)%pct_time - third_pct)
      @assertTrue(pct_diff < 1.0e-12_wp)
   end subroutine test_get_summary_returns_structured_entries

   @test
   subroutine test_summary_entry_positional_ctor_keeps_legacy_order()
      type(ftimer_summary_entry_t) :: entry

      entry = ftimer_summary_entry_t('work', 1, 4.0_wp, 1.5_wp, 2, 2.0_wp, 40.0_wp)

      @assertEqual('work', trim(entry%name))
      @assertEqual(1, entry%depth)
      @assertEqual(4.0_wp, entry%inclusive_time)
      @assertEqual(1.5_wp, entry%self_time)
      @assertEqual(2, entry%call_count)
      @assertEqual(2.0_wp, entry%avg_time)
      @assertEqual(40.0_wp, entry%pct_time)
      @assertEqual(0, entry%node_id)
      @assertEqual(0, entry%parent_id)
      @assertFalse(entry%is_active)
      @assertEqual(0, entry%timer_context_count)
   end subroutine test_summary_entry_positional_ctor_keeps_legacy_order

   @test
   subroutine test_summary_positional_ctor_keeps_legacy_order()
      type(ftimer_summary_entry_t), allocatable :: entries(:)
      type(ftimer_summary_t) :: summary

      allocate (entries(1))
      entries(1)%name = 'work'

      summary = ftimer_summary_t('start', 'end', 3.0_wp, 1, entries)

      @assertEqual('start', trim(summary%start_date))
      @assertEqual('end', trim(summary%end_date))
      @assertEqual(3.0_wp, summary%total_time)
      @assertEqual(1, summary%num_entries)
      @assertEqual('work', trim(summary%entries(1)%name))
      @assertFalse(summary%has_active_timers)
      @assertEqual(0, summary%total_contexts)
      @assertEqual(0, summary%max_contexts_per_timer)
   end subroutine test_summary_positional_ctor_keeps_legacy_order

   @test
   subroutine test_print_summary_writes_expected_text_with_metadata()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      type(ftimer_metadata_t) :: metadata(2)
      character(len=:), allocatable :: actual
      character(len=:), allocatable :: expected
      integer :: ierr
      integer :: unit
      logical :: texts_match

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 2.0_wp
      call timer%start("B", ierr=ierr)
      fake_time = 9.0_wp
      call timer%stop("B", ierr=ierr)
      fake_time = 10.0_wp
      call timer%stop("A", ierr=ierr)

      metadata(1)%key = 'Case'
      metadata(1)%value = 'Unit'
      metadata(2)%key = 'Steps'
      metadata(2)%value = '4'

      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      open (newunit=unit, status='scratch', action='readwrite')
      call timer%print_summary(unit=unit, metadata=metadata, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      actual = read_unit_text(unit)
      expected = expected_summary_output(summary, metadata)
      texts_match = actual == expected

      close (unit)

      @assertTrue(texts_match)
   end subroutine test_print_summary_writes_expected_text_with_metadata

   @test
   subroutine test_active_snapshot_does_not_mutate_runtime_or_fire_callbacks()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: active_summary
      type(ftimer_summary_t) :: final_summary
      character(len=:), allocatable :: text
      integer :: ierr
      integer :: unit
      logical :: row_marked_active

      call reset_snapshot_callback_count()
      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)
      call timer%set_callback(count_snapshot_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%start("A", ierr=ierr)
      @assertEqual(1, snapshot_callback_count)

      fake_time = 2.0_wp
      call timer%get_summary(active_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, snapshot_callback_count)

      open (newunit=unit, status='scratch', action='readwrite')
      fake_time = 3.0_wp
      call timer%print_summary(unit=unit, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, snapshot_callback_count)
      close (unit)

      call format_summary(active_summary, text)
      row_marked_active = index(text, 'A               2.000000      2.000000         1    100.00  yes') > 0

      @assertTrue(active_summary%has_active_timers)
      @assertTrue(active_summary%entries(1)%is_active)
      @assertTrue(row_marked_active)

      fake_time = 5.0_wp
      call timer%stop("A", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, snapshot_callback_count)

      call timer%get_summary(final_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertFalse(final_summary%has_active_timers)
      @assertFalse(final_summary%entries(1)%is_active)
      @assertEqual(5.0_wp, final_summary%entries(1)%inclusive_time)
      @assertEqual(5.0_wp, final_summary%entries(1)%self_time)
   end subroutine test_active_snapshot_does_not_mutate_runtime_or_fire_callbacks

   @test
   subroutine test_print_summary_handles_deep_hierarchy()
      type(ftimer_t) :: timer
      character(len=:), allocatable :: actual
      character(len=:), allocatable :: expected_prefix
      logical :: entry_present
      logical :: flattened_deepest_as_root
      integer :: ierr
      integer :: i
      integer :: line_count
      integer :: line_pos
      integer :: previous_pos
      integer :: unit
      character(len=8) :: name

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      do i = 1, 130
         write (name, '("Depth",i3.3)') i
         call timer%start(trim(name), ierr=ierr)
         fake_time = fake_time + 1.0_wp
      end do

      do i = 130, 1, -1
         write (name, '("Depth",i3.3)') i
         fake_time = fake_time + 1.0_wp
         call timer%stop(trim(name), ierr=ierr)
      end do

      open (newunit=unit, status='scratch', action='readwrite')
      call timer%print_summary(unit=unit, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      actual = read_unit_text(unit)
      line_count = count_lines(actual)
      previous_pos = 0

      do i = 1, 130
         expected_prefix = deep_hierarchy_prefix(i)
         line_pos = index(actual, new_line('a')//expected_prefix)
         entry_present = line_pos > 0
         @assertTrue(entry_present)
         @assertTrue(line_pos > previous_pos)
         previous_pos = line_pos
      end do

      flattened_deepest_as_root = index(actual, new_line('a')//'Depth130') > 0

      close (unit)

      @assertEqual(134, line_count)
      @assertFalse(flattened_deepest_as_root)
   end subroutine test_print_summary_handles_deep_hierarchy

   @test
   subroutine test_get_summary_surfaces_backward_clock_deltas()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: active_line_present
      logical :: active_note_present
      logical :: active_row_present
      integer :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = -1.0_wp
      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(-1.0_wp, summary%total_time)
      @assertEqual(1, summary%num_entries)
      @assertTrue(summary%has_active_timers)
      @assertTrue(summary%entries(1)%is_active)
      @assertEqual(-1.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(-1.0_wp, summary%entries(1)%self_time)

      call format_summary(summary, text)
      active_line_present = index(text, 'Active timers  : yes') > 0
      active_note_present = index(text, 'Snapshot note : active timers are included through the snapshot timestamp.') > 0
      active_row_present = index(text, 'yes') > 0

      @assertTrue(active_line_present)
      @assertTrue(active_note_present)
      @assertTrue(active_row_present)
   end subroutine test_get_summary_surfaces_backward_clock_deltas

   @test
   subroutine test_active_nested_snapshot_preserves_tree_and_self_time()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("outer", ierr=ierr)
      fake_time = 2.0_wp
      call timer%start("inner", ierr=ierr)
      fake_time = 5.0_wp
      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertTrue(summary%has_active_timers)
      @assertEqual(2, summary%num_entries)
      @assertEqual('outer', trim(summary%entries(1)%name))
      @assertEqual('inner', trim(summary%entries(2)%name))
      @assertTrue(summary%entries(1)%is_active)
      @assertTrue(summary%entries(2)%is_active)
      @assertEqual(5.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(3.0_wp, summary%entries(2)%inclusive_time)
      @assertEqual(2.0_wp, summary%entries(1)%self_time)
      @assertEqual(3.0_wp, summary%entries(2)%self_time)
      call assert_entry_parent(summary, 1, 0)
      call assert_entry_parent(summary, 2, 1)
   end subroutine test_active_nested_snapshot_preserves_tree_and_self_time

   @test
   subroutine test_active_snapshot_marks_mixed_active_and_stopped_rows()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: active_row_present
      logical :: stopped_row_present
      integer :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("stopped", ierr=ierr)
      fake_time = 1.0_wp
      call timer%stop("stopped", ierr=ierr)
      fake_time = 2.0_wp
      call timer%start("running", ierr=ierr)
      fake_time = 5.0_wp
      call timer%get_summary(summary, ierr=ierr)

      call format_summary(summary, text)
      stopped_row_present = index(text, 'stopped         1.000000      1.000000         1     20.00  no') > 0
      active_row_present = index(text, 'running         3.000000      3.000000         1     60.00  yes') > 0

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertTrue(summary%has_active_timers)
      @assertFalse(summary%entries(1)%is_active)
      @assertTrue(summary%entries(2)%is_active)
      @assertTrue(stopped_row_present)
      @assertTrue(active_row_present)
   end subroutine test_active_snapshot_marks_mixed_active_and_stopped_rows

   @test
   subroutine test_repair_snapshot_marks_zero_call_active_context()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      integer :: child_b_idx
      integer :: ierr
      integer :: root_b_idx
      logical :: continuation_row_present

      call timer%init(mismatch_mode=FTIMER_MISMATCH_REPAIR, ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%start("B", ierr=ierr)
      fake_time = 2.0_wp
      call timer%stop("A", ierr=ierr)
      fake_time = 5.0_wp
      call timer%get_summary(summary, ierr=ierr)

      child_b_idx = find_summary_entry(summary, "B", 1)
      root_b_idx = find_summary_entry(summary, "B", 0)
      call format_summary(summary, text)
      continuation_row_present = index(text, 'B               3.000000      3.000000         0     60.00  yes') > 0

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertTrue(summary%has_active_timers)
      @assertTrue(child_b_idx > 0)
      @assertTrue(root_b_idx > 0)
      @assertFalse(summary%entries(child_b_idx)%is_active)
      @assertTrue(summary%entries(root_b_idx)%is_active)
      @assertEqual(1, summary%entries(child_b_idx)%call_count)
      @assertEqual(0, summary%entries(root_b_idx)%call_count)
      @assertEqual(0.0_wp, summary%entries(root_b_idx)%avg_time)
      @assertTrue(continuation_row_present)
   end subroutine test_repair_snapshot_marks_zero_call_active_context

   @test
   subroutine test_format_summary_derives_active_header_from_entries()
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: active_header_present
      logical :: active_row_present

      summary%total_time = 2.0_wp
      summary%num_entries = 1
      summary%has_active_timers = .false.
      allocate (summary%entries(1))
      summary%entries(1)%name = 'manual'
      summary%entries(1)%inclusive_time = 2.0_wp
      summary%entries(1)%self_time = 2.0_wp
      summary%entries(1)%call_count = 1
      summary%entries(1)%pct_time = 100.0_wp
      summary%entries(1)%is_active = .true.

      call format_summary(summary, text)
      active_header_present = index(text, 'Active timers  : yes') > 0
      active_row_present = index(text, 'manual          2.000000      2.000000         1    100.00  yes') > 0

      @assertTrue(active_header_present)
      @assertTrue(active_row_present)
   end subroutine test_format_summary_derives_active_header_from_entries

   @test
   subroutine test_format_summary_ignores_stale_top_level_active_flag()
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: active_header_present
      logical :: active_column_present

      summary%total_time = 2.0_wp
      summary%num_entries = 1
      summary%has_active_timers = .true.
      allocate (summary%entries(1))
      summary%entries(1)%name = 'manual'
      summary%entries(1)%inclusive_time = 2.0_wp
      summary%entries(1)%self_time = 2.0_wp
      summary%entries(1)%call_count = 1
      summary%entries(1)%pct_time = 100.0_wp
      summary%entries(1)%is_active = .false.

      call format_summary(summary, text)
      active_header_present = index(text, 'Active timers') > 0
      active_column_present = index(text, 'Active') > 0

      @assertFalse(active_header_present)
      @assertFalse(active_column_present)
   end subroutine test_format_summary_ignores_stale_top_level_active_flag

   @test
   subroutine test_format_summary_ignores_empty_stale_top_level_active_flag()
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: active_header_present
      logical :: active_column_present

      summary%total_time = 2.0_wp
      summary%num_entries = 0
      summary%has_active_timers = .true.
      allocate (summary%entries(0))

      call format_summary(summary, text)
      active_header_present = index(text, 'Active timers') > 0
      active_column_present = index(text, 'Active') > 0

      @assertFalse(active_header_present)
      @assertFalse(active_column_present)
   end subroutine test_format_summary_ignores_empty_stale_top_level_active_flag

   @test
   subroutine test_format_summary_skips_active_status_metadata_collision()
      type(ftimer_metadata_t) :: metadata(2)
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: active_header_present
      logical :: conflicting_header_present
      logical :: user_metadata_present

      summary%total_time = 2.0_wp
      summary%num_entries = 1
      summary%has_active_timers = .true.
      allocate (summary%entries(1))
      summary%entries(1)%name = 'manual'
      summary%entries(1)%inclusive_time = 2.0_wp
      summary%entries(1)%self_time = 2.0_wp
      summary%entries(1)%call_count = 1
      summary%entries(1)%pct_time = 100.0_wp
      summary%entries(1)%is_active = .true.
      metadata(1)%key = 'Active timers'
      metadata(1)%value = 'no'
      metadata(2)%key = 'Case'
      metadata(2)%value = 'Unit'

      call format_summary(summary, text, metadata)
      active_header_present = index(text, 'Active timers  : yes') > 0
      conflicting_header_present = index(text, 'Active timers  : no') > 0
      user_metadata_present = index(text, 'Case           : Unit') > 0

      @assertTrue(active_header_present)
      @assertFalse(conflicting_header_present)
      @assertTrue(user_metadata_present)
   end subroutine test_format_summary_skips_active_status_metadata_collision

   @test
   subroutine test_format_summary_preserves_metadata_above_legacy_len()
      type(ftimer_metadata_t) :: metadata(1)
      type(ftimer_summary_t) :: summary
      character(len=FTIMER_NAME_LEN + 24) :: long_key
      character(len=FTIMER_NAME_LEN + 40) :: long_value
      character(len=:), allocatable :: expected_line
      character(len=:), allocatable :: text
      integer :: expected_key_len
      integer :: expected_value_len
      integer :: stored_key_len
      integer :: stored_value_len
      logical :: long_metadata_present

      long_key = repeat('k', len(long_key))
      long_value = repeat('v', len(long_value))
      expected_key_len = len(long_key)
      expected_value_len = len(long_value)

      summary%total_time = 1.0_wp
      summary%num_entries = 0
      allocate (summary%entries(0))
      metadata(1)%key = long_key
      metadata(1)%value = long_value

      call format_summary(summary, text, metadata)

      stored_key_len = len_trim(metadata(1)%key)
      stored_value_len = len_trim(metadata(1)%value)
      expected_line = long_key//' : '//long_value
      long_metadata_present = index(text, expected_line) > 0

      @assertEqual(expected_key_len, stored_key_len)
      @assertEqual(expected_value_len, stored_value_len)
      @assertTrue(long_metadata_present)
   end subroutine test_format_summary_preserves_metadata_above_legacy_len

   @test
   subroutine test_format_summary_handles_unallocated_metadata_fields()
      type(ftimer_metadata_t) :: metadata(3)
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: blank_value_key_present
      logical :: orphan_value_skipped

      summary%total_time = 1.0_wp
      summary%num_entries = 0
      allocate (summary%entries(0))
      metadata(2)%value = 'orphan-value'
      metadata(3)%key = 'BlankValue'

      call format_summary(summary, text, metadata)

      blank_value_key_present = index(text, 'BlankValue') > 0
      orphan_value_skipped = index(text, 'orphan-value') == 0

      @assertTrue(blank_value_key_present)
      @assertTrue(orphan_value_skipped)
   end subroutine test_format_summary_handles_unallocated_metadata_fields

   @test
   subroutine test_format_summary_escapes_metadata_controls()
      type(ftimer_metadata_t) :: metadata(17)
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text

      summary%total_time = 1.0_wp
      summary%num_entries = 0
      allocate (summary%entries(0))
      call set_control_metadata(metadata)

      call format_summary(summary, text, metadata)
      call assert_metadata_controls_escaped(text)
   end subroutine test_format_summary_escapes_metadata_controls

   @test
   subroutine test_format_mpi_summary_escapes_metadata_controls()
      type(ftimer_metadata_t) :: metadata(17)
      type(ftimer_mpi_summary_t) :: summary
      character(len=:), allocatable :: text

      summary%num_ranks = 2
      summary%num_entries = 0
      call set_control_metadata(metadata)

      call format_mpi_summary(summary, text, metadata)
      call assert_metadata_controls_escaped(text)
   end subroutine test_format_mpi_summary_escapes_metadata_controls

   @test
   subroutine test_format_mpi_union_summary_escapes_metadata_controls()
      type(ftimer_metadata_t) :: metadata(17)
      type(ftimer_mpi_union_summary_t) :: summary
      character(len=:), allocatable :: text

      summary%num_ranks = 2
      summary%num_entries = 0
      call set_control_metadata(metadata)

      call format_mpi_union_summary(summary, text, metadata)
      call assert_metadata_controls_escaped(text)
   end subroutine test_format_mpi_union_summary_escapes_metadata_controls

   subroutine set_control_metadata(metadata)
      type(ftimer_metadata_t), intent(out) :: metadata(:)

      metadata(1)%key = 'Line'//achar(10)//'Key'
      metadata(1)%value = 'line'//achar(10)//'value'
      metadata(2)%key = 'Carriage'
      metadata(2)%value = 'car'//achar(13)//'return'
      metadata(3)%key = 'Tab'
      metadata(3)%value = 'tab'//achar(9)//'value'
      metadata(4)%key = 'Delete'
      metadata(4)%value = 'del'//achar(127)//'value'
      metadata(5)%key = 'Escape'
      metadata(5)%value = 'esc'//achar(27)//'[31m'
      metadata(6)%key = '  Path\KeyWide'
      metadata(6)%value = '  Value\Tail'
      metadata(7)%key = 'C1CSI'
      metadata(7)%value = 'csi'//achar(155)//'value'
      metadata(8)%key = 'C1Start'
      metadata(8)%value = 'start'//achar(128)//'value'
      metadata(9)%key = 'BlankValue'
      metadata(10)%key = 'Key'//achar(9)//'Name'
      metadata(10)%value = 'tab-key'
      metadata(11)%key = 'Key'//achar(13)//'Name'
      metadata(11)%value = 'carriage-key'
      metadata(12)%key = 'Key'//achar(127)//'Name'
      metadata(12)%value = 'delete-key'
      metadata(13)%key = 'Key'//achar(27)//'Name'
      metadata(13)%value = 'escape-key'
      metadata(14)%key = 'Key'//achar(155)//'Name'
      metadata(14)%value = 'c1-key'
      metadata(15)%key = 'EuroKey'
      metadata(15)%value = 'euro'//achar(226)//achar(130)//achar(172)//'value'
      metadata(16)%key = 'Euro'//achar(226)//achar(130)//achar(172)//'Key'
      metadata(16)%value = 'euro-key'
      metadata(17)%key = 'Utf8C1'
      metadata(17)%value = 'utf8-c1'//achar(194)//achar(155)//'value'
   end subroutine set_control_metadata

   subroutine assert_metadata_controls_escaped(text)
      character(len=*), intent(in) :: text
      logical :: blank_value_remains_blank
      logical :: corrupted_utf8_present
      logical :: encoded_c1_escaped
      logical :: escaped_carriage
      logical :: escaped_c1_csi
      logical :: escaped_c1_start
      logical :: escaped_delete
      logical :: escaped_escape
      logical :: escaped_key_controls
      logical :: escaped_leading_space_and_backslash
      logical :: escaped_newline
      logical :: escaped_tab
      logical :: preserved_utf8
      logical :: raw_carriage_present
      logical :: raw_c1_csi_present
      logical :: raw_c1_start_present
      logical :: raw_delete_present
      logical :: raw_escape_present
      logical :: raw_leading_space_or_backslash_present
      logical :: raw_newline_present
      logical :: raw_tab_present

      escaped_newline = index(text, 'Line\nKey') > 0
      escaped_newline = escaped_newline .and. (index(text, 'line\nvalue') > 0)
      escaped_carriage = index(text, 'car\rreturn') > 0
      escaped_tab = index(text, 'tab\tvalue') > 0
      escaped_delete = index(text, 'del\x7Fvalue') > 0
      escaped_escape = index(text, 'esc\x1B[31m') > 0
      escaped_leading_space_and_backslash = index(text, '\x20\x20Path\\KeyWide') > 0
      escaped_leading_space_and_backslash = escaped_leading_space_and_backslash .and. &
                                            (index(text, '\x20\x20Value\\Tail') > 0)
      escaped_c1_csi = index(text, 'csi\x9Bvalue') > 0
      escaped_c1_start = index(text, 'start\x80value') > 0
      escaped_key_controls = index(text, 'Key\tName') > 0
      escaped_key_controls = escaped_key_controls .and. (index(text, 'Key\rName') > 0)
      escaped_key_controls = escaped_key_controls .and. (index(text, 'Key\x7FName') > 0)
      escaped_key_controls = escaped_key_controls .and. (index(text, 'Key\x1BName') > 0)
      escaped_key_controls = escaped_key_controls .and. (index(text, 'Key\x9BName') > 0)
      blank_value_remains_blank = index(text, 'BlankValue            :'//new_line('a')) > 0
      blank_value_remains_blank = blank_value_remains_blank .and. &
                                  (index(text, 'BlankValue            : <blank>') == 0)
      preserved_utf8 = index(text, 'euro'//achar(226)//achar(130)//achar(172)//'value') > 0
      preserved_utf8 = preserved_utf8 .and. &
                       (index(text, 'Euro'//achar(226)//achar(130)//achar(172)//'Key') > 0)
      corrupted_utf8_present = index(text, 'euro'//achar(226)//'\x82'//achar(172)//'value') > 0
      corrupted_utf8_present = corrupted_utf8_present .or. &
                               (index(text, 'Euro'//achar(226)//'\x82'//achar(172)//'Key') > 0)
      encoded_c1_escaped = index(text, 'utf8-c1\xC2\x9Bvalue') > 0
      raw_newline_present = index(text, 'Line'//achar(10)//'Key') > 0
      raw_newline_present = raw_newline_present .or. (index(text, 'line'//achar(10)//'value') > 0)
      raw_carriage_present = index(text, 'car'//achar(13)//'return') > 0
      raw_tab_present = index(text, 'tab'//achar(9)//'value') > 0
      raw_delete_present = index(text, 'del'//achar(127)//'value') > 0
      raw_escape_present = index(text, 'esc'//achar(27)//'[31m') > 0
      raw_leading_space_or_backslash_present = index(text, '  Path\KeyWide') > 0
      raw_leading_space_or_backslash_present = raw_leading_space_or_backslash_present .or. &
                                               (index(text, 'Path\KeyWide') > 0)
      raw_leading_space_or_backslash_present = raw_leading_space_or_backslash_present .or. &
                                               (index(text, '  Value\Tail') > 0)
      raw_leading_space_or_backslash_present = raw_leading_space_or_backslash_present .or. &
                                               (index(text, 'Value\Tail') > 0)
      raw_c1_csi_present = index(text, 'csi'//achar(155)//'value') > 0
      raw_c1_start_present = index(text, 'start'//achar(128)//'value') > 0
      raw_c1_start_present = raw_c1_start_present .or. (index(text, achar(194)//achar(155)) > 0)

      @assertTrue(escaped_newline)
      @assertTrue(escaped_carriage)
      @assertTrue(escaped_tab)
      @assertTrue(escaped_delete)
      @assertTrue(escaped_escape)
      @assertTrue(escaped_leading_space_and_backslash)
      @assertTrue(escaped_c1_csi)
      @assertTrue(escaped_c1_start)
      @assertTrue(escaped_key_controls)
      @assertTrue(blank_value_remains_blank)
      @assertTrue(preserved_utf8)
      @assertTrue(encoded_c1_escaped)
      @assertFalse(raw_newline_present)
      @assertFalse(raw_carriage_present)
      @assertFalse(raw_tab_present)
      @assertFalse(raw_delete_present)
      @assertFalse(raw_escape_present)
      @assertFalse(raw_leading_space_or_backslash_present)
      @assertFalse(raw_c1_csi_present)
      @assertFalse(raw_c1_start_present)
      @assertFalse(corrupted_utf8_present)
   end subroutine assert_metadata_controls_escaped

   @test
   subroutine test_format_summary_preserves_utf8_names_and_metadata()
      type(ftimer_metadata_t) :: metadata(1)
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: corrupted_utf8_absent
      logical :: metadata_value_preserved
      logical :: name_preserved

      summary%total_time = 1.0_wp
      summary%num_entries = 1
      allocate (summary%entries(1))
      summary%entries(1)%name = 'name'//achar(226)//achar(130)//achar(172)
      summary%entries(1)%inclusive_time = 1.0_wp
      summary%entries(1)%self_time = 1.0_wp
      summary%entries(1)%call_count = 1
      summary%entries(1)%pct_time = 100.0_wp
      metadata(1)%key = 'Unit'
      metadata(1)%value = 'euro'//achar(226)//achar(130)//achar(172)//'value'

      call format_summary(summary, text, metadata)

      name_preserved = index(text, 'name'//achar(226)//achar(130)//achar(172)) > 0
      metadata_value_preserved = index(text, 'euro'//achar(226)//achar(130)//achar(172)//'value') > 0
      corrupted_utf8_absent = index(text, achar(226)//'\x82'//achar(172)) == 0

      @assertTrue(name_preserved)
      @assertTrue(metadata_value_preserved)
      @assertTrue(corrupted_utf8_absent)
   end subroutine test_format_summary_preserves_utf8_names_and_metadata

   @test
   subroutine test_get_summary_keeps_same_timer_distinct_across_parents()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr
      logical :: first_matches
      logical :: second_matches
      logical :: third_matches
      logical :: fourth_matches

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 3.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)

      call timer%start("B", ierr=ierr)
      fake_time = 5.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 8.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 9.0_wp
      call timer%stop("B", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      first_matches = trim(summary%entries(1)%name) == 'A'
      second_matches = trim(summary%entries(2)%name) == 'work'
      third_matches = trim(summary%entries(3)%name) == 'B'
      fourth_matches = trim(summary%entries(4)%name) == 'work'

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(4, summary%num_entries)
      @assertTrue(first_matches)
      @assertTrue(second_matches)
      @assertTrue(third_matches)
      @assertTrue(fourth_matches)
      call assert_node_ids_are_unique(summary)
      @assertEqual(0, summary%entries(1)%depth)
      @assertEqual(1, summary%entries(2)%depth)
      @assertEqual(0, summary%entries(3)%depth)
      @assertEqual(1, summary%entries(4)%depth)
      call assert_entry_parent(summary, 1, 0)
      call assert_entry_parent(summary, 2, 1)
      call assert_entry_parent(summary, 3, 0)
      call assert_entry_parent(summary, 4, 3)
      @assertEqual(4.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(2.0_wp, summary%entries(2)%inclusive_time)
      @assertEqual(5.0_wp, summary%entries(3)%inclusive_time)
      @assertEqual(3.0_wp, summary%entries(4)%inclusive_time)
      @assertEqual(2.0_wp, summary%entries(1)%self_time)
      @assertEqual(2.0_wp, summary%entries(2)%self_time)
      @assertEqual(2.0_wp, summary%entries(3)%self_time)
      @assertEqual(3.0_wp, summary%entries(4)%self_time)
      @assertTrue(summary%entries(2)%node_id /= summary%entries(4)%node_id)
   end subroutine test_get_summary_keeps_same_timer_distinct_across_parents

   @test
   subroutine test_get_summary_reports_context_cardinality()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr
      integer :: i
      integer :: parent_entry_count
      integer :: work_entry_count

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("work", ierr=ierr)
      fake_time = 1.0_wp
      call timer%stop("work", ierr=ierr)

      call timer%start("A", ierr=ierr)
      fake_time = 2.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 3.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)

      call timer%start("B", ierr=ierr)
      fake_time = 5.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 6.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 7.0_wp
      call timer%stop("B", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(5, summary%num_entries)
      @assertEqual(5, summary%total_contexts)
      @assertEqual(3, summary%max_contexts_per_timer)

      work_entry_count = 0
      parent_entry_count = 0
      do i = 1, summary%num_entries
         if (trim(summary%entries(i)%name) == 'work') then
            work_entry_count = work_entry_count + 1
            @assertEqual(3, summary%entries(i)%timer_context_count)
         else
            parent_entry_count = parent_entry_count + 1
            @assertEqual(1, summary%entries(i)%timer_context_count)
         end if
      end do

      @assertEqual(3, work_entry_count)
      @assertEqual(2, parent_entry_count)
   end subroutine test_get_summary_reports_context_cardinality

   @test
   subroutine test_context_cardinality_diagnostics_do_not_warn_by_default()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: captured
      character(len=*), parameter :: stderr_path = 'context_cardinality_default_stderr.txt'
      integer :: capture_ierr
      integer :: ierr
      integer :: saved_fd
      logical :: no_warning_emitted

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("outer_a", ierr=ierr)
      fake_time = 1.0_wp
      call timer%start("hot", ierr=ierr)
      fake_time = 2.0_wp
      call timer%stop("hot", ierr=ierr)
      fake_time = 3.0_wp
      call timer%stop("outer_a", ierr=ierr)

      call timer%start("outer_b", ierr=ierr)
      fake_time = 4.0_wp
      call timer%start("hot", ierr=ierr)
      fake_time = 5.0_wp
      call timer%stop("hot", ierr=ierr)
      fake_time = 6.0_wp
      call timer%stop("outer_b", ierr=ierr)

      call begin_stderr_capture(stderr_path, saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%get_summary(summary)
      call end_stderr_capture(stderr_path, saved_fd, captured, capture_ierr)
      @assertEqual(0, capture_ierr)

      no_warning_emitted = len_trim(captured) == 0

      @assertTrue(no_warning_emitted)
      @assertEqual(4, summary%total_contexts)
      @assertEqual(2, summary%max_contexts_per_timer)
   end subroutine test_context_cardinality_diagnostics_do_not_warn_by_default

   @test
   subroutine test_get_summary_preserves_large_time_precision()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      real(wp), parameter :: base_time = 1.0e12_wp
      real(wp) :: outer_diff
      real(wp) :: inner_diff
      real(wp) :: self_diff
      integer :: ierr

      call timer%init(ierr=ierr)
      call reset_mock_clock_state()
      fake_time = base_time
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%start("outer", ierr=ierr)
      fake_time = base_time + 1.25_wp
      call timer%start("inner", ierr=ierr)
      fake_time = base_time + 1.75_wp
      call timer%stop("inner", ierr=ierr)
      fake_time = base_time + 2.5_wp
      call timer%stop("outer", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, summary%num_entries)

      outer_diff = abs(summary%entries(1)%inclusive_time - 2.5_wp)
      inner_diff = abs(summary%entries(2)%inclusive_time - 0.5_wp)
      self_diff = abs(summary%entries(1)%self_time - 2.0_wp)

      @assertTrue(outer_diff < 1.0e-12_wp)
      @assertTrue(inner_diff < 1.0e-12_wp)
      @assertTrue(self_diff < 1.0e-12_wp)
      @assertTrue(abs(summary%total_time - 2.5_wp) < 1.0e-12_wp)
      @assertTrue(abs(summary%entries(2)%self_time - 0.5_wp) < 1.0e-12_wp)
      @assertEqual(1, summary%entries(1)%call_count)
      @assertEqual(1, summary%entries(2)%call_count)
   end subroutine test_get_summary_preserves_large_time_precision

   @test
   subroutine test_build_summary_skips_visible_child_without_visible_parent()
      type(ftimer_call_stack_t) :: root_stack
      type(ftimer_segment_t) :: segments(2)
      type(ftimer_summary_t) :: summary
      integer :: ctx

      segments(1)%name = 'A'
      ctx = segments(1)%contexts%add(root_stack)
      allocate (segments(1)%call_count(1))
      allocate (segments(1)%time(1))
      segments(1)%call_count(ctx) = 0
      segments(1)%time(ctx) = 0.0_wp

      segments(2)%name = 'B'
      ctx = segments(2)%contexts%add(build_stack([1]))
      allocate (segments(2)%call_count(1))
      allocate (segments(2)%time(1))
      segments(2)%call_count(ctx) = 1
      segments(2)%time(ctx) = 2.0_wp

      call build_summary(summary, segments, 0.0_wp, 'start', 2.0_wp, 'end')

      @assertEqual(0, summary%num_entries)
      @assertEqual(2.0_wp, summary%total_time)
   end subroutine test_build_summary_skips_visible_child_without_visible_parent

   @test
   subroutine test_format_summary_escapes_unsafe_names()
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: escaped_backslash
      logical :: escaped_blank_name
      logical :: escaped_carriage
      logical :: escaped_delete
      logical :: escaped_leading_space
      logical :: escaped_newline
      logical :: escaped_tab
      logical :: raw_carriage_name_present
      logical :: raw_delete_name_present
      logical :: raw_flattened_name_present
      logical :: raw_newline_name_present
      logical :: raw_tab_name_present

      summary%total_time = 7.0_wp
      summary%num_entries = 7
      allocate (summary%entries(7))

      summary%entries(1)%name = '  fake root'
      summary%entries(1)%inclusive_time = 1.0_wp
      summary%entries(1)%self_time = 1.0_wp
      summary%entries(1)%call_count = 1
      summary%entries(1)%pct_time = 14.28_wp

      summary%entries(2)%name = 'line'//achar(10)//'break'
      summary%entries(2)%inclusive_time = 1.0_wp
      summary%entries(2)%self_time = 1.0_wp
      summary%entries(2)%call_count = 1
      summary%entries(2)%pct_time = 14.28_wp

      summary%entries(3)%name = 'tab'//achar(9)//'name'
      summary%entries(3)%inclusive_time = 1.0_wp
      summary%entries(3)%self_time = 1.0_wp
      summary%entries(3)%call_count = 1
      summary%entries(3)%pct_time = 14.28_wp

      summary%entries(4)%name = 'line\nbreak'
      summary%entries(4)%inclusive_time = 1.0_wp
      summary%entries(4)%self_time = 1.0_wp
      summary%entries(4)%call_count = 1
      summary%entries(4)%pct_time = 14.28_wp

      summary%entries(5)%name = ''
      summary%entries(5)%inclusive_time = 1.0_wp
      summary%entries(5)%self_time = 1.0_wp
      summary%entries(5)%call_count = 1
      summary%entries(5)%pct_time = 14.29_wp

      summary%entries(6)%name = 'car'//achar(13)//'return'
      summary%entries(6)%inclusive_time = 1.0_wp
      summary%entries(6)%self_time = 1.0_wp
      summary%entries(6)%call_count = 1
      summary%entries(6)%pct_time = 14.29_wp

      summary%entries(7)%name = 'del'//achar(127)//'name'
      summary%entries(7)%inclusive_time = 1.0_wp
      summary%entries(7)%self_time = 1.0_wp
      summary%entries(7)%call_count = 1
      summary%entries(7)%pct_time = 14.30_wp

      call format_summary(summary, text)

      escaped_backslash = index(text, 'line\\nbreak') > 0
      escaped_blank_name = index(text, '<blank>') > 0
      escaped_carriage = index(text, 'car\rreturn') > 0
      escaped_delete = index(text, 'del\x7Fname') > 0
      escaped_leading_space = index(text, '\x20\x20fake root') > 0
      escaped_newline = index(text, 'line\nbreak') > 0
      escaped_tab = index(text, 'tab\tname') > 0
      raw_carriage_name_present = index(text, 'car'//achar(13)//'return') > 0
      raw_delete_name_present = index(text, 'del'//achar(127)//'name') > 0
      raw_flattened_name_present = index(text, new_line('a')//'  fake root') > 0
      raw_newline_name_present = index(text, 'line'//achar(10)//'break') > 0
      raw_tab_name_present = index(text, 'tab'//achar(9)//'name') > 0

      @assertTrue(escaped_backslash)
      @assertTrue(escaped_blank_name)
      @assertTrue(escaped_carriage)
      @assertTrue(escaped_delete)
      @assertTrue(escaped_leading_space)
      @assertTrue(escaped_newline)
      @assertTrue(escaped_tab)
      @assertFalse(raw_carriage_name_present)
      @assertFalse(raw_delete_name_present)
      @assertFalse(raw_flattened_name_present)
      @assertFalse(raw_newline_name_present)
      @assertFalse(raw_tab_name_present)
   end subroutine test_format_summary_escapes_unsafe_names

   function expected_summary_output(summary, metadata) result(text)
      type(ftimer_summary_t), intent(in) :: summary
      type(ftimer_metadata_t), intent(in) :: metadata(:)
      character(len=:), allocatable :: text
      character(len=256) :: line

      text = ''

      write (line, '(a,f0.6)') 'Total time (s) : ', summary%total_time
      text = text//trim(line)//new_line('a')
      text = text//'Case           : Unit'//new_line('a')
      text = text//'Steps          : 4'//new_line('a')
      text = text//new_line('a')
      text = text//'Timer name  Inclusive (s)     Self (s)    Calls   % Total'//new_line('a')
      text = text//'---------------------------------------------------------'//new_line('a')
      text = text//'A              10.000000      3.000000         1    100.00'//new_line('a')
      text = text//'  B             7.000000      7.000000         1     70.00'//new_line('a')
   end function expected_summary_output

   subroutine count_snapshot_callback(timer_id, context_idx, event, timestamp, user_data)
      integer, intent(in) :: timer_id
      integer, intent(in) :: context_idx
      integer, intent(in) :: event
      real(wp), intent(in) :: timestamp
      type(c_ptr), intent(in) :: user_data

      if ((event == FTIMER_EVENT_START) .or. (event == FTIMER_EVENT_STOP)) then
         snapshot_callback_count = snapshot_callback_count + 1
      end if
   end subroutine count_snapshot_callback

   subroutine reset_snapshot_callback_count()
      snapshot_callback_count = 0
   end subroutine reset_snapshot_callback_count

   integer function find_summary_entry(summary, name, depth) result(idx)
      type(ftimer_summary_t), intent(in) :: summary
      character(len=*), intent(in) :: name
      integer, intent(in) :: depth
      integer :: i

      idx = 0
      do i = 1, summary%num_entries
         if ((trim(summary%entries(i)%name) == name) .and. (summary%entries(i)%depth == depth)) then
            idx = i
            return
         end if
      end do
   end function find_summary_entry

   integer function count_lines(text) result(count)
      character(len=*), intent(in) :: text
      integer :: i

      count = 0
      do i = 1, len(text)
         if (text(i:i) == new_line('a')) count = count + 1
      end do
   end function count_lines

   function deep_hierarchy_prefix(level) result(prefix)
      integer, intent(in) :: level
      character(len=:), allocatable :: prefix
      character(len=8) :: name

      write (name, '("Depth",i3.3)') level
      prefix = repeat(' ', 2*(level - 1))//trim(name)
   end function deep_hierarchy_prefix

   subroutine assert_entry_parent(summary, entry_idx, parent_entry_idx)
      type(ftimer_summary_t), intent(in) :: summary
      integer, intent(in) :: entry_idx
      integer, intent(in) :: parent_entry_idx
      integer :: parent_id

      @assertTrue(summary%entries(entry_idx)%node_id > 0)
      parent_id = summary%entries(entry_idx)%parent_id
      if (parent_entry_idx <= 0) then
         @assertEqual(0, parent_id)
      else
         @assertEqual(summary%entries(parent_entry_idx)%node_id, parent_id)
      end if
   end subroutine assert_entry_parent

   subroutine assert_node_ids_are_unique(summary)
      type(ftimer_summary_t), intent(in) :: summary
      integer :: i
      integer :: j

      do i = 1, summary%num_entries
         @assertTrue(summary%entries(i)%node_id > 0)
         do j = i + 1, summary%num_entries
            @assertTrue(summary%entries(i)%node_id /= summary%entries(j)%node_id)
         end do
      end do
   end subroutine assert_node_ids_are_unique

end module test_summary
