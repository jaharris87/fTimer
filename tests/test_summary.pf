module test_summary
   use pfunit
   use ftimer_core, only: ftimer_t
   use ftimer_summary, only: build_summary, format_summary
   use ftimer_types, only: FTIMER_SUCCESS, ftimer_call_stack_t, ftimer_metadata_t, ftimer_segment_t, &
                           ftimer_summary_t, wp
   use test_support, only: attach_mock_clock, build_stack, fake_time, read_unit_text
   implicit none

contains

   @test
   subroutine test_get_summary_returns_structured_entries()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr
      integer :: entry_count
      integer :: trimmed_start
      integer :: trimmed_end
      logical :: has_mpi_data
      logical :: first_name_matches
      logical :: second_name_matches
      logical :: third_name_matches
      real(wp) :: total_time
      real(wp) :: first_pct
      real(wp) :: second_pct
      real(wp) :: third_pct
      real(wp) :: pct_diff

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 2.0_wp
      call timer%start("B", ierr=ierr)
      fake_time = 9.0_wp
      call timer%stop("B", ierr=ierr)
      fake_time = 10.0_wp
      call timer%stop("A", ierr=ierr)

      call timer%start("C", ierr=ierr)
      fake_time = 15.0_wp
      call timer%stop("C", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)

      entry_count = summary%num_entries
      total_time = summary%total_time
      trimmed_start = len_trim(summary%start_date)
      trimmed_end = len_trim(summary%end_date)
      has_mpi_data = summary%has_mpi_data
      first_name_matches = trim(summary%entries(1)%name) == 'A'
      second_name_matches = trim(summary%entries(2)%name) == 'B'
      third_name_matches = trim(summary%entries(3)%name) == 'C'
      first_pct = 100.0_wp*10.0_wp/15.0_wp
      second_pct = 100.0_wp*7.0_wp/15.0_wp
      third_pct = 100.0_wp*5.0_wp/15.0_wp

      @assertEqual(3, entry_count)
      @assertEqual(15.0_wp, total_time)
      @assertTrue(trimmed_start > 0)
      @assertTrue(trimmed_end > 0)
      @assertFalse(has_mpi_data)
      @assertTrue(first_name_matches)
      @assertTrue(second_name_matches)
      @assertTrue(third_name_matches)
      @assertEqual(0, summary%entries(1)%depth)
      @assertEqual(1, summary%entries(2)%depth)
      @assertEqual(0, summary%entries(3)%depth)
      @assertEqual(10.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(7.0_wp, summary%entries(2)%inclusive_time)
      @assertEqual(5.0_wp, summary%entries(3)%inclusive_time)
      @assertEqual(3.0_wp, summary%entries(1)%self_time)
      @assertEqual(7.0_wp, summary%entries(2)%self_time)
      @assertEqual(5.0_wp, summary%entries(3)%self_time)
      @assertEqual(1, summary%entries(1)%call_count)
      @assertEqual(1, summary%entries(2)%call_count)
      @assertEqual(1, summary%entries(3)%call_count)
      @assertEqual(10.0_wp, summary%entries(1)%avg_time)
      @assertEqual(7.0_wp, summary%entries(2)%avg_time)
      @assertEqual(5.0_wp, summary%entries(3)%avg_time)

      pct_diff = abs(summary%entries(1)%pct_time - first_pct)
      @assertTrue(pct_diff < 1.0e-12_wp)
      pct_diff = abs(summary%entries(2)%pct_time - second_pct)
      @assertTrue(pct_diff < 1.0e-12_wp)
      pct_diff = abs(summary%entries(3)%pct_time - third_pct)
      @assertTrue(pct_diff < 1.0e-12_wp)
   end subroutine test_get_summary_returns_structured_entries

   @test
   subroutine test_print_summary_writes_expected_text_with_metadata()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      type(ftimer_metadata_t) :: metadata(2)
      character(len=:), allocatable :: actual
      character(len=:), allocatable :: expected
      integer :: ierr
      integer :: unit
      logical :: texts_match

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 2.0_wp
      call timer%start("B", ierr=ierr)
      fake_time = 9.0_wp
      call timer%stop("B", ierr=ierr)
      fake_time = 10.0_wp
      call timer%stop("A", ierr=ierr)

      metadata(1)%key = 'Case'
      metadata(1)%value = 'Unit'
      metadata(2)%key = 'Steps'
      metadata(2)%value = '4'

      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      open (newunit=unit, status='scratch', action='readwrite')
      call timer%print_summary(unit=unit, metadata=metadata, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      actual = read_unit_text(unit)
      expected = expected_summary_output(summary, metadata)
      texts_match = actual == expected

      close (unit)

      @assertTrue(texts_match)
   end subroutine test_print_summary_writes_expected_text_with_metadata

   @test
   subroutine test_print_summary_handles_deep_hierarchy()
      type(ftimer_t) :: timer
      character(len=:), allocatable :: actual
      character(len=:), allocatable :: expected_prefix
      logical :: entry_present
      logical :: flattened_deepest_as_root
      integer :: ierr
      integer :: i
      integer :: line_count
      integer :: line_pos
      integer :: previous_pos
      integer :: unit
      character(len=8) :: name

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      do i = 1, 130
         write (name, '("Depth",i3.3)') i
         call timer%start(trim(name), ierr=ierr)
         fake_time = fake_time + 1.0_wp
      end do

      do i = 130, 1, -1
         write (name, '("Depth",i3.3)') i
         fake_time = fake_time + 1.0_wp
         call timer%stop(trim(name), ierr=ierr)
      end do

      open (newunit=unit, status='scratch', action='readwrite')
      call timer%print_summary(unit=unit, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      actual = read_unit_text(unit)
      line_count = count_lines(actual)
      previous_pos = 0

      do i = 1, 130
         expected_prefix = deep_hierarchy_prefix(i)
         line_pos = index(actual, new_line('a')//expected_prefix)
         entry_present = line_pos > 0
         @assertTrue(entry_present)
         @assertTrue(line_pos > previous_pos)
         previous_pos = line_pos
      end do

      flattened_deepest_as_root = index(actual, new_line('a')//'Depth130') > 0

      close (unit)

      @assertEqual(134, line_count)
      @assertFalse(flattened_deepest_as_root)
   end subroutine test_print_summary_handles_deep_hierarchy

   @test
   subroutine test_get_summary_surfaces_backward_clock_deltas()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = -1.0_wp
      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(-1.0_wp, summary%total_time)
      @assertEqual(1, summary%num_entries)
      @assertEqual(-1.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(-1.0_wp, summary%entries(1)%self_time)
   end subroutine test_get_summary_surfaces_backward_clock_deltas

   @test
   subroutine test_get_summary_keeps_same_timer_distinct_across_parents()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr
      logical :: first_matches
      logical :: second_matches
      logical :: third_matches
      logical :: fourth_matches

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 3.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)

      call timer%start("B", ierr=ierr)
      fake_time = 5.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 8.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 9.0_wp
      call timer%stop("B", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      first_matches = trim(summary%entries(1)%name) == 'A'
      second_matches = trim(summary%entries(2)%name) == 'work'
      third_matches = trim(summary%entries(3)%name) == 'B'
      fourth_matches = trim(summary%entries(4)%name) == 'work'

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(4, summary%num_entries)
      @assertTrue(first_matches)
      @assertTrue(second_matches)
      @assertTrue(third_matches)
      @assertTrue(fourth_matches)
      @assertEqual(0, summary%entries(1)%depth)
      @assertEqual(1, summary%entries(2)%depth)
      @assertEqual(0, summary%entries(3)%depth)
      @assertEqual(1, summary%entries(4)%depth)
      @assertEqual(4.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(2.0_wp, summary%entries(2)%inclusive_time)
      @assertEqual(5.0_wp, summary%entries(3)%inclusive_time)
      @assertEqual(3.0_wp, summary%entries(4)%inclusive_time)
      @assertEqual(2.0_wp, summary%entries(1)%self_time)
      @assertEqual(2.0_wp, summary%entries(2)%self_time)
      @assertEqual(2.0_wp, summary%entries(3)%self_time)
      @assertEqual(3.0_wp, summary%entries(4)%self_time)
   end subroutine test_get_summary_keeps_same_timer_distinct_across_parents

   @test
   subroutine test_get_summary_preserves_large_time_precision()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      real(wp), parameter :: base_time = 1.0e12_wp
      real(wp) :: outer_diff
      real(wp) :: inner_diff
      real(wp) :: self_diff
      integer :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      fake_time = base_time
      call timer%start("outer", ierr=ierr)
      fake_time = base_time + 1.25_wp
      call timer%start("inner", ierr=ierr)
      fake_time = base_time + 1.75_wp
      call timer%stop("inner", ierr=ierr)
      fake_time = base_time + 2.5_wp
      call timer%stop("outer", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      outer_diff = abs(summary%entries(1)%inclusive_time - 2.5_wp)
      inner_diff = abs(summary%entries(2)%inclusive_time - 0.5_wp)
      self_diff = abs(summary%entries(1)%self_time - 2.0_wp)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, summary%num_entries)
      @assertTrue(outer_diff < 1.0e-12_wp)
      @assertTrue(inner_diff < 1.0e-12_wp)
      @assertTrue(self_diff < 1.0e-12_wp)
      @assertTrue(abs(summary%total_time - 2.5_wp) < 1.0e-12_wp)
      @assertTrue(abs(summary%entries(2)%self_time - 0.5_wp) < 1.0e-12_wp)
      @assertEqual(1, summary%entries(1)%call_count)
      @assertEqual(1, summary%entries(2)%call_count)
   end subroutine test_get_summary_preserves_large_time_precision

   @test
   subroutine test_build_summary_skips_visible_child_without_visible_parent()
      type(ftimer_call_stack_t) :: root_stack
      type(ftimer_segment_t) :: segments(2)
      type(ftimer_summary_t) :: summary
      integer :: ctx

      segments(1)%name = 'A'
      ctx = segments(1)%contexts%add(root_stack)
      allocate (segments(1)%call_count(1))
      allocate (segments(1)%time(1))
      segments(1)%call_count(ctx) = 0
      segments(1)%time(ctx) = 0.0_wp

      segments(2)%name = 'B'
      ctx = segments(2)%contexts%add(build_stack([1]))
      allocate (segments(2)%call_count(1))
      allocate (segments(2)%time(1))
      segments(2)%call_count(ctx) = 1
      segments(2)%time(ctx) = 2.0_wp

      call build_summary(summary, segments, 0.0_wp, 'start', 2.0_wp, 'end')

      @assertEqual(0, summary%num_entries)
      @assertEqual(2.0_wp, summary%total_time)
   end subroutine test_build_summary_skips_visible_child_without_visible_parent

   @test
   subroutine test_format_summary_escapes_unsafe_names()
      type(ftimer_summary_t) :: summary
      character(len=:), allocatable :: text
      logical :: escaped_backslash
      logical :: escaped_blank_name
      logical :: escaped_carriage
      logical :: escaped_delete
      logical :: escaped_leading_space
      logical :: escaped_newline
      logical :: escaped_tab
      logical :: raw_carriage_name_present
      logical :: raw_delete_name_present
      logical :: raw_flattened_name_present
      logical :: raw_newline_name_present
      logical :: raw_tab_name_present

      summary%total_time = 7.0_wp
      summary%num_entries = 7
      allocate (summary%entries(7))

      summary%entries(1)%name = '  fake root'
      summary%entries(1)%inclusive_time = 1.0_wp
      summary%entries(1)%self_time = 1.0_wp
      summary%entries(1)%call_count = 1
      summary%entries(1)%pct_time = 14.28_wp

      summary%entries(2)%name = 'line'//achar(10)//'break'
      summary%entries(2)%inclusive_time = 1.0_wp
      summary%entries(2)%self_time = 1.0_wp
      summary%entries(2)%call_count = 1
      summary%entries(2)%pct_time = 14.28_wp

      summary%entries(3)%name = 'tab'//achar(9)//'name'
      summary%entries(3)%inclusive_time = 1.0_wp
      summary%entries(3)%self_time = 1.0_wp
      summary%entries(3)%call_count = 1
      summary%entries(3)%pct_time = 14.28_wp

      summary%entries(4)%name = 'line\nbreak'
      summary%entries(4)%inclusive_time = 1.0_wp
      summary%entries(4)%self_time = 1.0_wp
      summary%entries(4)%call_count = 1
      summary%entries(4)%pct_time = 14.28_wp

      summary%entries(5)%name = ''
      summary%entries(5)%inclusive_time = 1.0_wp
      summary%entries(5)%self_time = 1.0_wp
      summary%entries(5)%call_count = 1
      summary%entries(5)%pct_time = 14.29_wp

      summary%entries(6)%name = 'car'//achar(13)//'return'
      summary%entries(6)%inclusive_time = 1.0_wp
      summary%entries(6)%self_time = 1.0_wp
      summary%entries(6)%call_count = 1
      summary%entries(6)%pct_time = 14.29_wp

      summary%entries(7)%name = 'del'//achar(127)//'name'
      summary%entries(7)%inclusive_time = 1.0_wp
      summary%entries(7)%self_time = 1.0_wp
      summary%entries(7)%call_count = 1
      summary%entries(7)%pct_time = 14.30_wp

      call format_summary(summary, text)

      escaped_backslash = index(text, 'line\\nbreak') > 0
      escaped_blank_name = index(text, '<blank>') > 0
      escaped_carriage = index(text, 'car\rreturn') > 0
      escaped_delete = index(text, 'del\x7Fname') > 0
      escaped_leading_space = index(text, '\x20\x20fake root') > 0
      escaped_newline = index(text, 'line\nbreak') > 0
      escaped_tab = index(text, 'tab\tname') > 0
      raw_carriage_name_present = index(text, 'car'//achar(13)//'return') > 0
      raw_delete_name_present = index(text, 'del'//achar(127)//'name') > 0
      raw_flattened_name_present = index(text, new_line('a')//'  fake root') > 0
      raw_newline_name_present = index(text, 'line'//achar(10)//'break') > 0
      raw_tab_name_present = index(text, 'tab'//achar(9)//'name') > 0

      @assertTrue(escaped_backslash)
      @assertTrue(escaped_blank_name)
      @assertTrue(escaped_carriage)
      @assertTrue(escaped_delete)
      @assertTrue(escaped_leading_space)
      @assertTrue(escaped_newline)
      @assertTrue(escaped_tab)
      @assertFalse(raw_carriage_name_present)
      @assertFalse(raw_delete_name_present)
      @assertFalse(raw_flattened_name_present)
      @assertFalse(raw_newline_name_present)
      @assertFalse(raw_tab_name_present)
   end subroutine test_format_summary_escapes_unsafe_names

   function expected_summary_output(summary, metadata) result(text)
      type(ftimer_summary_t), intent(in) :: summary
      type(ftimer_metadata_t), intent(in) :: metadata(:)
      character(len=:), allocatable :: text
      character(len=256) :: line

      text = ''

      write (line, '(a,f0.6)') 'Total time (s) : ', summary%total_time
      text = text//trim(line)//new_line('a')
      text = text//'Case           : Unit'//new_line('a')
      text = text//'Steps          : 4'//new_line('a')
      text = text//new_line('a')
      text = text//'Timer name  Inclusive (s)     Self (s)    Calls   % Total'//new_line('a')
      text = text//'---------------------------------------------------------'//new_line('a')
      text = text//'A              10.000000      3.000000         1    100.00'//new_line('a')
      text = text//'  B             7.000000      7.000000         1     70.00'//new_line('a')
   end function expected_summary_output

   integer function count_lines(text) result(count)
      character(len=*), intent(in) :: text
      integer :: i

      count = 0
      do i = 1, len(text)
         if (text(i:i) == new_line('a')) count = count + 1
      end do
   end function count_lines

   function deep_hierarchy_prefix(level) result(prefix)
      integer, intent(in) :: level
      character(len=:), allocatable :: prefix
      character(len=8) :: name

      write (name, '("Depth",i3.3)') level
      prefix = repeat(' ', 2*(level - 1))//trim(name)
   end function deep_hierarchy_prefix

end module test_summary
