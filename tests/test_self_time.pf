module test_self_time
   use pfunit
   use ftimer_core, only: ftimer_t
   use ftimer_types, only: FTIMER_SUCCESS, ftimer_summary_t, wp
   use test_support, only: attach_mock_clock, fake_time
   implicit none

contains

   @test
   subroutine test_parent_self_time_excludes_single_child()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("Parent", ierr=ierr)
      fake_time = 3.0_wp
      call timer%start("Child", ierr=ierr)
      fake_time = 10.0_wp
      call timer%stop("Child", ierr=ierr)
      call timer%stop("Parent", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, summary%num_entries)
      @assertEqual(10.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(3.0_wp, summary%entries(1)%self_time)
      @assertEqual(7.0_wp, summary%entries(2)%inclusive_time)
      @assertEqual(7.0_wp, summary%entries(2)%self_time)
   end subroutine test_parent_self_time_excludes_single_child

   @test
   subroutine test_parent_self_time_excludes_multiple_direct_children()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("Parent", ierr=ierr)
      fake_time = 1.0_wp
      call timer%start("Child1", ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop("Child1", ierr=ierr)
      fake_time = 5.0_wp
      call timer%start("Child2", ierr=ierr)
      fake_time = 9.0_wp
      call timer%stop("Child2", ierr=ierr)
      fake_time = 12.0_wp
      call timer%stop("Parent", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(3, summary%num_entries)
      @assertEqual(12.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(5.0_wp, summary%entries(1)%self_time)
      @assertEqual(3.0_wp, summary%entries(2)%self_time)
      @assertEqual(4.0_wp, summary%entries(3)%self_time)
   end subroutine test_parent_self_time_excludes_multiple_direct_children

   @test
   subroutine test_nested_self_time_uses_direct_children_only()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 2.0_wp
      call timer%start("B", ierr=ierr)
      fake_time = 5.0_wp
      call timer%start("C", ierr=ierr)
      fake_time = 7.0_wp
      call timer%stop("C", ierr=ierr)
      fake_time = 10.0_wp
      call timer%stop("B", ierr=ierr)
      fake_time = 12.0_wp
      call timer%stop("A", ierr=ierr)

      call timer%get_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(3, summary%num_entries)
      @assertEqual(12.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(4.0_wp, summary%entries(1)%self_time)
      @assertEqual(8.0_wp, summary%entries(2)%inclusive_time)
      @assertEqual(6.0_wp, summary%entries(2)%self_time)
      @assertEqual(2.0_wp, summary%entries(3)%inclusive_time)
      @assertEqual(2.0_wp, summary%entries(3)%self_time)
   end subroutine test_nested_self_time_uses_direct_children_only

end module test_self_time
