module test_context
   use, intrinsic :: iso_c_binding, only: c_associated, c_loc, c_ptr
   use pfunit
   use ftimer_core, only: ftimer_t, ftimer_test_state_t
   use ftimer_types, only: FTIMER_EVENT_START, FTIMER_EVENT_STOP, FTIMER_MISMATCH_REPAIR, FTIMER_SUCCESS, &
                           ftimer_call_stack_t, wp
   use test_support, only: attach_mock_clock, build_stack, fake_time, find_context_idx, snapshot_timer
   implicit none

   integer, save :: deep_context_callback_count = 0

contains

   @test
   subroutine test_same_timer_under_different_parents_uses_distinct_contexts()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: stack_a
      type(ftimer_call_stack_t) :: stack_b
      integer :: ierr
      integer :: id_work
      integer :: ctx_a
      integer :: ctx_b
      real(wp) :: time_a
      real(wp) :: time_b

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 3.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)

      call timer%start("B", ierr=ierr)
      fake_time = 5.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 8.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 9.0_wp
      call timer%stop("B", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      id_work = timer%lookup("work", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, state)
      stack_a = build_stack([1])
      stack_b = build_stack([3])
      ctx_a = find_context_idx(state, id_work, stack_a)
      ctx_b = find_context_idx(state, id_work, stack_b)
      time_a = state%segments(id_work)%time(ctx_a)
      time_b = state%segments(id_work)%time(ctx_b)

      @assertEqual(2, state%segments(id_work)%contexts%count)
      @assertEqual(2.0_wp, time_a)
      @assertEqual(3.0_wp, time_b)
   end subroutine test_same_timer_under_different_parents_uses_distinct_contexts

   @test
   subroutine test_many_contexts_preserve_existing_work_times()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: parent_stack
      integer :: ctx
      integer :: i
      integer :: id_work
      integer :: ierr
      integer :: parent_ids(12)
      real(wp) :: elapsed
      character(len=18) :: parent_name
      character(len=*), parameter :: work_name = 'work'

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      id_work = timer%lookup(work_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      do i = 1, size(parent_ids)
         write (parent_name, '("parent_",i2.2)') i
         parent_ids(i) = timer%lookup(trim(parent_name), ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         fake_time = real(10*i, wp)
         call timer%start(trim(parent_name), ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         fake_time = real(10*i + 1, wp)
         call timer%start(work_name, ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         fake_time = real(10*i + 2, wp)
         call timer%stop(work_name, ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         fake_time = real(10*i + 3, wp)
         call timer%stop(trim(parent_name), ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end do

      call snapshot_timer(timer, state)
      @assertEqual(size(parent_ids), state%segments(id_work)%contexts%count)

      do i = 1, size(parent_ids)
         parent_stack = build_stack([parent_ids(i)])
         ctx = find_context_idx(state, id_work, parent_stack)
         elapsed = state%segments(id_work)%time(ctx)

         @assertEqual(i, ctx)
         @assertEqual(1.0_wp, elapsed)
         @assertEqual(1, state%segments(id_work)%call_count(ctx))
      end do
   end subroutine test_many_contexts_preserve_existing_work_times

   @test
   subroutine test_many_deep_contexts_reuse_existing_work_contexts()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: parent_stack
      integer :: branch_id
      integer :: ctx
      integer, parameter :: first_batch_size = 10
      integer :: i
      integer :: id_work
      integer :: ierr
      integer :: leaf_id
      integer :: parent_ids(18)
      integer, target :: token
      real(wp) :: elapsed
      character(len=18) :: parent_name
      character(len=*), parameter :: branch_name = 'branch'
      character(len=*), parameter :: leaf_name = 'leaf'
      character(len=*), parameter :: work_name = 'work'

      call reset_deep_context_callback_log()
      call timer%init(mismatch_mode=FTIMER_MISMATCH_REPAIR, ierr=ierr)
      call attach_mock_clock(timer)

      token = 17
      call timer%set_callback(record_deep_context_callback, c_loc(token), ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_work = timer%lookup(work_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      branch_id = timer%lookup(branch_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      leaf_id = timer%lookup(leaf_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      do i = 1, first_batch_size
         write (parent_name, '("parent_",i2.2)') i
         parent_ids(i) = timer%lookup(trim(parent_name), ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         call run_repair_deep_context_cycle(timer, trim(parent_name), branch_name, work_name, leaf_name, &
                                            real(20*i, wp), ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end do

      do i = first_batch_size + 1, size(parent_ids)
         write (parent_name, '("parent_",i2.2)') i
         parent_ids(i) = timer%lookup(trim(parent_name), ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end do

      do i = first_batch_size + 1, size(parent_ids)
         write (parent_name, '("parent_",i2.2)') i
         call run_repair_deep_context_cycle(timer, trim(parent_name), branch_name, work_name, leaf_name, &
                                            real(200 + 20*i, wp), ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end do

      do i = size(parent_ids), 1, -1
         write (parent_name, '("parent_",i2.2)') i
         call run_normal_deep_context_cycle(timer, trim(parent_name), branch_name, work_name, &
                                            real(500 + 20*i, wp), ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end do

      call snapshot_timer(timer, state)
      @assertEqual(size(parent_ids), state%segments(id_work)%contexts%count)
      @assertEqual(size(parent_ids)*13, deep_context_callback_count)

      do i = 1, size(parent_ids)
         parent_stack = build_stack([parent_ids(i), branch_id])
         ctx = find_context_idx(state, id_work, parent_stack)
         elapsed = state%segments(id_work)%time(ctx)

         @assertEqual(3.0_wp, elapsed)
         @assertEqual(2, state%segments(id_work)%call_count(ctx))
      end do
   end subroutine test_many_deep_contexts_reuse_existing_work_contexts

   subroutine run_repair_deep_context_cycle(timer, parent_name, branch_name, work_name, leaf_name, base_time, ierr)
      class(ftimer_t), intent(inout) :: timer
      character(len=*), intent(in) :: parent_name
      character(len=*), intent(in) :: branch_name
      character(len=*), intent(in) :: work_name
      character(len=*), intent(in) :: leaf_name
      real(wp), intent(in) :: base_time
      integer, intent(out) :: ierr

      fake_time = base_time
      call timer%start(parent_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 1.0_wp
      call timer%start(branch_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 2.0_wp
      call timer%start(work_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 3.0_wp
      call timer%start(leaf_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 4.0_wp
      call timer%stop(work_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 6.0_wp
      call timer%stop(leaf_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 7.0_wp
      call timer%stop(branch_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 8.0_wp
      call timer%stop(parent_name, ierr=ierr)
   end subroutine run_repair_deep_context_cycle

   subroutine run_normal_deep_context_cycle(timer, parent_name, branch_name, work_name, base_time, ierr)
      class(ftimer_t), intent(inout) :: timer
      character(len=*), intent(in) :: parent_name
      character(len=*), intent(in) :: branch_name
      character(len=*), intent(in) :: work_name
      real(wp), intent(in) :: base_time
      integer, intent(out) :: ierr

      fake_time = base_time
      call timer%start(parent_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 1.0_wp
      call timer%start(branch_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 2.0_wp
      call timer%start(work_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 3.0_wp
      call timer%stop(work_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 4.0_wp
      call timer%stop(branch_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 5.0_wp
      call timer%stop(parent_name, ierr=ierr)
   end subroutine run_normal_deep_context_cycle

   subroutine record_deep_context_callback(timer_id, context_idx, event, timestamp, user_data)
      integer, intent(in) :: timer_id
      integer, intent(in) :: context_idx
      integer, intent(in) :: event
      real(wp), intent(in) :: timestamp
      type(c_ptr), intent(in) :: user_data

      deep_context_callback_count = deep_context_callback_count + 1
      if ((timer_id + context_idx + event) < 0) error stop 1
      if (timestamp < 0.0_wp) error stop 2
      if (.not. c_associated(user_data)) error stop 3
      if (.not. (event == FTIMER_EVENT_START .or. event == FTIMER_EVENT_STOP)) error stop 4
   end subroutine record_deep_context_callback

   subroutine reset_deep_context_callback_log()
      deep_context_callback_count = 0
   end subroutine reset_deep_context_callback_log

end module test_context
