module test_context
   use pfunit
   use ftimer_core, only: ftimer_t, ftimer_test_state_t
   use ftimer_types, only: FTIMER_SUCCESS, ftimer_call_stack_t, wp
   use test_support, only: attach_mock_clock, build_stack, fake_time, find_context_idx, snapshot_timer
   implicit none

contains

   @test
   subroutine test_same_timer_under_different_parents_uses_distinct_contexts()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: stack_a
      type(ftimer_call_stack_t) :: stack_b
      integer :: ierr
      integer :: id_work
      integer :: ctx_a
      integer :: ctx_b
      real(wp) :: time_a
      real(wp) :: time_b

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 3.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)

      call timer%start("B", ierr=ierr)
      fake_time = 5.0_wp
      call timer%start("work", ierr=ierr)
      fake_time = 8.0_wp
      call timer%stop("work", ierr=ierr)
      fake_time = 9.0_wp
      call timer%stop("B", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      id_work = timer%lookup("work", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, state)
      stack_a = build_stack([1])
      stack_b = build_stack([3])
      ctx_a = find_context_idx(state, id_work, stack_a)
      ctx_b = find_context_idx(state, id_work, stack_b)
      time_a = state%segments(id_work)%time(ctx_a)
      time_b = state%segments(id_work)%time(ctx_b)

      @assertEqual(2, state%segments(id_work)%contexts%count)
      @assertEqual(2.0_wp, time_a)
      @assertEqual(3.0_wp, time_b)
   end subroutine test_same_timer_under_different_parents_uses_distinct_contexts

   @test
   subroutine test_many_contexts_preserve_existing_work_times()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: parent_stack
      integer :: ctx
      integer :: i
      integer :: id_work
      integer :: ierr
      integer :: parent_ids(12)
      real(wp) :: elapsed
      character(len=18) :: parent_name
      character(len=*), parameter :: work_name = 'work'

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      id_work = timer%lookup(work_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      do i = 1, size(parent_ids)
         write (parent_name, '("parent_",i2.2)') i
         parent_ids(i) = timer%lookup(trim(parent_name), ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         fake_time = real(10*i, wp)
         call timer%start(trim(parent_name), ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         fake_time = real(10*i + 1, wp)
         call timer%start(work_name, ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         fake_time = real(10*i + 2, wp)
         call timer%stop(work_name, ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         fake_time = real(10*i + 3, wp)
         call timer%stop(trim(parent_name), ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end do

      call snapshot_timer(timer, state)
      @assertEqual(size(parent_ids), state%segments(id_work)%contexts%count)

      do i = 1, size(parent_ids)
         parent_stack = build_stack([parent_ids(i)])
         ctx = find_context_idx(state, id_work, parent_stack)
         elapsed = state%segments(id_work)%time(ctx)

         @assertEqual(i, ctx)
         @assertEqual(1.0_wp, elapsed)
         @assertEqual(1, state%segments(id_work)%call_count(ctx))
      end do
   end subroutine test_many_contexts_preserve_existing_work_times

end module test_context
