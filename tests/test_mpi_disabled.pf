module test_mpi_disabled
   use pfunit
   use ftimer, only: ftimer_default_instance, ftimer_finalize, ftimer_init, ftimer_mpi_summary, ftimer_start, ftimer_stop
   use ftimer_core, only: ftimer_t
   use ftimer_types, only: FTIMER_ERR_NOT_IMPLEMENTED, FTIMER_SUCCESS, ftimer_mpi_summary_t, wp
   use test_support, only: attach_mock_clock, fake_time
   implicit none

contains

   @test
   subroutine test_oop_mpi_summary_not_implemented_returns_empty_mpi_result()
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_single_timer(timer, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_NOT_IMPLEMENTED, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)
      @assertEqual(0.0_wp, summary%min_total_time)
      @assertEqual(0.0_wp, summary%max_total_time)
      @assertEqual(0.0_wp, summary%avg_total_time)
      @assertEqual(-1, summary%min_total_time_rank)
      @assertEqual(-1, summary%max_total_time_rank)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_oop_mpi_summary_not_implemented_returns_empty_mpi_result

   @test
   subroutine test_procedural_mpi_summary_matches_oop_when_disabled()
      type(ftimer_t) :: oop_timer
      type(ftimer_mpi_summary_t) :: oop_summary
      type(ftimer_mpi_summary_t) :: procedural_summary
      integer :: ierr

      call oop_timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call build_single_timer(oop_timer, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call build_single_timer_procedural(ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%mpi_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_ERR_NOT_IMPLEMENTED, ierr)
      call ftimer_mpi_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_ERR_NOT_IMPLEMENTED, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_mpi_summary_matches_oop_when_disabled

   subroutine build_single_timer(timer, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("work", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 4.0_wp
      call timer%stop("work", ierr=ierr)
   end subroutine build_single_timer

   subroutine build_single_timer_procedural(ierr)
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call ftimer_start("work", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 4.0_wp
      call ftimer_stop("work", ierr=ierr)
   end subroutine build_single_timer_procedural

   subroutine assert_summary_equal(lhs, rhs)
      type(ftimer_mpi_summary_t), intent(in) :: lhs
      type(ftimer_mpi_summary_t), intent(in) :: rhs

      @assertEqual(rhs%num_ranks, lhs%num_ranks)
      @assertEqual(rhs%num_entries, lhs%num_entries)
      @assertEqual(rhs%min_total_time, lhs%min_total_time)
      @assertEqual(rhs%max_total_time, lhs%max_total_time)
      @assertEqual(rhs%avg_total_time, lhs%avg_total_time)
      @assertEqual(rhs%min_total_time_rank, lhs%min_total_time_rank)
      @assertEqual(rhs%max_total_time_rank, lhs%max_total_time_rank)
      @assertEqual(rhs%total_time_imbalance, lhs%total_time_imbalance)
   end subroutine assert_summary_equal

end module test_mpi_disabled
