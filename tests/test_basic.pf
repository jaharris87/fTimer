module test_basic
   use, intrinsic :: iso_c_binding, only: c_associated, c_loc, c_ptr
   use pfunit
   use ftimer_core, only: ftimer_t, ftimer_test_state_t
   use ftimer_types, only: FTIMER_MISMATCH_STRICT, FTIMER_SUCCESS, wp
   use test_support, only: attach_mock_clock, fake_time, find_context_idx, snapshot_timer
   implicit none

   integer, save :: finalize_callback_count = 0

contains

   @test
   subroutine test_init_finalize_sets_core_state()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      integer :: trimmed_date_len
      logical :: initialized
      integer :: mismatch_mode
      integer :: num_segments

      call timer%init(ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(timer, state)

      initialized = state%initialized
      mismatch_mode = state%mismatch_mode
      num_segments = state%num_segments
      trimmed_date_len = len_trim(state%init_date)

      @assertTrue(initialized)
      @assertEqual(FTIMER_MISMATCH_STRICT, mismatch_mode)
      @assertEqual(0, num_segments)
      @assertTrue(trimmed_date_len > 0)

      call timer%finalize(ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(timer, state)
      initialized = state%initialized
      num_segments = state%num_segments
      @assertFalse(initialized)
      @assertEqual(0, num_segments)
   end subroutine test_init_finalize_sets_core_state

   @test
   subroutine test_init_without_ierr_still_initializes()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      logical :: initialized

      call timer%init()
      call snapshot_timer(timer, state)
      initialized = state%initialized
      @assertTrue(initialized)
   end subroutine test_init_without_ierr_still_initializes

   @test
   subroutine test_start_stop_auto_creates_and_accumulates()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      integer :: ctx
      real(wp) :: elapsed
      integer :: count
      logical :: running

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 2.5_wp
      call timer%stop("A", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(timer, state)

      ctx = find_context_idx(state, 1, state%call_stack)
      elapsed = state%segments(1)%time(ctx)
      count = state%segments(1)%call_count(ctx)
      running = state%segments(1)%is_running(ctx)

      @assertEqual(1, state%num_segments)
      @assertEqual(1, ctx)
      @assertEqual(2.5_wp, elapsed)
      @assertEqual(1, count)
      @assertFalse(running)
   end subroutine test_start_stop_auto_creates_and_accumulates

   @test
   subroutine test_lookup_reuses_existing_segment_id()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      integer :: id_a
      integer :: id_b
      integer :: id_first_again
      integer :: i
      integer :: last_id
      character(len=18) :: name

      call timer%init(ierr=ierr)

      id_a = timer%lookup("alpha", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_b = timer%lookup("alpha", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(id_a, id_b)

      do i = 1, 40
         write (name, '("bulk_timer_",i2.2)') i
         last_id = timer%lookup(trim(name), ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end do

      id_first_again = timer%lookup("alpha", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(id_a, id_first_again)
      @assertEqual(41, last_id)

      call snapshot_timer(timer, state)
      @assertEqual(41, state%num_segments)
   end subroutine test_lookup_reuses_existing_segment_id

   @test
   subroutine test_start_id_stop_id_uses_cached_id()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      integer :: id_a
      integer :: ctx
      real(wp) :: elapsed

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      id_a = timer%lookup("id_timer", ierr=ierr)
      call timer%start_id(id_a, ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop_id(id_a, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(timer, state)

      ctx = find_context_idx(state, id_a, state%call_stack)
      elapsed = state%segments(id_a)%time(ctx)

      @assertEqual(4.0_wp, elapsed)
      @assertEqual(1, state%segments(id_a)%call_count(ctx))
   end subroutine test_start_id_stop_id_uses_cached_id

   @test
   subroutine test_finalize_clears_hook_state()
      type(ftimer_t) :: timer
      integer, target :: user_token
      integer :: ierr

      call reset_finalize_callback_count()
      call timer%init(ierr=ierr)
      user_token = 7
      call timer%set_callback(test_hook, c_loc(user_token), ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%finalize(ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call timer%start("after_finalize", ierr=ierr)
      fake_time = 1.0_wp
      call timer%stop("after_finalize", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(0, finalize_callback_count)
   end subroutine test_finalize_clears_hook_state

   subroutine test_hook(timer_id, context_idx, event, timestamp, user_data)
      integer, intent(in) :: timer_id
      integer, intent(in) :: context_idx
      integer, intent(in) :: event
      real(wp), intent(in) :: timestamp
      type(c_ptr), intent(in) :: user_data

      finalize_callback_count = finalize_callback_count + 1
      if ((timer_id + context_idx + event) < 0) error stop 1
      if (timestamp < 0.0_wp) error stop 2
      if (.not. c_associated(user_data)) error stop 3
   end subroutine test_hook

   subroutine reset_finalize_callback_count()
      finalize_callback_count = 0
   end subroutine reset_finalize_callback_count

end module test_basic
