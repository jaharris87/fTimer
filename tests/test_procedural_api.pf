module test_procedural_api
   use pfunit
   use, intrinsic :: iso_c_binding, only: c_ptr
   use, intrinsic :: iso_fortran_env, only: int64
   use ftimer, only: ftimer_default_instance, ftimer_finalize, ftimer_get_summary, ftimer_init, &
                     ftimer_lookup, ftimer_print_summary, ftimer_reset, ftimer_start, ftimer_start_id, &
                     ftimer_stop, ftimer_stop_id, ftimer_write_summary, ftimer_write_summary_csv
   use ftimer_core, only: ftimer_t, ftimer_test_set_call_count, ftimer_test_state_t
   use ftimer_types, only: FTIMER_MISMATCH_STRICT, FTIMER_ERR_MISMATCH, FTIMER_ERR_NOT_INIT, FTIMER_ERR_UNKNOWN, &
                           FTIMER_SUCCESS, ftimer_call_stack_t, ftimer_metadata_t, ftimer_summary_t, wp
   use test_support, only: attach_mock_clock, begin_stderr_capture, end_stderr_capture, fake_time, find_context_idx, &
                           read_file_text, read_unit_text, snapshot_timer, summary_node_ids_unique, &
                           summary_parent_index
   implicit none

   integer, save :: procedural_callback_count = 0

contains

   @test
   subroutine test_procedural_init_finalize_matches_oop()
      type(ftimer_t) :: oop_timer
      type(ftimer_test_state_t) :: oop_state
      type(ftimer_test_state_t) :: procedural_state
      integer :: ierr
      logical :: oop_initialized
      logical :: procedural_initialized
      integer :: oop_num_segments
      integer :: procedural_num_segments
      integer :: oop_date_len
      integer :: procedural_date_len

      call oop_timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(oop_timer, oop_state)

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(ftimer_default_instance, procedural_state)

      oop_initialized = oop_state%initialized
      procedural_initialized = procedural_state%initialized
      oop_num_segments = oop_state%num_segments
      procedural_num_segments = procedural_state%num_segments
      oop_date_len = len_trim(oop_state%init_date)
      procedural_date_len = len_trim(procedural_state%init_date)

      @assertTrue(oop_initialized)
      @assertTrue(procedural_initialized)
      @assertEqual(oop_state%mismatch_mode, procedural_state%mismatch_mode)
      @assertEqual(oop_num_segments, procedural_num_segments)
      @assertEqual(0, oop_num_segments)
      @assertTrue(oop_date_len > 0)
      @assertTrue(procedural_date_len > 0)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(oop_timer, oop_state)
      call snapshot_timer(ftimer_default_instance, procedural_state)
      oop_initialized = oop_state%initialized
      procedural_initialized = procedural_state%initialized
      @assertFalse(oop_initialized)
      @assertFalse(procedural_initialized)
      @assertEqual(oop_state%num_segments, procedural_state%num_segments)
      @assertEqual(0, oop_state%num_segments)
   end subroutine test_procedural_init_finalize_matches_oop

   @test
   subroutine test_procedural_init_without_integer_args_matches_oop()
      type(ftimer_t) :: oop_timer
      type(ftimer_test_state_t) :: oop_state
      type(ftimer_test_state_t) :: procedural_state
      integer :: ierr
      logical :: oop_initialized
      logical :: procedural_initialized

      call oop_timer%init()
      call snapshot_timer(oop_timer, oop_state)

      call ftimer_init()
      call snapshot_timer(ftimer_default_instance, procedural_state)

      oop_initialized = oop_state%initialized
      procedural_initialized = procedural_state%initialized

      @assertTrue(oop_initialized)
      @assertTrue(procedural_initialized)
      @assertEqual(oop_state%mismatch_mode, procedural_state%mismatch_mode)
      @assertEqual(oop_state%num_segments, procedural_state%num_segments)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_init_without_integer_args_matches_oop

   @test
   subroutine test_procedural_init_keyword_options_match_oop()
      type(ftimer_t) :: oop_timer
      type(ftimer_test_state_t) :: oop_state
      type(ftimer_test_state_t) :: procedural_state
      integer :: ierr
      integer :: comm
      integer :: mismatch_mode

      comm = 42
      mismatch_mode = 2

      call oop_timer%init(mismatch_mode=mismatch_mode, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(oop_timer, oop_state)

      call ftimer_init(comm=comm, mismatch_mode=mismatch_mode, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call snapshot_timer(ftimer_default_instance, procedural_state)

      @assertEqual(42, comm)
      @assertEqual(oop_state%mismatch_mode, procedural_state%mismatch_mode)
      @assertEqual(mismatch_mode, procedural_state%mismatch_mode)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_init_keyword_options_match_oop

   @test
   subroutine test_init_positional_integer_binds_safely_to_comm()
      type(ftimer_t) :: oop_timer
      type(ftimer_test_state_t) :: oop_state
      type(ftimer_test_state_t) :: procedural_state
      integer :: ierr
      integer :: oop_val
      integer :: procedural_val

      ! After reorder, a single positional integer binds to comm (intent(in)),
      ! not ierr (intent(out)).  The caller's variable is NOT clobbered.
      oop_val = 42
      call oop_timer%init(oop_val)
      call snapshot_timer(oop_timer, oop_state)

      procedural_val = 42
      call ftimer_init(procedural_val)
      call snapshot_timer(ftimer_default_instance, procedural_state)

      ! Key safety assertion: caller's variable is NOT overwritten
      @assertEqual(42, oop_val)
      @assertEqual(42, procedural_val)

      ! mismatch_mode defaults to strict (was not passed)
      @assertEqual(FTIMER_MISMATCH_STRICT, oop_state%mismatch_mode)
      @assertEqual(FTIMER_MISMATCH_STRICT, procedural_state%mismatch_mode)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_init_positional_integer_binds_safely_to_comm

   @test
   subroutine test_procedural_start_stop_matches_oop()
      type(ftimer_t) :: oop_timer
      type(ftimer_summary_t) :: oop_summary
      type(ftimer_summary_t) :: procedural_summary
      integer :: ierr

      call oop_timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call oop_timer%start("phase4", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_start("phase4", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 3.5_wp

      call oop_timer%stop("phase4", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_stop("phase4", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%get_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_get_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_start_stop_matches_oop

   @test
   subroutine test_procedural_active_get_summary_matches_oop()
      type(ftimer_t) :: oop_timer
      type(ftimer_summary_t) :: oop_summary
      type(ftimer_summary_t) :: procedural_summary
      integer :: ierr

      call oop_timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call oop_timer%start("phase4_active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_start("phase4_active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 2.25_wp
      call oop_timer%get_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_get_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)
      @assertTrue(procedural_summary%has_active_timers)
      @assertTrue(procedural_summary%entries(1)%is_active)

      fake_time = 4.5_wp
      call oop_timer%stop("phase4_active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_stop("phase4_active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%get_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_get_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)
      @assertFalse(procedural_summary%has_active_timers)
      @assertFalse(procedural_summary%entries(1)%is_active)
      @assertEqual(4.5_wp, procedural_summary%entries(1)%inclusive_time)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_active_get_summary_matches_oop

   @test
   subroutine test_procedural_lookup_start_id_stop_id_matches_oop()
      type(ftimer_t) :: oop_timer
      type(ftimer_summary_t) :: oop_summary
      type(ftimer_summary_t) :: procedural_summary
      integer :: ierr
      integer :: oop_id
      integer :: procedural_id

      call oop_timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      oop_id = oop_timer%lookup("cached", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      procedural_id = ftimer_lookup("cached", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertTrue(procedural_id > 0)

      call oop_timer%start_id(oop_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_start_id(procedural_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 8.0_wp

      call oop_timer%stop_id(oop_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_stop_id(procedural_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%get_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_get_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_lookup_start_id_stop_id_matches_oop

   @test
   subroutine test_procedural_cached_id_negative_paths_match_oop_contract()
      type(ftimer_test_state_t) :: after_state
      type(ftimer_test_state_t) :: before_state
      type(ftimer_test_state_t) :: state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: id
      integer :: ierr
      integer :: saved_fd
      logical :: call_count_allocated
      logical :: has_start_warning
      logical :: has_stop_warning
      logical :: is_silent

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call reset_procedural_callback_count()
      call ftimer_default_instance%set_callback(count_procedural_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call begin_stderr_capture('test_procedural_cached_id_preinit_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_start_id(1, ierr=ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)
      call ftimer_stop_id(1, ierr=ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)
      call end_stderr_capture('test_procedural_cached_id_preinit_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      is_silent = len_trim(stderr_text) == 0
      @assertTrue(is_silent)
      @assertEqual(0, procedural_callback_count)

      call begin_stderr_capture('test_procedural_cached_id_preinit_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_start_id(1)
      call ftimer_stop_id(1)
      call end_stderr_capture('test_procedural_cached_id_preinit_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      has_start_warning = index(stderr_text, 'ftimer start_id before init') > 0
      has_stop_warning = index(stderr_text, 'ftimer stop_id before init') > 0
      @assertTrue(has_start_warning)
      @assertTrue(has_stop_warning)
      @assertEqual(0, procedural_callback_count)

      call snapshot_timer(ftimer_default_instance, state)
      @assertFalse(state%initialized)
      @assertEqual(0, state%num_segments)
      @assertEqual(0, state%call_stack%depth)

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)
      call reset_procedural_callback_count()
      call ftimer_default_instance%set_callback(count_procedural_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id = ftimer_lookup('procedural_cached_id', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertTrue(id > 0)

      call snapshot_timer(ftimer_default_instance, before_state)
      call ftimer_start_id(0, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(ftimer_default_instance, before_state)
      call ftimer_stop_id(id + 1, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(ftimer_default_instance, before_state)
      call begin_stderr_capture('test_procedural_cached_id_unknown_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_start_id(id + 1)
      call end_stderr_capture('test_procedural_cached_id_unknown_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(ftimer_default_instance, after_state)

      has_start_warning = index(stderr_text, 'ftimer start_id with unknown timer id') > 0
      @assertTrue(has_start_warning)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(ftimer_default_instance, before_state)
      call begin_stderr_capture('test_procedural_cached_id_unknown_stop_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_stop_id(0)
      call end_stderr_capture('test_procedural_cached_id_unknown_stop_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(ftimer_default_instance, after_state)

      has_stop_warning = index(stderr_text, 'ftimer stop_id with unknown timer id') > 0
      @assertTrue(has_stop_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, procedural_callback_count)

      call snapshot_timer(ftimer_default_instance, state)
      call_count_allocated = allocated(state%segments(1)%call_count)
      @assertTrue(state%initialized)
      @assertEqual(1, state%num_segments)
      @assertEqual(0, state%call_stack%depth)
      @assertFalse(call_count_allocated)

      call ftimer_start_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp
      call ftimer_stop_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, procedural_callback_count)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)
      call reset_procedural_callback_count()
      call ftimer_default_instance%set_callback(count_procedural_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(ftimer_default_instance, before_state)
      call ftimer_start_id(id, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(ftimer_default_instance, before_state)
      call ftimer_stop_id(id, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(ftimer_default_instance, before_state)
      call begin_stderr_capture('test_procedural_cached_id_stale_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_start_id(id)
      call end_stderr_capture('test_procedural_cached_id_stale_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(ftimer_default_instance, after_state)

      has_start_warning = index(stderr_text, 'ftimer start_id with unknown timer id') > 0
      @assertTrue(has_start_warning)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(ftimer_default_instance, before_state)
      call begin_stderr_capture('test_procedural_cached_id_stale_stop_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_stop_id(id)
      call end_stderr_capture('test_procedural_cached_id_stale_stop_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(ftimer_default_instance, after_state)

      has_stop_warning = index(stderr_text, 'ftimer stop_id with unknown timer id') > 0
      @assertTrue(has_stop_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, procedural_callback_count)

      call snapshot_timer(ftimer_default_instance, state)
      @assertTrue(state%initialized)
      @assertEqual(0, state%num_segments)
      @assertEqual(0, state%call_stack%depth)

      id = ftimer_lookup('procedural_valid_after_failures', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_start_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 2.0_wp
      call ftimer_stop_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, procedural_callback_count)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_cached_id_negative_paths_match_oop_contract

   @test
   subroutine test_procedural_cached_id_survives_reset()
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: root_stack
      integer :: id
      integer :: ierr
      integer :: new_id
      integer :: new_ctx
      integer :: old_ctx
      integer(int64) :: new_count
      integer(int64) :: old_count
      logical :: ids_differ
      real(wp) :: new_elapsed
      real(wp) :: old_elapsed

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      id = ftimer_lookup('procedural_cached_reset_region', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call ftimer_start_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp
      call ftimer_stop_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call ftimer_reset(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call ftimer_start_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 3.0_wp
      call ftimer_stop_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      new_id = ftimer_lookup('procedural_cached_reset_new_region', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      ids_differ = new_id /= id
      @assertTrue(ids_differ)

      call ftimer_start_id(new_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 4.0_wp
      call ftimer_stop_id(new_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(ftimer_default_instance, state)
      old_ctx = find_context_idx(state, 1, root_stack)
      new_ctx = find_context_idx(state, 2, root_stack)
      old_elapsed = state%segments(1)%time(old_ctx)
      new_elapsed = state%segments(2)%time(new_ctx)
      old_count = state%segments(1)%call_count(old_ctx)
      new_count = state%segments(2)%call_count(new_ctx)

      @assertEqual(2, state%num_segments)
      @assertEqual('procedural_cached_reset_region', trim(state%segments(1)%name))
      @assertEqual('procedural_cached_reset_new_region', trim(state%segments(2)%name))
      @assertEqual(2.0_wp, old_elapsed)
      @assertEqual(1.0_wp, new_elapsed)
      @assertEqual(1_int64, old_count)
      @assertEqual(1_int64, new_count)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_cached_id_survives_reset

   @test
   subroutine test_procedural_cached_id_stale_alias_after_reinit_is_rejected()
      type(ftimer_test_state_t) :: after_state
      type(ftimer_test_state_t) :: before_state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: ierr
      integer :: new_id
      integer :: old_id
      integer :: saved_fd
      logical :: has_start_warning
      logical :: has_stop_warning
      logical :: ids_differ

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      old_id = ftimer_lookup('procedural_old_cached_region', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)
      call reset_procedural_callback_count()
      call ftimer_default_instance%set_callback(count_procedural_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      new_id = ftimer_lookup('procedural_new_cached_region', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      ids_differ = new_id /= old_id
      @assertTrue(ids_differ)

      call snapshot_timer(ftimer_default_instance, before_state)
      call ftimer_start_id(old_id, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(ftimer_default_instance, before_state)
      call ftimer_stop_id(old_id, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(ftimer_default_instance, before_state)
      call begin_stderr_capture('test_procedural_cached_id_stale_alias_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_start_id(old_id)
      call ftimer_stop_id(old_id)
      call end_stderr_capture('test_procedural_cached_id_stale_alias_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(ftimer_default_instance, after_state)

      has_start_warning = index(stderr_text, 'ftimer start_id with unknown timer id') > 0
      has_stop_warning = index(stderr_text, 'ftimer stop_id with unknown timer id') > 0
      @assertTrue(has_start_warning)
      @assertTrue(has_stop_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, procedural_callback_count)

      call ftimer_start_id(new_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp
      call ftimer_stop_id(new_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, procedural_callback_count)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_cached_id_stale_alias_after_reinit_is_rejected

   @test
   subroutine test_procedural_stop_id_mismatch_preserves_state()
      type(ftimer_test_state_t) :: after_state
      type(ftimer_test_state_t) :: before_state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: id_a
      integer :: id_b
      integer :: ierr
      integer :: saved_fd
      logical :: has_empty_warning
      logical :: has_mismatch_warning
      logical :: is_silent

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)
      call reset_procedural_callback_count()
      call ftimer_default_instance%set_callback(count_procedural_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_a = ftimer_lookup('procedural_valid_a', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      id_b = ftimer_lookup('procedural_valid_b', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(ftimer_default_instance, before_state)
      call begin_stderr_capture('test_procedural_stop_id_empty_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_stop_id(id_a, ierr=ierr)
      call end_stderr_capture('test_procedural_stop_id_empty_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_MISMATCH, ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      is_silent = len_trim(stderr_text) == 0
      @assertTrue(is_silent)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, procedural_callback_count)

      call snapshot_timer(ftimer_default_instance, before_state)
      call begin_stderr_capture('test_procedural_stop_id_empty_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_stop_id(id_a)
      call end_stderr_capture('test_procedural_stop_id_empty_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      has_empty_warning = index(stderr_text, 'ftimer stop mismatch on empty call stack') > 0
      @assertTrue(has_empty_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, procedural_callback_count)

      call ftimer_start_id(id_a, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, procedural_callback_count)

      call snapshot_timer(ftimer_default_instance, before_state)
      call begin_stderr_capture('test_procedural_stop_id_mismatch_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_stop_id(id_b, ierr=ierr)
      call end_stderr_capture('test_procedural_stop_id_mismatch_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_MISMATCH, ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      is_silent = len_trim(stderr_text) == 0
      @assertTrue(is_silent)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(1, procedural_callback_count)

      call snapshot_timer(ftimer_default_instance, before_state)
      call begin_stderr_capture('test_procedural_stop_id_mismatch_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_stop_id(id_b)
      call end_stderr_capture('test_procedural_stop_id_mismatch_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(ftimer_default_instance, after_state)
      has_mismatch_warning = index(stderr_text, 'ftimer stop mismatch: requested procedural_valid_b') > 0
      @assertTrue(has_mismatch_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(1, procedural_callback_count)

      fake_time = 3.0_wp
      call ftimer_stop_id(id_a, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, procedural_callback_count)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_stop_id_mismatch_preserves_state

   @test
   subroutine test_procedural_start_id_handles_int64_boundary()
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: root_stack
      integer :: ctx
      integer :: id_hot
      integer :: ierr
      integer(int64) :: stored_count
      logical :: count_at_max
      logical :: count_unchanged

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      id_hot = ftimer_lookup("hot_id", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_start_id(id_hot, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp
      call ftimer_stop_id(id_hot, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(ftimer_default_instance, state)
      ctx = find_context_idx(state, 1, root_stack)
      call ftimer_test_set_call_count(ftimer_default_instance, id_hot, ctx, huge(0_int64) - 1_int64, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 2.0_wp
      call ftimer_start_id(id_hot, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 3.0_wp
      call ftimer_stop_id(id_hot, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(ftimer_default_instance, state)
      stored_count = state%segments(1)%call_count(ctx)
      count_at_max = stored_count == huge(0_int64)
      @assertTrue(count_at_max)

      call ftimer_start_id(id_hot, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)

      call snapshot_timer(ftimer_default_instance, state)
      stored_count = state%segments(1)%call_count(ctx)
      count_unchanged = stored_count == huge(0_int64)
      @assertTrue(count_unchanged)
      @assertEqual(0, state%call_stack%depth)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_start_id_handles_int64_boundary

   @test
   subroutine test_procedural_reset_matches_oop()
      type(ftimer_t) :: oop_timer
      type(ftimer_summary_t) :: oop_summary
      type(ftimer_summary_t) :: procedural_summary
      integer :: ierr

      call oop_timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call oop_timer%start("reset_me", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_start("reset_me", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 6.0_wp

      call oop_timer%stop("reset_me", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_stop("reset_me", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 9.0_wp
      call oop_timer%reset(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_reset(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%get_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_get_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_reset_matches_oop

   @test
   subroutine test_procedural_print_summary_matches_oop()
      type(ftimer_t) :: oop_timer
      type(ftimer_metadata_t) :: metadata(2)
      character(len=:), allocatable :: oop_text
      character(len=:), allocatable :: procedural_text
      integer :: ierr
      integer :: oop_unit
      integer :: procedural_unit
      logical :: texts_match

      metadata(1)%key = 'Case'
      metadata(1)%value = 'Phase4'
      metadata(2)%key = 'Mode'
      metadata(2)%value = 'Wrapper'

      call build_matching_timers(oop_timer, ierr)

      open (newunit=oop_unit, status='scratch', action='readwrite')
      call oop_timer%print_summary(unit=oop_unit, metadata=metadata, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      oop_text = read_unit_text(oop_unit)
      close (oop_unit)

      open (newunit=procedural_unit, status='scratch', action='readwrite')
      call ftimer_print_summary(unit=procedural_unit, metadata=metadata, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      procedural_text = read_unit_text(procedural_unit)
      close (procedural_unit)

      texts_match = procedural_text == oop_text
      @assertTrue(texts_match)

      call cleanup_matching_timers(oop_timer, ierr)
   end subroutine test_procedural_print_summary_matches_oop

   @test
   subroutine test_procedural_start_before_init_matches_oop_stderr_contract()
      type(ftimer_t) :: oop_timer
      type(ftimer_test_state_t) :: oop_state
      type(ftimer_test_state_t) :: procedural_state
      character(len=:), allocatable :: oop_stderr
      character(len=:), allocatable :: procedural_stderr
      integer :: capture_ierr
      integer :: ierr
      integer :: saved_fd
      logical :: oop_silent
      logical :: procedural_silent
      logical :: oop_warned
      logical :: procedural_warned

      call begin_stderr_capture('test_procedural_start_before_init_oop_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call oop_timer%start("before_init", ierr=ierr)
      call end_stderr_capture('test_procedural_start_before_init_oop_ierr.err', saved_fd, oop_stderr, capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)

      call begin_stderr_capture('test_procedural_start_before_init_procedural_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_start("before_init", ierr=ierr)
      call end_stderr_capture('test_procedural_start_before_init_procedural_ierr.err', saved_fd, procedural_stderr, &
                              capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)

      oop_silent = len_trim(oop_stderr) == 0
      procedural_silent = len_trim(procedural_stderr) == 0
      @assertTrue(oop_silent)
      @assertTrue(procedural_silent)

      call begin_stderr_capture('test_procedural_start_before_init_oop_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call oop_timer%start("before_init")
      call end_stderr_capture('test_procedural_start_before_init_oop_warn.err', saved_fd, oop_stderr, capture_ierr)
      @assertEqual(0, capture_ierr)

      call begin_stderr_capture('test_procedural_start_before_init_procedural_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_start("before_init")
      call end_stderr_capture('test_procedural_start_before_init_procedural_warn.err', saved_fd, procedural_stderr, &
                              capture_ierr)
      @assertEqual(0, capture_ierr)

      oop_warned = index(oop_stderr, 'ftimer start before init') > 0
      procedural_warned = index(procedural_stderr, 'ftimer start before init') > 0
      @assertTrue(oop_warned)
      @assertTrue(procedural_warned)

      call snapshot_timer(oop_timer, oop_state)
      call snapshot_timer(ftimer_default_instance, procedural_state)
      @assertFalse(oop_state%initialized)
      @assertFalse(procedural_state%initialized)
      @assertEqual(0, oop_state%num_segments)
      @assertEqual(0, procedural_state%num_segments)
      @assertEqual(0, oop_state%call_stack%depth)
      @assertEqual(0, procedural_state%call_stack%depth)
   end subroutine test_procedural_start_before_init_matches_oop_stderr_contract

   @test
   subroutine test_procedural_print_summary_before_init_matches_oop()
      type(ftimer_t) :: oop_timer
      type(ftimer_test_state_t) :: oop_state
      type(ftimer_test_state_t) :: procedural_state
      character(len=:), allocatable :: oop_stderr
      character(len=:), allocatable :: procedural_stderr
      character(len=:), allocatable :: oop_text
      character(len=:), allocatable :: procedural_text
      integer :: capture_ierr
      integer :: ierr
      integer :: oop_unit
      integer :: procedural_unit
      integer :: saved_fd
      logical :: oop_warned
      logical :: procedural_warned
      logical :: oop_silent
      logical :: procedural_silent

      open (newunit=oop_unit, status='scratch', action='readwrite')
      open (newunit=procedural_unit, status='scratch', action='readwrite')

      call begin_stderr_capture('test_procedural_print_summary_before_init_oop.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call oop_timer%print_summary(unit=oop_unit)
      call end_stderr_capture('test_procedural_print_summary_before_init_oop.err', saved_fd, oop_stderr, capture_ierr)
      @assertEqual(0, capture_ierr)

      call begin_stderr_capture('test_procedural_print_summary_before_init_procedural.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_print_summary(unit=procedural_unit)
      call end_stderr_capture('test_procedural_print_summary_before_init_procedural.err', saved_fd, procedural_stderr, &
                              capture_ierr)
      @assertEqual(0, capture_ierr)

      oop_text = read_unit_text(oop_unit)
      procedural_text = read_unit_text(procedural_unit)
      oop_warned = index(oop_stderr, 'ftimer print_summary before init') > 0
      procedural_warned = index(procedural_stderr, 'ftimer print_summary before init') > 0

      @assertTrue(oop_warned)
      @assertTrue(procedural_warned)
      @assertEqual('', oop_text)
      @assertEqual('', procedural_text)

      call begin_stderr_capture('test_procedural_print_summary_before_init_oop_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call oop_timer%print_summary(unit=oop_unit, ierr=ierr)
      call end_stderr_capture('test_procedural_print_summary_before_init_oop_ierr.err', saved_fd, oop_stderr, &
                              capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)

      call begin_stderr_capture('test_procedural_print_summary_before_init_procedural_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call ftimer_print_summary(unit=procedural_unit, ierr=ierr)
      call end_stderr_capture('test_procedural_print_summary_before_init_procedural_ierr.err', saved_fd, &
                              procedural_stderr, capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)

      oop_text = read_unit_text(oop_unit)
      procedural_text = read_unit_text(procedural_unit)
      oop_silent = len_trim(oop_stderr) == 0
      procedural_silent = len_trim(procedural_stderr) == 0

      @assertEqual('', oop_text)
      @assertEqual('', procedural_text)
      @assertTrue(oop_silent)
      @assertTrue(procedural_silent)

      call snapshot_timer(oop_timer, oop_state)
      call snapshot_timer(ftimer_default_instance, procedural_state)
      @assertFalse(oop_state%initialized)
      @assertFalse(procedural_state%initialized)
      @assertEqual(0, oop_state%num_segments)
      @assertEqual(0, procedural_state%num_segments)
      @assertEqual(0, oop_state%call_stack%depth)
      @assertEqual(0, procedural_state%call_stack%depth)

      close (oop_unit)
      close (procedural_unit)
   end subroutine test_procedural_print_summary_before_init_matches_oop

   @test
   subroutine test_procedural_write_summary_matches_oop()
