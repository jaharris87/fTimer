   subroutine build_matching_timers(oop_timer, ierr)
      type(ftimer_t), intent(out) :: oop_timer
      integer, intent(out) :: ierr

      call oop_timer%init(ierr=ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(ierr=ierr)
      call attach_mock_clock(ftimer_default_instance)

      call oop_timer%start("outer", ierr=ierr)
      call ftimer_start("outer", ierr=ierr)
      fake_time = 2.0_wp
      call oop_timer%start("inner", ierr=ierr)
      call ftimer_start("inner", ierr=ierr)
      fake_time = 5.0_wp
      call oop_timer%stop("inner", ierr=ierr)
      call ftimer_stop("inner", ierr=ierr)
      fake_time = 7.0_wp
      call oop_timer%stop("outer", ierr=ierr)
      call ftimer_stop("outer", ierr=ierr)
   end subroutine build_matching_timers

   subroutine cleanup_matching_timers(oop_timer, ierr)
      type(ftimer_t), intent(inout) :: oop_timer
      integer, intent(out) :: ierr

      call oop_timer%finalize(ierr=ierr)
      call ftimer_finalize(ierr=ierr)
   end subroutine cleanup_matching_timers

   subroutine delete_if_exists(path)
      character(len=*), intent(in) :: path
      integer :: io
      integer :: unit

      open (newunit=unit, file=path, status='old', iostat=io)
      if (io == 0) close (unit, status='delete')
   end subroutine delete_if_exists

   logical function test_state_matches(lhs, rhs) result(matches)
      type(ftimer_test_state_t), intent(in) :: lhs
      type(ftimer_test_state_t), intent(in) :: rhs
      integer :: i

      matches = (lhs%initialized .eqv. rhs%initialized) .and. &
                (lhs%num_segments == rhs%num_segments) .and. &
                (lhs%next_segment_id == rhs%next_segment_id) .and. &
                (lhs%call_stack%depth == rhs%call_stack%depth) .and. &
                (lhs%init_wtime == rhs%init_wtime) .and. &
                (lhs%init_date == rhs%init_date) .and. &
                (lhs%mismatch_mode == rhs%mismatch_mode)
      if (.not. matches) return

      if (.not. segment_integer_arrays_match(lhs%segment_ids, rhs%segment_ids)) then
         matches = .false.
         return
      end if
      if (.not. segment_integer_arrays_match(lhs%segment_id_slots, rhs%segment_id_slots)) then
         matches = .false.
         return
      end if

      if (allocated(lhs%call_stack%ids) .neqv. allocated(rhs%call_stack%ids)) then
         matches = .false.
         return
      end if
      if (allocated(lhs%call_stack%ids)) then
         if (size(lhs%call_stack%ids) /= size(rhs%call_stack%ids)) then
            matches = .false.
            return
         end if
         if (any(lhs%call_stack%ids /= rhs%call_stack%ids)) then
            matches = .false.
            return
         end if
      end if

      if (allocated(lhs%call_stack%activation_tokens) .neqv. &
          allocated(rhs%call_stack%activation_tokens)) then
         matches = .false.
         return
      end if
      if (allocated(lhs%call_stack%activation_tokens)) then
         if (size(lhs%call_stack%activation_tokens) /= size(rhs%call_stack%activation_tokens)) then
            matches = .false.
            return
         end if
         if (any(lhs%call_stack%activation_tokens /= rhs%call_stack%activation_tokens)) then
            matches = .false.
            return
         end if
      end if

      if (allocated(lhs%segments) .neqv. allocated(rhs%segments)) then
         matches = .false.
         return
      end if
      if (.not. allocated(lhs%segments)) return
      if (size(lhs%segments) /= size(rhs%segments)) then
         matches = .false.
         return
      end if

      do i = 1, lhs%num_segments
         if (allocated(lhs%segments(i)%name) .neqv. allocated(rhs%segments(i)%name)) then
            matches = .false.
            return
         end if
         if (allocated(lhs%segments(i)%name)) then
            if (lhs%segments(i)%name /= rhs%segments(i)%name) then
               matches = .false.
               return
            end if
         end if

         if (lhs%segments(i)%contexts%count /= rhs%segments(i)%contexts%count) then
            matches = .false.
            return
         end if
         if (.not. segment_context_stacks_match(lhs%segments(i)%contexts%stacks, &
                                                rhs%segments(i)%contexts%stacks, &
                                                lhs%segments(i)%contexts%count)) then
            matches = .false.
            return
         end if
         if (.not. segment_real_arrays_match(lhs%segments(i)%time, rhs%segments(i)%time)) then
            matches = .false.
            return
         end if
         if (.not. segment_real_arrays_match(lhs%segments(i)%start_time, rhs%segments(i)%start_time)) then
            matches = .false.
            return
         end if
         if (.not. segment_logical_arrays_match(lhs%segments(i)%is_running, rhs%segments(i)%is_running)) then
            matches = .false.
            return
         end if
         if (.not. segment_count_arrays_match(lhs%segments(i)%call_count, rhs%segments(i)%call_count)) then
            matches = .false.
            return
         end if
      end do
   end function test_state_matches

   logical function segment_real_arrays_match(lhs, rhs) result(matches)
      real(wp), allocatable, intent(in) :: lhs(:)
      real(wp), allocatable, intent(in) :: rhs(:)

      matches = allocated(lhs) .eqv. allocated(rhs)
      if (.not. matches) return
      if (.not. allocated(lhs)) return
      matches = size(lhs) == size(rhs)
      if (.not. matches) return
      matches = all(lhs == rhs)
   end function segment_real_arrays_match

   logical function segment_logical_arrays_match(lhs, rhs) result(matches)
      logical, allocatable, intent(in) :: lhs(:)
      logical, allocatable, intent(in) :: rhs(:)

      matches = allocated(lhs) .eqv. allocated(rhs)
      if (.not. matches) return
      if (.not. allocated(lhs)) return
      matches = size(lhs) == size(rhs)
      if (.not. matches) return
      matches = all(lhs .eqv. rhs)
   end function segment_logical_arrays_match

   logical function segment_count_arrays_match(lhs, rhs) result(matches)
      integer(int64), allocatable, intent(in) :: lhs(:)
      integer(int64), allocatable, intent(in) :: rhs(:)

      matches = allocated(lhs) .eqv. allocated(rhs)
      if (.not. matches) return
      if (.not. allocated(lhs)) return
      matches = size(lhs) == size(rhs)
      if (.not. matches) return
      matches = all(lhs == rhs)
   end function segment_count_arrays_match

   logical function segment_integer_arrays_match(lhs, rhs) result(matches)
      integer, allocatable, intent(in) :: lhs(:)
      integer, allocatable, intent(in) :: rhs(:)

      matches = allocated(lhs) .eqv. allocated(rhs)
      if (.not. matches) return
      if (.not. allocated(lhs)) return
      matches = size(lhs) == size(rhs)
      if (.not. matches) return
      matches = all(lhs == rhs)
   end function segment_integer_arrays_match

   logical function segment_context_stacks_match(lhs, rhs, count) result(matches)
      type(ftimer_call_stack_t), allocatable, intent(in) :: lhs(:)
      type(ftimer_call_stack_t), allocatable, intent(in) :: rhs(:)
      integer, intent(in) :: count
      integer :: i

      matches = allocated(lhs) .eqv. allocated(rhs)
      if (.not. matches) return
      if (.not. allocated(lhs)) return
      matches = size(lhs) == size(rhs)
      if (.not. matches) return

      do i = 1, count
         if (.not. stack_storage_matches(lhs(i), rhs(i))) then
            matches = .false.
            return
         end if
      end do
   end function segment_context_stacks_match

   logical function stack_storage_matches(lhs, rhs) result(matches)
      type(ftimer_call_stack_t), intent(in) :: lhs
      type(ftimer_call_stack_t), intent(in) :: rhs

      matches = lhs%depth == rhs%depth
      if (.not. matches) return

      matches = allocated(lhs%ids) .eqv. allocated(rhs%ids)
      if (.not. matches) return
      if (allocated(lhs%ids)) then
         matches = size(lhs%ids) == size(rhs%ids)
         if (.not. matches) return
         matches = all(lhs%ids == rhs%ids)
         if (.not. matches) return
      end if

      matches = allocated(lhs%activation_tokens) .eqv. allocated(rhs%activation_tokens)
      if (.not. matches) return
      if (allocated(lhs%activation_tokens)) then
         matches = size(lhs%activation_tokens) == size(rhs%activation_tokens)
         if (.not. matches) return
         matches = all(lhs%activation_tokens == rhs%activation_tokens)
      end if
   end function stack_storage_matches

   subroutine count_procedural_callback(timer_id, context_idx, event, timestamp, user_data)
      integer, intent(in) :: timer_id
      integer, intent(in) :: context_idx
      integer, intent(in) :: event
      real(wp), intent(in) :: timestamp
      type(c_ptr), intent(in) :: user_data

      procedural_callback_count = procedural_callback_count + 1
   end subroutine count_procedural_callback

   subroutine reset_procedural_callback_count()
      procedural_callback_count = 0
   end subroutine reset_procedural_callback_count

   subroutine assert_summary_equal(lhs, rhs)
      type(ftimer_summary_t), intent(in) :: lhs
      type(ftimer_summary_t), intent(in) :: rhs
      integer :: i
      integer :: lhs_parent_idx
      integer :: rhs_parent_idx
      real(wp) :: pct_diff
      logical :: names_match

      @assertEqual(rhs%num_entries, lhs%num_entries)
      @assertEqual(rhs%total_time, lhs%total_time)
      @assertEqual(rhs%has_active_timers, lhs%has_active_timers)
      @assertEqual(rhs%total_contexts, lhs%total_contexts)
      @assertEqual(rhs%max_contexts_per_timer, lhs%max_contexts_per_timer)
      @assertTrue(summary_node_ids_unique(lhs))
      @assertTrue(summary_node_ids_unique(rhs))

      do i = 1, lhs%num_entries
         names_match = trim(lhs%entries(i)%name) == trim(rhs%entries(i)%name)
         @assertTrue(names_match)
         @assertEqual(rhs%entries(i)%depth, lhs%entries(i)%depth)
         lhs_parent_idx = summary_parent_index(lhs, i)
         rhs_parent_idx = summary_parent_index(rhs, i)
         @assertTrue(lhs_parent_idx >= 0)
         @assertTrue(rhs_parent_idx >= 0)
         @assertEqual(rhs_parent_idx, lhs_parent_idx)
         @assertEqual(rhs%entries(i)%inclusive_time, lhs%entries(i)%inclusive_time)
         @assertEqual(rhs%entries(i)%self_time, lhs%entries(i)%self_time)
         @assertEqual(rhs%entries(i)%call_count, lhs%entries(i)%call_count)
         @assertEqual(rhs%entries(i)%avg_time, lhs%entries(i)%avg_time)
         @assertEqual(rhs%entries(i)%is_active, lhs%entries(i)%is_active)
         @assertEqual(rhs%entries(i)%timer_context_count, lhs%entries(i)%timer_context_count)
         pct_diff = abs(lhs%entries(i)%pct_time - rhs%entries(i)%pct_time)
         @assertTrue(pct_diff < 1.0e-12_wp)
      end do
   end subroutine assert_summary_equal

end module test_procedural_api
