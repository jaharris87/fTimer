module test_callbacks
   use, intrinsic :: iso_c_binding, only: c_associated, c_loc, c_ptr
   use pfunit
   use ftimer_core, only: ftimer_t
   use ftimer_types, only: FTIMER_EVENT_START, FTIMER_EVENT_STOP, FTIMER_MISMATCH_REPAIR, FTIMER_SUCCESS, wp
   use test_support, only: attach_mock_clock, fake_time
   implicit none

   integer, parameter :: max_events = 16
   integer, save :: callback_count = 0
   integer, save :: callback_timer_ids(max_events) = 0
   integer, save :: callback_contexts(max_events) = 0
   integer, save :: callback_events(max_events) = 0
   real(wp), save :: callback_timestamps(max_events) = 0.0_wp
   logical, save :: callback_has_user_data(max_events) = .false.

contains

   @test
   subroutine test_callbacks_fire_for_normal_start_and_stop()
      type(ftimer_t) :: timer
      integer, target :: token
      integer :: ierr
      logical :: first_event_is_start
      logical :: second_event_is_stop

      call reset_callback_log()
      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      token = 7
      timer%on_event => record_callback
      timer%user_data = c_loc(token)

      call timer%start("A", ierr=ierr)
      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)

      first_event_is_start = callback_events(1) == FTIMER_EVENT_START
      second_event_is_stop = callback_events(2) == FTIMER_EVENT_STOP

      @assertEqual(2, callback_count)
      @assertEqual(1, callback_timer_ids(1))
      @assertEqual(1, callback_timer_ids(2))
      @assertEqual(1, callback_contexts(1))
      @assertEqual(1, callback_contexts(2))
      @assertTrue(first_event_is_start)
      @assertTrue(second_event_is_stop)
      @assertEqual(0.0_wp, callback_timestamps(1))
      @assertEqual(4.0_wp, callback_timestamps(2))
      @assertTrue(callback_has_user_data(1))
      @assertTrue(callback_has_user_data(2))
   end subroutine test_callbacks_fire_for_normal_start_and_stop

   @test
   subroutine test_repair_does_not_fire_internal_callbacks()
      type(ftimer_t) :: timer
      integer, target :: token
      integer :: ierr
      logical :: first_event_is_start
      logical :: second_event_is_start
      logical :: third_event_is_stop

      call reset_callback_log()
      call timer%init(mismatch_mode=FTIMER_MISMATCH_REPAIR, ierr=ierr)
      call attach_mock_clock(timer)

      token = 11
      timer%on_event => record_callback
      timer%user_data = c_loc(token)

      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%start("B", ierr=ierr)
      fake_time = 2.0_wp
      call timer%stop("A", ierr=ierr)
      fake_time = 5.0_wp
      call timer%stop("B", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)

      first_event_is_start = callback_events(1) == FTIMER_EVENT_START
      second_event_is_start = callback_events(2) == FTIMER_EVENT_START
      third_event_is_stop = callback_events(3) == FTIMER_EVENT_STOP

      @assertEqual(3, callback_count)
      @assertTrue(first_event_is_start)
      @assertTrue(second_event_is_start)
      @assertTrue(third_event_is_stop)
      @assertEqual(1, callback_timer_ids(1))
      @assertEqual(2, callback_timer_ids(2))
      @assertEqual(2, callback_timer_ids(3))
      @assertEqual(0.0_wp, callback_timestamps(1))
      @assertEqual(1.0_wp, callback_timestamps(2))
      @assertEqual(5.0_wp, callback_timestamps(3))
      @assertTrue(callback_has_user_data(1))
      @assertTrue(callback_has_user_data(2))
      @assertTrue(callback_has_user_data(3))
   end subroutine test_repair_does_not_fire_internal_callbacks

   subroutine record_callback(timer_id, context_idx, event, timestamp, user_data)
      integer, intent(in) :: timer_id
      integer, intent(in) :: context_idx
      integer, intent(in) :: event
      real(wp), intent(in) :: timestamp
      type(c_ptr), intent(in) :: user_data
      integer :: slot

      if (callback_count >= max_events) error stop 1

      slot = callback_count + 1
      callback_count = slot
      callback_timer_ids(slot) = timer_id
      callback_contexts(slot) = context_idx
      callback_events(slot) = event
      callback_timestamps(slot) = timestamp
      callback_has_user_data(slot) = c_associated(user_data)

      if (.not. c_associated(user_data)) error stop 2
   end subroutine record_callback

   subroutine reset_callback_log()
      callback_count = 0
      callback_timer_ids = 0
      callback_contexts = 0
      callback_events = 0
      callback_timestamps = 0.0_wp
      callback_has_user_data = .false.
   end subroutine reset_callback_log

end module test_callbacks
