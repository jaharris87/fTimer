   @test
   subroutine test_finalize_with_active_timer_returns_active()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%finalize(ierr=ierr)

      @assertEqual(FTIMER_ERR_ACTIVE, ierr)
      call snapshot_timer(timer, state)
      @assertTrue(state%initialized)
      @assertEqual(1, state%call_stack%depth)
   end subroutine test_finalize_with_active_timer_returns_active

   @test
   subroutine test_clock_change_after_data_preserves_window()
      type(ftimer_t) :: timer
      type(ftimer_call_stack_t) :: root_stack
      type(ftimer_summary_t) :: summary
      type(ftimer_test_state_t) :: state
      integer :: ctx
      integer :: ierr
      real(wp) :: elapsed
      real(wp) :: initial_init_wtime

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%stop("A", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, state)
      initial_init_wtime = state%init_wtime

      fake_time = 6.0_wp
      call timer%set_clock(scaled_mock_clock, ierr=ierr)
      @assertEqual(FTIMER_ERR_ACTIVE, ierr)

      call snapshot_timer(timer, state)
      @assertEqual(initial_init_wtime, state%init_wtime)
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(6.0_wp, summary%total_time)
      @assertEqual(1.0_wp, summary%entries(1)%inclusive_time)

      call timer%clear_clock(ierr=ierr)
      @assertEqual(FTIMER_ERR_ACTIVE, ierr)

      call snapshot_timer(timer, state)
      @assertEqual(initial_init_wtime, state%init_wtime)
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(6.0_wp, summary%total_time)
      @assertEqual(1.0_wp, summary%entries(1)%inclusive_time)

      call timer%start("B", ierr=ierr)
      fake_time = 7.5_wp
      call timer%stop("B", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, state)
      ctx = find_context_idx(state, 2, root_stack)
      elapsed = state%segments(2)%time(ctx)

      @assertEqual(1.5_wp, elapsed)
   end subroutine test_clock_change_after_data_preserves_window

   @test
   subroutine test_finalize_clears_preinit_callback_state()
      type(ftimer_t) :: timer
      integer :: ierr

      call reset_lifecycle_callback_count()
      call timer%set_callback(count_lifecycle_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call timer%start("A", ierr=ierr)
      fake_time = 1.0_wp
      call timer%stop("A", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(0, lifecycle_callback_count)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_finalize_clears_preinit_callback_state

   @test
   subroutine test_finalize_without_ierr_warns_and_leaves_state_unchanged()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      type(ftimer_call_stack_t) :: root_stack
      type(ftimer_test_state_t) :: state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: ctx
      integer :: ierr
      integer :: idx_a
      integer :: idx_b
      integer :: idx_c
      integer :: idx_outer
      integer :: saved_fd
      logical :: has_warning

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      call begin_stderr_capture('test_finalize_without_ierr_warns_and_leaves_state_unchanged.err', saved_fd, &
                                capture_ierr)
      @assertEqual(0, capture_ierr)

      fake_time = 1.0_wp
      call timer%finalize()

      call end_stderr_capture('test_finalize_without_ierr_warns_and_leaves_state_unchanged.err', saved_fd, &
                              stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      call snapshot_timer(timer, state)
      ctx = find_context_idx(state, 1, root_stack)
      has_warning = index(stderr_text, 'ftimer finalize with active timers; state unchanged') > 0

      @assertTrue(has_warning)
      @assertTrue(state%initialized)
      @assertEqual(1, state%num_segments)
      @assertEqual(1, state%call_stack%depth)
      @assertTrue(state%segments(1)%is_running(ctx))
      @assertEqual(0.0_wp, state%segments(1)%time(ctx))
      @assertEqual(1, state%segments(1)%call_count(ctx))

      fake_time = 3.0_wp
      call timer%stop("A", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 4.0_wp
      call timer%start("outer", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 5.0_wp
      call timer%start("B", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 7.0_wp
      call timer%stop("B", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 8.0_wp
      call timer%start("C", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 11.0_wp
      call timer%stop("C", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 13.0_wp
      call timer%stop("outer", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(13.0_wp, summary%total_time)

      idx_a = find_summary_entry(summary, "A", 0)
      idx_outer = find_summary_entry(summary, "outer", 0)
      idx_b = find_summary_entry(summary, "B", 1)
      idx_c = find_summary_entry(summary, "C", 1)

      @assertTrue(idx_a > 0)
      @assertTrue(idx_outer > 0)
      @assertTrue(idx_b > 0)
      @assertTrue(idx_c > 0)
      @assertEqual(3.0_wp, summary%entries(idx_a)%inclusive_time)
      @assertEqual(3.0_wp, summary%entries(idx_a)%self_time)
      @assertEqual(9.0_wp, summary%entries(idx_outer)%inclusive_time)
      @assertEqual(4.0_wp, summary%entries(idx_outer)%self_time)
      @assertEqual(2.0_wp, summary%entries(idx_b)%inclusive_time)
      @assertEqual(2.0_wp, summary%entries(idx_b)%self_time)
      @assertEqual(3.0_wp, summary%entries(idx_c)%inclusive_time)
      @assertEqual(3.0_wp, summary%entries(idx_c)%self_time)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_finalize_without_ierr_warns_and_leaves_state_unchanged

   @test
   subroutine test_active_lifecycle_warning_paths_do_not_fire_callbacks()
      type(ftimer_t) :: finalize_timer
      type(ftimer_t) :: init_timer
      type(ftimer_t) :: reset_timer
      integer :: before_warn
      integer :: ierr

      call prepare_active_callback_timer(finalize_timer, ierr)
      before_warn = lifecycle_callback_count
      call finalize_timer%finalize()
      @assertEqual(before_warn, lifecycle_callback_count)
      fake_time = 3.0_wp
      call finalize_timer%stop("A", ierr=ierr)
      @assertEqual(before_warn + 1, lifecycle_callback_count)
      call finalize_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call prepare_active_callback_timer(reset_timer, ierr)
      before_warn = lifecycle_callback_count
      fake_time = 2.0_wp
      call reset_timer%reset()
      @assertEqual(before_warn, lifecycle_callback_count)
      fake_time = 4.0_wp
      call reset_timer%stop("A", ierr=ierr)
      @assertEqual(before_warn + 1, lifecycle_callback_count)
      call reset_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call prepare_active_callback_timer(init_timer, ierr)
      before_warn = lifecycle_callback_count
      fake_time = 1.0_wp
      call init_timer%init(mismatch_mode=FTIMER_MISMATCH_WARN)
      @assertEqual(before_warn, lifecycle_callback_count)
      fake_time = 4.0_wp
      call init_timer%stop("A", ierr=ierr)
      @assertEqual(before_warn + 1, lifecycle_callback_count)
      call init_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_active_lifecycle_warning_paths_do_not_fire_callbacks

   @test
   subroutine test_clear_callback_with_active_timer_preserves_callback()
      type(ftimer_t) :: timer
      integer :: before_clear
      integer :: ierr

      call prepare_active_callback_timer(timer, ierr)
      before_clear = lifecycle_callback_count

      call timer%clear_callback(ierr=ierr)

      @assertEqual(FTIMER_ERR_ACTIVE, ierr)
      @assertEqual(before_clear, lifecycle_callback_count)

      fake_time = 2.0_wp
      call timer%stop("A", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(before_clear + 1, lifecycle_callback_count)
   end subroutine test_clear_callback_with_active_timer_preserves_callback

   @test
   subroutine test_set_callback_with_active_timer_preserves_callback()
      type(ftimer_t) :: timer
      integer :: before_replace
      integer :: ierr

      call reset_replacement_callback_count()
      call prepare_active_callback_timer(timer, ierr)
      before_replace = lifecycle_callback_count

      call timer%set_callback(replacement_callback, ierr=ierr)

      @assertEqual(FTIMER_ERR_ACTIVE, ierr)
      @assertEqual(before_replace, lifecycle_callback_count)
      @assertEqual(0, replacement_callback_count)

      fake_time = 2.0_wp
      call timer%stop("A", ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(before_replace + 1, lifecycle_callback_count)
      @assertEqual(0, replacement_callback_count)
   end subroutine test_set_callback_with_active_timer_preserves_callback

   @test
   subroutine test_init_with_active_timer_reports_active_and_preserves_state()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      type(ftimer_call_stack_t) :: root_stack
      type(ftimer_test_state_t) :: after_ierr_state
      type(ftimer_test_state_t) :: after_warn_state
      type(ftimer_test_state_t) :: before_state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: ctx
      integer :: ierr
      integer :: saved_fd
      logical :: has_warning
      logical :: is_silent

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("A", ierr=ierr)
      call snapshot_timer(timer, before_state)

      call begin_stderr_capture('test_init_with_active_timer_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      fake_time = 1.0_wp
      call timer%init(mismatch_mode=FTIMER_MISMATCH_WARN, ierr=ierr)
      call end_stderr_capture('test_init_with_active_timer_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_ACTIVE, ierr)

      is_silent = len_trim(stderr_text) == 0
      @assertTrue(is_silent)

      call snapshot_timer(timer, after_ierr_state)
      ctx = find_context_idx(after_ierr_state, 1, root_stack)
      @assertTrue(after_ierr_state%initialized)
      @assertEqual(before_state%num_segments, after_ierr_state%num_segments)
      @assertEqual(before_state%call_stack%depth, after_ierr_state%call_stack%depth)
      @assertEqual(before_state%init_wtime, after_ierr_state%init_wtime)
      @assertEqual(before_state%init_date, after_ierr_state%init_date)
      @assertEqual(FTIMER_MISMATCH_STRICT, after_ierr_state%mismatch_mode)
      @assertTrue(after_ierr_state%segments(1)%is_running(ctx))
      @assertEqual(0.0_wp, after_ierr_state%segments(1)%time(ctx))
      @assertEqual(1, after_ierr_state%segments(1)%call_count(ctx))

      call begin_stderr_capture('test_init_with_active_timer_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%init(mismatch_mode=FTIMER_MISMATCH_WARN)
      call end_stderr_capture('test_init_with_active_timer_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      has_warning = index(stderr_text, 'ftimer init with active timers; state unchanged') > 0
      @assertTrue(has_warning)

      call snapshot_timer(timer, after_warn_state)
      ctx = find_context_idx(after_warn_state, 1, root_stack)
      @assertTrue(after_warn_state%initialized)
      @assertEqual(before_state%num_segments, after_warn_state%num_segments)
      @assertEqual(before_state%call_stack%depth, after_warn_state%call_stack%depth)
      @assertEqual(before_state%init_wtime, after_warn_state%init_wtime)
      @assertEqual(before_state%init_date, after_warn_state%init_date)
      @assertEqual(FTIMER_MISMATCH_STRICT, after_warn_state%mismatch_mode)
      @assertTrue(after_warn_state%segments(1)%is_running(ctx))
      @assertEqual(0.0_wp, after_warn_state%segments(1)%time(ctx))
      @assertEqual(1, after_warn_state%segments(1)%call_count(ctx))

      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(4.0_wp, summary%total_time)
      @assertEqual(4.0_wp, summary%entries(1)%inclusive_time)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_init_with_active_timer_reports_active_and_preserves_state

   @test
   subroutine test_init_rejects_invalid_mismatch_mode()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      logical :: initialized

      call timer%init(mismatch_mode=99, ierr=ierr)

      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(timer, state)
      initialized = state%initialized
      @assertFalse(initialized)
   end subroutine test_init_rejects_invalid_mismatch_mode

   @test
   subroutine test_reset_without_ierr_warns_and_leaves_state_unchanged()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      type(ftimer_test_state_t) :: state
      type(ftimer_call_stack_t) :: root_stack
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: ierr
      integer :: idx_a
      integer :: idx_done
      integer :: ctx
      integer :: done_ctx
      integer :: saved_fd
      logical :: has_warning

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      call timer%start("done", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp
      call timer%stop("done", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%start("A", ierr=ierr)
      call begin_stderr_capture('test_reset_without_ierr_warns_and_leaves_state_unchanged.err', saved_fd, &
                                capture_ierr)
      @assertEqual(0, capture_ierr)

      fake_time = 2.0_wp
      call timer%reset()

      call end_stderr_capture('test_reset_without_ierr_warns_and_leaves_state_unchanged.err', saved_fd, &
                              stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      call snapshot_timer(timer, state)
      done_ctx = find_context_idx(state, 1, root_stack)
      ctx = find_context_idx(state, 2, root_stack)
      has_warning = index(stderr_text, 'ftimer reset with active timers; state unchanged') > 0

      @assertTrue(has_warning)
      @assertTrue(state%initialized)
      @assertEqual(2, state%num_segments)
      @assertEqual(1, state%call_stack%depth)
      @assertEqual(1.0_wp, state%segments(1)%time(done_ctx))
      @assertFalse(state%segments(1)%is_running(done_ctx))
      @assertEqual(1, state%segments(1)%call_count(done_ctx))
      @assertTrue(state%segments(2)%is_running(ctx))
      @assertEqual(0.0_wp, state%segments(2)%time(ctx))
      @assertEqual(1, state%segments(2)%call_count(ctx))

      fake_time = 4.0_wp
      call timer%stop("A", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      idx_done = find_summary_entry(summary, "done", 0)
      idx_a = find_summary_entry(summary, "A", 0)

      @assertTrue(idx_done > 0)
      @assertTrue(idx_a > 0)
      @assertEqual(4.0_wp, summary%total_time)
      @assertEqual(1.0_wp, summary%entries(idx_done)%inclusive_time)
      @assertEqual(1, summary%entries(idx_done)%call_count)
      @assertEqual(3.0_wp, summary%entries(idx_a)%inclusive_time)
      @assertEqual(1, summary%entries(idx_a)%call_count)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_reset_without_ierr_warns_and_leaves_state_unchanged

   @test
   subroutine test_long_name_above_legacy_len_round_trips()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      type(ftimer_test_state_t) :: state
      character(len=:), allocatable :: printed
      character(len=FTIMER_NAME_LEN + 48) :: long_name
      integer :: expected_len
      integer :: ierr
      integer :: id
      integer :: state_name_len
      integer :: summary_name_len
      integer :: unit
      logical :: printed_name_matches
      logical :: state_name_matches
      logical :: summary_name_matches

      long_name = repeat("x", len(long_name))
      expected_len = len(long_name)

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      id = timer%lookup(long_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, id)

      call timer%start(long_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 2.0_wp
      call timer%stop(long_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, state)
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      state_name_len = len_trim(state%segments(id)%name)
      summary_name_len = len_trim(summary%entries(1)%name)
      state_name_matches = trim(state%segments(id)%name) == long_name
      summary_name_matches = trim(summary%entries(1)%name) == long_name
      open (newunit=unit, status='scratch', action='readwrite')
      call timer%print_summary(unit=unit, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      printed = read_unit_text(unit)
      close (unit)
      printed_name_matches = index(printed, long_name) > 0

      @assertEqual(expected_len, state_name_len)
      @assertEqual(expected_len, summary_name_len)
      @assertTrue(state_name_matches)
      @assertTrue(summary_name_matches)
      @assertTrue(printed_name_matches)
      @assertEqual(2.0_wp, summary%entries(1)%inclusive_time)
   end subroutine test_long_name_above_legacy_len_round_trips

   @test
   subroutine test_names_that_share_legacy_prefix_remain_distinct()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      character(len=FTIMER_NAME_LEN) :: legacy_prefix
      character(len=FTIMER_NAME_LEN + 8) :: first_name
      character(len=FTIMER_NAME_LEN + 8) :: second_name
      integer :: first_id
      integer :: first_idx
      integer :: ierr
      integer :: second_id
      integer :: second_idx
      logical :: first_name_matches
      logical :: second_name_matches

      legacy_prefix = repeat('p', len(legacy_prefix))
      first_name = legacy_prefix//'suffixA1'
      second_name = legacy_prefix//'suffixB2'

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      first_id = timer%lookup(first_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      second_id = timer%lookup(second_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertTrue(first_id /= second_id)

      fake_time = 0.0_wp
      call timer%start(first_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 2.0_wp
      call timer%stop(first_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%start(second_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 5.0_wp
      call timer%stop(second_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      first_idx = find_summary_entry(summary, first_name, 0)
      second_idx = find_summary_entry(summary, second_name, 0)
      @assertTrue(first_idx > 0)
      @assertTrue(second_idx > 0)

      first_name_matches = trim(summary%entries(first_idx)%name) == first_name
      second_name_matches = trim(summary%entries(second_idx)%name) == second_name

      @assertTrue(first_name_matches)
      @assertTrue(second_name_matches)
      @assertEqual(2.0_wp, summary%entries(first_idx)%inclusive_time)
      @assertEqual(3.0_wp, summary%entries(second_idx)%inclusive_time)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_names_that_share_legacy_prefix_remain_distinct

   @test
   subroutine test_lookup_rejects_control_chars_and_edge_whitespace()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      character(len=16) :: carriage_name
      character(len=16) :: newline_name
      character(len=16) :: safe_name
      character(len=16) :: tab_name
      integer :: ierr
      integer :: id

      carriage_name = 'bad'//achar(13)//'name'
      safe_name = 'safe name'
      newline_name = 'bad'//achar(10)//'name'
      tab_name = 'bad'//achar(9)//'name'

      call timer%init(ierr=ierr)

      id = timer%lookup(safe_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, id)

      id = timer%lookup(' leading', ierr=ierr)
      @assertEqual(FTIMER_ERR_INVALID_NAME, ierr)
      @assertEqual(0, id)

      id = timer%lookup(carriage_name, ierr=ierr)
      @assertEqual(FTIMER_ERR_INVALID_NAME, ierr)
      @assertEqual(0, id)

      id = timer%lookup(tab_name, ierr=ierr)
      @assertEqual(FTIMER_ERR_INVALID_NAME, ierr)
      @assertEqual(0, id)

      id = timer%lookup(newline_name, ierr=ierr)
      @assertEqual(FTIMER_ERR_INVALID_NAME, ierr)
      @assertEqual(0, id)

      call snapshot_timer(timer, state)
      @assertEqual(1, state%num_segments)
   end subroutine test_lookup_rejects_control_chars_and_edge_whitespace

   @test
   subroutine test_non_ascii_name_round_trips_without_crashing()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      character(len=8) :: accented_name
      integer :: ctx
      integer :: first_id
      integer :: ierr
      integer :: second_id
      real(wp) :: elapsed

      accented_name = 'caf'//achar(233)

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      first_id = timer%lookup(accented_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%start(accented_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp
      call timer%stop(accented_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      second_id = timer%lookup(accented_name, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(first_id, second_id)

      call snapshot_timer(timer, state)
      ctx = 1
      elapsed = state%segments(first_id)%time(ctx)
      @assertEqual(1.0_wp, elapsed)
      @assertEqual(1, state%segments(first_id)%call_count(ctx))
   end subroutine test_non_ascii_name_round_trips_without_crashing

   @test
   subroutine test_start_stop_validation_preserves_state_and_right_trims()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      integer :: first_id
      integer :: second_id

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      first_id = timer%lookup('trimmed', ierr=ierr)
      second_id = timer%lookup('trimmed   ', ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(first_id, second_id)

      call timer%start('trimmed   ', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%start(' bad', ierr=ierr)
      @assertEqual(FTIMER_ERR_INVALID_NAME, ierr)

      call timer%stop('bad'//achar(9)//'name', ierr=ierr)
      @assertEqual(FTIMER_ERR_INVALID_NAME, ierr)

      call snapshot_timer(timer, state)
      @assertEqual(1, state%num_segments)
      @assertEqual(1, state%call_stack%depth)

      call timer%stop('trimmed', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, state)
      @assertEqual(0, state%call_stack%depth)
   end subroutine test_start_stop_validation_preserves_state_and_right_trims

   @test
   subroutine test_invalid_name_without_ierr_warns_stderr_and_is_noop()
      ! Contract: invalid-name calls without ierr emit a stderr warning and are no-ops.
      ! Timer state must be unchanged — no segment created, call stack depth unchanged.
      ! This is the deliberate warn-and-skip policy for ierr-absent invalid-name calls;
      ! see docs/semantics.md "Timer Name Policy" and issue #49 / PR #43.
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: saved_fd
      logical :: has_warning

      call timer%init()
      call attach_mock_clock(timer)

      call begin_stderr_capture('test_invalid_name_without_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      ! Both calls are no-ops: leading space rejected, control char rejected
      call timer%start(' bad')
      call timer%stop('bad'//achar(9)//'name')

      call end_stderr_capture('test_invalid_name_without_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      has_warning = index(stderr_text, 'ftimer timer name') > 0
      @assertTrue(has_warning)

      call snapshot_timer(timer, state)
      @assertEqual(0, state%num_segments)
      @assertEqual(0, state%call_stack%depth)
   end subroutine test_invalid_name_without_ierr_warns_stderr_and_is_noop

   @test
   subroutine test_invalid_name_lookup_without_ierr_warns_stderr_and_is_noop()
      ! Contract: lookup() with an invalid name and no ierr emits a stderr warning
      ! and is a no-op: returns 0, no segment created, call stack depth unchanged.
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: id
      integer :: saved_fd
      logical :: has_warning

      call timer%init()
      call attach_mock_clock(timer)

      call begin_stderr_capture('test_invalid_name_lookup_without_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      ! Leading space — rejected before any segment creation
      id = timer%lookup(' bad')

      call end_stderr_capture('test_invalid_name_lookup_without_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      @assertEqual(0, id)

      has_warning = index(stderr_text, 'ftimer timer name') > 0
      @assertTrue(has_warning)

      call snapshot_timer(timer, state)
      @assertEqual(0, state%num_segments)
      @assertEqual(0, state%call_stack%depth)
   end subroutine test_invalid_name_lookup_without_ierr_warns_stderr_and_is_noop

   @test
   subroutine test_stderr_capture_isolates_sequential_warning_blocks()
      type(ftimer_t) :: timer
      character(len=:), allocatable :: first_stderr
      character(len=:), allocatable :: second_stderr
      integer :: capture_ierr
      integer :: saved_fd
      logical :: first_has_start
      logical :: first_has_stop
      logical :: second_has_start
      logical :: second_has_stop

      call begin_stderr_capture('test_stderr_capture_isolates_first.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      call timer%start('first')

      call end_stderr_capture('test_stderr_capture_isolates_first.err', saved_fd, first_stderr, capture_ierr)
      @assertEqual(0, capture_ierr)

      call begin_stderr_capture('test_stderr_capture_isolates_second.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      call timer%stop('second')

      call end_stderr_capture('test_stderr_capture_isolates_second.err', saved_fd, second_stderr, capture_ierr)
      @assertEqual(0, capture_ierr)

      first_has_start = index(first_stderr, 'ftimer start before init') > 0
      first_has_stop = index(first_stderr, 'ftimer stop before init') > 0
      second_has_start = index(second_stderr, 'ftimer start before init') > 0
      second_has_stop = index(second_stderr, 'ftimer stop before init') > 0

      @assertTrue(first_has_start)
      @assertFalse(first_has_stop)
      @assertFalse(second_has_start)
      @assertTrue(second_has_stop)
   end subroutine test_stderr_capture_isolates_sequential_warning_blocks

   @test
   subroutine test_stderr_capture_restores_and_isolates_direct_stderr_writes()
      character(len=:), allocatable :: first_stderr
      character(len=:), allocatable :: second_stderr
      integer :: capture_ierr
      integer :: saved_fd
      logical :: first_has_message
      logical :: second_is_silent

      call begin_stderr_capture('test_stderr_capture_direct_first.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      write (error_unit, '(a)') 'direct stderr message'

      call end_stderr_capture('test_stderr_capture_direct_first.err', saved_fd, first_stderr, capture_ierr)
      @assertEqual(0, capture_ierr)

      call begin_stderr_capture('test_stderr_capture_direct_second.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      call end_stderr_capture('test_stderr_capture_direct_second.err', saved_fd, second_stderr, capture_ierr)
      @assertEqual(0, capture_ierr)

      first_has_message = index(first_stderr, 'direct stderr message') > 0
      second_is_silent = len_trim(second_stderr) == 0

      @assertTrue(first_has_message)
      @assertTrue(second_is_silent)
   end subroutine test_stderr_capture_restores_and_isolates_direct_stderr_writes

   @test
   subroutine test_dynamic_growth_creates_many_segments()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: state
      integer :: ierr
      integer :: i
      character(len=12) :: name

      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)

      do i = 1, 20
         write (name, '("timer_",i2.2)') i
         call timer%start(trim(name), ierr=ierr)
         fake_time = fake_time + 1.0_wp
         call timer%stop(trim(name), ierr=ierr)
      end do

      call snapshot_timer(timer, state)
      @assertEqual(20, state%num_segments)
   end subroutine test_dynamic_growth_creates_many_segments

   logical function test_state_matches(lhs, rhs) result(matches)
      type(ftimer_test_state_t), intent(in) :: lhs
      type(ftimer_test_state_t), intent(in) :: rhs
      integer :: i

      matches = (lhs%initialized .eqv. rhs%initialized) .and. &
                (lhs%num_segments == rhs%num_segments) .and. &
                (lhs%call_stack%depth == rhs%call_stack%depth) .and. &
                (lhs%init_wtime == rhs%init_wtime) .and. &
                (lhs%init_date == rhs%init_date) .and. &
                (lhs%mismatch_mode == rhs%mismatch_mode)
      if (.not. matches) return

      if (allocated(lhs%call_stack%ids) .neqv. allocated(rhs%call_stack%ids)) then
         matches = .false.
         return
      end if
      if (allocated(lhs%call_stack%ids)) then
         if (size(lhs%call_stack%ids) /= size(rhs%call_stack%ids)) then
            matches = .false.
            return
         end if
         if (any(lhs%call_stack%ids /= rhs%call_stack%ids)) then
            matches = .false.
            return
         end if
      end if

      if (allocated(lhs%call_stack%activation_tokens) .neqv. &
          allocated(rhs%call_stack%activation_tokens)) then
         matches = .false.
         return
      end if
      if (allocated(lhs%call_stack%activation_tokens)) then
         if (size(lhs%call_stack%activation_tokens) /= size(rhs%call_stack%activation_tokens)) then
            matches = .false.
            return
         end if
         if (any(lhs%call_stack%activation_tokens /= rhs%call_stack%activation_tokens)) then
            matches = .false.
            return
         end if
      end if

      if (allocated(lhs%segments) .neqv. allocated(rhs%segments)) then
         matches = .false.
         return
      end if
      if (.not. allocated(lhs%segments)) return
      if (size(lhs%segments) /= size(rhs%segments)) then
         matches = .false.
         return
      end if

      do i = 1, lhs%num_segments
         if (allocated(lhs%segments(i)%name) .neqv. allocated(rhs%segments(i)%name)) then
            matches = .false.
            return
         end if
         if (allocated(lhs%segments(i)%name)) then
            if (lhs%segments(i)%name /= rhs%segments(i)%name) then
               matches = .false.
               return
            end if
         end if

         if (lhs%segments(i)%contexts%count /= rhs%segments(i)%contexts%count) then
            matches = .false.
            return
         end if
         if (.not. segment_context_stacks_match(lhs%segments(i)%contexts%stacks, &
                                                rhs%segments(i)%contexts%stacks, &
                                                lhs%segments(i)%contexts%count)) then
            matches = .false.
            return
         end if
         if (.not. segment_real_arrays_match(lhs%segments(i)%time, rhs%segments(i)%time)) then
            matches = .false.
            return
         end if
         if (.not. segment_real_arrays_match(lhs%segments(i)%start_time, rhs%segments(i)%start_time)) then
            matches = .false.
            return
         end if
         if (.not. segment_logical_arrays_match(lhs%segments(i)%is_running, rhs%segments(i)%is_running)) then
            matches = .false.
            return
         end if
         if (.not. segment_count_arrays_match(lhs%segments(i)%call_count, rhs%segments(i)%call_count)) then
            matches = .false.
            return
         end if
      end do
   end function test_state_matches

   logical function segment_real_arrays_match(lhs, rhs) result(matches)
      real(wp), allocatable, intent(in) :: lhs(:)
      real(wp), allocatable, intent(in) :: rhs(:)

      matches = allocated(lhs) .eqv. allocated(rhs)
      if (.not. matches) return
      if (.not. allocated(lhs)) return
      matches = size(lhs) == size(rhs)
      if (.not. matches) return
      matches = all(lhs == rhs)
   end function segment_real_arrays_match

   logical function segment_logical_arrays_match(lhs, rhs) result(matches)
      logical, allocatable, intent(in) :: lhs(:)
      logical, allocatable, intent(in) :: rhs(:)

      matches = allocated(lhs) .eqv. allocated(rhs)
      if (.not. matches) return
      if (.not. allocated(lhs)) return
      matches = size(lhs) == size(rhs)
      if (.not. matches) return
      matches = all(lhs .eqv. rhs)
   end function segment_logical_arrays_match

   logical function segment_count_arrays_match(lhs, rhs) result(matches)
      integer(int64), allocatable, intent(in) :: lhs(:)
      integer(int64), allocatable, intent(in) :: rhs(:)

      matches = allocated(lhs) .eqv. allocated(rhs)
      if (.not. matches) return
      if (.not. allocated(lhs)) return
      matches = size(lhs) == size(rhs)
      if (.not. matches) return
      matches = all(lhs == rhs)
   end function segment_count_arrays_match

   logical function segment_context_stacks_match(lhs, rhs, count) result(matches)
      type(ftimer_call_stack_t), allocatable, intent(in) :: lhs(:)
      type(ftimer_call_stack_t), allocatable, intent(in) :: rhs(:)
      integer, intent(in) :: count
      integer :: i

      matches = allocated(lhs) .eqv. allocated(rhs)
      if (.not. matches) return
      if (.not. allocated(lhs)) return
      matches = size(lhs) == size(rhs)
      if (.not. matches) return

      do i = 1, count
         if (.not. stack_storage_matches(lhs(i), rhs(i))) then
            matches = .false.
            return
         end if
      end do
   end function segment_context_stacks_match

   logical function stack_storage_matches(lhs, rhs) result(matches)
      type(ftimer_call_stack_t), intent(in) :: lhs
      type(ftimer_call_stack_t), intent(in) :: rhs

      matches = lhs%depth == rhs%depth
      if (.not. matches) return

      matches = allocated(lhs%ids) .eqv. allocated(rhs%ids)
      if (.not. matches) return
      if (allocated(lhs%ids)) then
         matches = size(lhs%ids) == size(rhs%ids)
         if (.not. matches) return
         matches = all(lhs%ids == rhs%ids)
         if (.not. matches) return
      end if

      matches = allocated(lhs%activation_tokens) .eqv. allocated(rhs%activation_tokens)
      if (.not. matches) return
      if (allocated(lhs%activation_tokens)) then
         matches = size(lhs%activation_tokens) == size(rhs%activation_tokens)
         if (.not. matches) return
         matches = all(lhs%activation_tokens == rhs%activation_tokens)
      end if
   end function stack_storage_matches

   integer function find_summary_entry(summary, name, depth) result(idx)
      type(ftimer_summary_t), intent(in) :: summary
      character(len=*), intent(in) :: name
      integer, intent(in) :: depth
      integer :: i

      idx = 0
      do i = 1, summary%num_entries
         if ((trim(summary%entries(i)%name) == trim(name)) .and. (summary%entries(i)%depth == depth)) then
            idx = i
            return
         end if
      end do
   end function find_summary_entry

   subroutine prepare_active_callback_timer(timer, ierr)
      type(ftimer_t), intent(out) :: timer
      integer, intent(out) :: ierr

      call reset_lifecycle_callback_count()
      call timer%init(ierr=ierr)
      call attach_mock_clock(timer)
      call timer%set_callback(count_lifecycle_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%start("A", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, lifecycle_callback_count)
   end subroutine prepare_active_callback_timer

   subroutine count_lifecycle_callback(timer_id, context_idx, event, timestamp, user_data)
      integer, intent(in) :: timer_id
      integer, intent(in) :: context_idx
      integer, intent(in) :: event
      real(wp), intent(in) :: timestamp
      type(c_ptr), intent(in) :: user_data

      lifecycle_callback_count = lifecycle_callback_count + 1
   end subroutine count_lifecycle_callback

   subroutine replacement_callback(timer_id, context_idx, event, timestamp, user_data)
      integer, intent(in) :: timer_id
      integer, intent(in) :: context_idx
      integer, intent(in) :: event
      real(wp), intent(in) :: timestamp
      type(c_ptr), intent(in) :: user_data

      replacement_callback_count = replacement_callback_count + 1
   end subroutine replacement_callback

   subroutine reset_lifecycle_callback_count()
      lifecycle_callback_count = 0
   end subroutine reset_lifecycle_callback_count

   subroutine reset_replacement_callback_count()
      replacement_callback_count = 0
   end subroutine reset_replacement_callback_count

   function runtime_default_clock() result(t)
      real(wp) :: t

#ifdef FTIMER_USE_MPI
      t = ftimer_mpi_clock()
#else
      t = ftimer_default_clock()
#endif
   end function runtime_default_clock

end module test_edge_cases
