module test_edge_cases
   use, intrinsic :: iso_c_binding, only: c_ptr
   use pfunit
   use ftimer_clock, only: ftimer_default_clock, ftimer_mpi_clock
   use ftimer_core, only: ftimer_t, ftimer_test_state_t
   use ftimer_types, only: FTIMER_ERR_ACTIVE, FTIMER_ERR_INVALID_NAME, FTIMER_ERR_MISMATCH, FTIMER_ERR_NOT_INIT, &
                           FTIMER_ERR_UNKNOWN, FTIMER_MISMATCH_STRICT, FTIMER_MISMATCH_WARN, FTIMER_NAME_LEN, &
                           FTIMER_SUCCESS, ftimer_call_stack_t, ftimer_summary_t, wp
   use, intrinsic :: iso_fortran_env, only: error_unit, int64
   use test_support, only: attach_mock_clock, begin_stderr_capture, end_stderr_capture, fake_time, &
                           find_context_idx, mock_clock, read_unit_text, reset_mock_clock_state, &
                           scaled_mock_clock, snapshot_timer
   implicit none

   integer, save :: lifecycle_callback_count = 0
   integer, save :: replacement_callback_count = 0

contains

   @test
   subroutine test_start_and_stop_before_init_return_not_init()
      type(ftimer_t) :: timer
      integer :: ierr

      call timer%start("A", ierr=ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)

      call timer%stop("A", ierr=ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)
   end subroutine test_start_and_stop_before_init_return_not_init

   @test
   subroutine test_cached_id_negative_paths_are_noops_and_warn_without_ierr()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: after_state
      type(ftimer_test_state_t) :: before_state
      type(ftimer_test_state_t) :: state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: id
      integer :: ierr
      integer :: saved_fd
      logical :: call_count_allocated
      logical :: has_start_warning
      logical :: has_stop_warning
      logical :: is_silent

      call reset_lifecycle_callback_count()
      call timer%set_callback(count_lifecycle_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call begin_stderr_capture('test_cached_id_preinit_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%start_id(1, ierr=ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)
      call timer%stop_id(1, ierr=ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)
      call end_stderr_capture('test_cached_id_preinit_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      is_silent = len_trim(stderr_text) == 0
      @assertTrue(is_silent)
      @assertEqual(0, lifecycle_callback_count)

      call begin_stderr_capture('test_cached_id_preinit_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%start_id(1)
      call timer%stop_id(1)
      call end_stderr_capture('test_cached_id_preinit_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      has_start_warning = index(stderr_text, 'ftimer start_id before init') > 0
      has_stop_warning = index(stderr_text, 'ftimer stop_id before init') > 0
      @assertTrue(has_start_warning)
      @assertTrue(has_stop_warning)
      @assertEqual(0, lifecycle_callback_count)

      call snapshot_timer(timer, state)
      @assertFalse(state%initialized)
      @assertEqual(0, state%num_segments)
      @assertEqual(0, state%call_stack%depth)

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call reset_lifecycle_callback_count()
      call timer%set_callback(count_lifecycle_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, before_state)
      id = timer%lookup('cached_id', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, id)
      call snapshot_timer(timer, before_state)

      call timer%start_id(0, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(timer, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(timer, before_state)
      call timer%stop_id(id + 1, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(timer, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(timer, before_state)
      call begin_stderr_capture('test_cached_id_unknown_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%start_id(id + 1)
      call end_stderr_capture('test_cached_id_unknown_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(timer, after_state)

      has_start_warning = index(stderr_text, 'ftimer start_id with unknown timer id') > 0
      @assertTrue(has_start_warning)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(timer, before_state)
      call begin_stderr_capture('test_cached_id_unknown_stop_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%stop_id(0)
      call end_stderr_capture('test_cached_id_unknown_stop_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(timer, after_state)

      has_stop_warning = index(stderr_text, 'ftimer stop_id with unknown timer id') > 0
      @assertTrue(has_stop_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, lifecycle_callback_count)

      call snapshot_timer(timer, state)
      call_count_allocated = allocated(state%segments(id)%call_count)
      @assertTrue(state%initialized)
      @assertEqual(1, state%num_segments)
      @assertEqual(0, state%call_stack%depth)
      @assertFalse(call_count_allocated)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call reset_lifecycle_callback_count()
      call timer%set_callback(count_lifecycle_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, before_state)
      call timer%start_id(id, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(timer, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(timer, before_state)
      call timer%stop_id(id, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(timer, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(timer, before_state)
      call begin_stderr_capture('test_cached_id_stale_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%start_id(id)
      call end_stderr_capture('test_cached_id_stale_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(timer, after_state)

      has_start_warning = index(stderr_text, 'ftimer start_id with unknown timer id') > 0
      @assertTrue(has_start_warning)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(timer, before_state)
      call begin_stderr_capture('test_cached_id_stale_stop_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%stop_id(id)
      call end_stderr_capture('test_cached_id_stale_stop_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(timer, after_state)

      has_stop_warning = index(stderr_text, 'ftimer stop_id with unknown timer id') > 0
      @assertTrue(has_stop_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, lifecycle_callback_count)

      call snapshot_timer(timer, state)
      @assertTrue(state%initialized)
      @assertEqual(0, state%num_segments)
      @assertEqual(0, state%call_stack%depth)

      id = timer%lookup('valid_after_failures', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%start_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 2.0_wp
      call timer%stop_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, lifecycle_callback_count)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_cached_id_negative_paths_are_noops_and_warn_without_ierr

   @test
   subroutine test_cached_id_stale_alias_after_reinit_is_rejected()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: after_state
      type(ftimer_test_state_t) :: before_state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: ierr
      integer :: new_id
      integer :: old_id
      integer :: saved_fd
      logical :: has_start_warning
      logical :: has_stop_warning
      logical :: ids_differ

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      old_id = timer%lookup('old_cached_region', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call reset_lifecycle_callback_count()
      call timer%set_callback(count_lifecycle_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      new_id = timer%lookup('new_cached_region', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      ids_differ = new_id /= old_id
      @assertTrue(ids_differ)

      call snapshot_timer(timer, before_state)
      call timer%start_id(old_id, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(timer, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(timer, before_state)
      call timer%stop_id(old_id, ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      call snapshot_timer(timer, after_state)
      @assertTrue(test_state_matches(before_state, after_state))

      call snapshot_timer(timer, before_state)
      call begin_stderr_capture('test_cached_id_stale_alias_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%start_id(old_id)
      call timer%stop_id(old_id)
      call end_stderr_capture('test_cached_id_stale_alias_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(timer, after_state)

      has_start_warning = index(stderr_text, 'ftimer start_id with unknown timer id') > 0
      has_stop_warning = index(stderr_text, 'ftimer stop_id with unknown timer id') > 0
      @assertTrue(has_start_warning)
      @assertTrue(has_stop_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, lifecycle_callback_count)

      call timer%start_id(new_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp
      call timer%stop_id(new_id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, lifecycle_callback_count)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_cached_id_stale_alias_after_reinit_is_rejected

   @test
   subroutine test_stop_id_valid_id_mismatch_preserves_state_and_callbacks()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: after_state
      type(ftimer_test_state_t) :: before_state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: id_a
      integer :: id_b
      integer :: ierr
      integer :: saved_fd
      logical :: has_empty_warning
      logical :: has_mismatch_warning
      logical :: is_silent

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call reset_lifecycle_callback_count()
      call timer%set_callback(count_lifecycle_callback, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_a = timer%lookup('valid_a', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      id_b = timer%lookup('valid_b', ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, before_state)
      call begin_stderr_capture('test_stop_id_empty_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%stop_id(id_a, ierr=ierr)
      call end_stderr_capture('test_stop_id_empty_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_MISMATCH, ierr)
      call snapshot_timer(timer, after_state)
      is_silent = len_trim(stderr_text) == 0
      @assertTrue(is_silent)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, lifecycle_callback_count)

      call snapshot_timer(timer, before_state)
      call begin_stderr_capture('test_stop_id_empty_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%stop_id(id_a)
      call end_stderr_capture('test_stop_id_empty_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(timer, after_state)
      has_empty_warning = index(stderr_text, 'ftimer stop mismatch on empty call stack') > 0
      @assertTrue(has_empty_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(0, lifecycle_callback_count)

      call timer%start_id(id_a, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(1, lifecycle_callback_count)

      call snapshot_timer(timer, before_state)
      call begin_stderr_capture('test_stop_id_mismatch_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%stop_id(id_b, ierr=ierr)
      call end_stderr_capture('test_stop_id_mismatch_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_MISMATCH, ierr)
      call snapshot_timer(timer, after_state)
      is_silent = len_trim(stderr_text) == 0
      @assertTrue(is_silent)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(1, lifecycle_callback_count)

      call snapshot_timer(timer, before_state)
      call begin_stderr_capture('test_stop_id_mismatch_warn.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)
      call timer%stop_id(id_b)
      call end_stderr_capture('test_stop_id_mismatch_warn.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      call snapshot_timer(timer, after_state)
      has_mismatch_warning = index(stderr_text, 'ftimer stop mismatch: requested valid_b') > 0
      @assertTrue(has_mismatch_warning)
      @assertTrue(test_state_matches(before_state, after_state))
      @assertEqual(1, lifecycle_callback_count)

      fake_time = 3.0_wp
      call timer%stop_id(id_a, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, lifecycle_callback_count)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_stop_id_valid_id_mismatch_preserves_state_and_callbacks

   @test
   subroutine test_print_summary_before_init_with_ierr_is_silent()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: after_state
      type(ftimer_test_state_t) :: before_state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: ierr
      integer :: saved_fd
      integer :: unit
      logical :: is_silent
      logical :: state_unchanged
      character(len=:), allocatable :: unit_text

      call snapshot_timer(timer, before_state)
      open (newunit=unit, status='scratch', action='readwrite')
      call begin_stderr_capture('test_print_summary_before_init_with_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      call timer%print_summary(unit=unit, ierr=ierr)

      call end_stderr_capture('test_print_summary_before_init_with_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)
      @assertEqual(FTIMER_ERR_NOT_INIT, ierr)

      is_silent = len_trim(stderr_text) == 0
      unit_text = read_unit_text(unit)
      call snapshot_timer(timer, after_state)
      state_unchanged = (after_state%initialized .eqv. before_state%initialized) .and. &
                        (after_state%num_segments == before_state%num_segments) .and. &
                        (after_state%call_stack%depth == before_state%call_stack%depth) .and. &
                        (after_state%init_wtime == before_state%init_wtime) .and. &
                        (after_state%init_date == before_state%init_date)

      @assertTrue(is_silent)
      @assertEqual('', unit_text)
      @assertTrue(state_unchanged)
      close (unit)
   end subroutine test_print_summary_before_init_with_ierr_is_silent

   @test
   subroutine test_print_summary_before_init_without_ierr_warns_to_stderr()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: after_state
      type(ftimer_test_state_t) :: before_state
      character(len=:), allocatable :: stderr_text
      integer :: capture_ierr
      integer :: saved_fd
      integer :: unit
      logical :: has_warning
      logical :: state_unchanged
      character(len=:), allocatable :: unit_text

      call snapshot_timer(timer, before_state)
      open (newunit=unit, status='scratch', action='readwrite')
      call begin_stderr_capture('test_print_summary_before_init_without_ierr.err', saved_fd, capture_ierr)
      @assertEqual(0, capture_ierr)

      call timer%print_summary(unit=unit)

      call end_stderr_capture('test_print_summary_before_init_without_ierr.err', saved_fd, stderr_text, capture_ierr)
      @assertEqual(0, capture_ierr)

      has_warning = index(stderr_text, 'ftimer print_summary before init') > 0
      unit_text = read_unit_text(unit)
      call snapshot_timer(timer, after_state)
      state_unchanged = (after_state%initialized .eqv. before_state%initialized) .and. &
                        (after_state%num_segments == before_state%num_segments) .and. &
                        (after_state%call_stack%depth == before_state%call_stack%depth) .and. &
                        (after_state%init_wtime == before_state%init_wtime) .and. &
                        (after_state%init_date == before_state%init_date)

      @assertTrue(has_warning)
      @assertEqual('', unit_text)
      @assertTrue(state_unchanged)
      close (unit)
   end subroutine test_print_summary_before_init_without_ierr_warns_to_stderr

   @test
   subroutine test_stop_unknown_timer_returns_unknown()
      type(ftimer_t) :: timer
      integer :: ierr

      call timer%init(ierr=ierr)
      call timer%stop("missing", ierr=ierr)
      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
   end subroutine test_stop_unknown_timer_returns_unknown

   @test
   subroutine test_clear_clock_rebases_init_wtime_before_timing()
      type(ftimer_t) :: timer
      type(ftimer_test_state_t) :: after_state
      type(ftimer_test_state_t) :: before_state
      type(ftimer_summary_t) :: summary
      real(wp) :: default_after
      real(wp) :: default_before
      real(wp) :: original_init_wtime
      real(wp) :: rebased_init_wtime
      real(wp) :: summary_after
      real(wp) :: summary_before
      real(wp) :: summary_total
      integer :: ierr
      logical :: rebased_between_defaults
      logical :: summary_total_in_default_window

      call reset_mock_clock_state()
      fake_time = 7.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, before_state)
      original_init_wtime = before_state%init_wtime
      @assertEqual(7.0_wp, original_init_wtime)

      default_before = runtime_default_clock()
      call timer%clear_clock(ierr=ierr)
      default_after = runtime_default_clock()
      @assertEqual(FTIMER_SUCCESS, ierr)

      call snapshot_timer(timer, after_state)
      rebased_init_wtime = after_state%init_wtime
      rebased_between_defaults = (rebased_init_wtime >= default_before) .and. &
                                 (rebased_init_wtime <= default_after)

      @assertTrue(rebased_between_defaults)
      @assertTrue(rebased_init_wtime /= original_init_wtime)

      summary_before = runtime_default_clock()
      call timer%get_summary(summary, ierr=ierr)
      summary_after = runtime_default_clock()
      @assertEqual(FTIMER_SUCCESS, ierr)

      summary_total = summary%total_time
      summary_total_in_default_window = (summary_total >= summary_before - rebased_init_wtime) .and. &
                                        (summary_total <= summary_after - rebased_init_wtime)

      @assertTrue(summary_total_in_default_window)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_clear_clock_rebases_init_wtime_before_timing

   @test
   subroutine test_set_clock_before_init_summary_window_starts_at_init()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call reset_mock_clock_state()
      fake_time = 7.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 9.0_wp
      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 12.0_wp
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(3.0_wp, summary%total_time)
      @assertEqual(0, summary%num_entries)
   end subroutine test_set_clock_before_init_summary_window_starts_at_init

   @test
   subroutine test_set_clock_after_init_rebases_empty_summary_window()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call reset_mock_clock_state()
      fake_time = 100.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 104.0_wp
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(4.0_wp, summary%total_time)
      @assertEqual(0, summary%num_entries)
   end subroutine test_set_clock_after_init_rebases_empty_summary_window

   @test
   subroutine test_set_clock_after_lookup_rebases_summary_window()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: id
      integer :: id_again
      integer :: ierr

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id = timer%lookup("planned", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call reset_mock_clock_state()
      fake_time = 200.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_again = timer%lookup("planned", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(id, id_again)

      fake_time = 204.0_wp
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(4.0_wp, summary%total_time)
      @assertEqual(0, summary%num_entries)

      fake_time = 205.0_wp
      call timer%start_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 208.0_wp
      call timer%stop_id(id, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 210.0_wp
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(10.0_wp, summary%total_time)
      @assertEqual(1, summary%num_entries)
      @assertEqual(3.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(30.0_wp, summary%entries(1)%pct_time)
   end subroutine test_set_clock_after_lookup_rebases_summary_window

   @test
   subroutine test_first_start_preserves_custom_clock_summary_window()
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call reset_mock_clock_state()
      fake_time = 10.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 15.0_wp
      call timer%start("work", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 18.0_wp
      call timer%stop("work", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      fake_time = 20.0_wp
      call timer%get_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(10.0_wp, summary%total_time)
      @assertEqual(3.0_wp, summary%entries(1)%inclusive_time)
      @assertEqual(30.0_wp, summary%entries(1)%pct_time)
   end subroutine test_first_start_preserves_custom_clock_summary_window

   @test
   subroutine test_print_summary_after_set_clock_uses_custom_clock_window()
      type(ftimer_t) :: timer
      character(len=:), allocatable :: text
      integer :: ierr
      integer :: unit
