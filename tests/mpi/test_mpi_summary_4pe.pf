module test_mpi_summary_4pe
   use pfunit
   use, intrinsic :: iso_fortran_env, only: int64
   use mpi_f08, only: MPI_F08_Allreduce => MPI_Allreduce, MPI_F08_Barrier => MPI_Barrier, &
                      MPI_F08_Bcast => MPI_Bcast, MPI_F08_Comm => MPI_Comm, &
                      MPI_F08_COMM_NULL => MPI_COMM_NULL, MPI_F08_COMM_WORLD => MPI_COMM_WORLD, &
                      MPI_F08_Comm_free => MPI_Comm_free, MPI_F08_Comm_rank => MPI_Comm_rank, &
                      MPI_F08_Comm_split => MPI_Comm_split, MPI_F08_INTEGER => MPI_INTEGER, &
                      MPI_F08_MAX => MPI_MAX, MPI_F08_MIN => MPI_MIN, MPI_F08_SUCCESS => MPI_SUCCESS, &
                      MPI_F08_SUM => MPI_SUM
   use ftimer, only: ftimer_default_instance, ftimer_finalize, ftimer_init, ftimer_mpi_summary, &
                     ftimer_mpi_union_summary, ftimer_start, ftimer_stop
   use ftimer_core, only: ftimer_t, ftimer_test_set_call_count
   use ftimer_types, only: FTIMER_SUCCESS, ftimer_mpi_summary_t, ftimer_mpi_union_summary_t, wp
   use test_support, only: attach_mock_clock, fake_time, mock_clock
   implicit none

   @testcase(npes=[4])
   type, extends(MpiTestCase) :: mpi_summary_4pe_case
   end type mpi_summary_4pe_case

contains

   @test
   subroutine test_mpi_summary_supports_consistent_split_communicators(this)
      class(mpi_summary_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: color
      integer :: ierr
      integer :: rank
      type(MPI_F08_Comm) :: subcomm
      integer :: subrank

      rank = this%getProcessRank()
      color = rank/2
      call MPI_F08_Comm_split(MPI_F08_COMM_WORLD, color, rank, subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
      call MPI_F08_Comm_rank(subcomm, subrank, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%init(comm=subcomm, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_split_comm_timer(timer, color, subrank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, summary%num_ranks)
      @assertEqual(1, summary%num_entries)
      @assertEqual('work', trim(summary%entries(1)%name))
      call assert_real_close(summary%min_total_time, 4.0_wp + real(color, wp))
      call assert_real_close(summary%avg_total_time, 5.0_wp + real(color, wp))
      call assert_real_close(summary%max_total_time, 6.0_wp + real(color, wp))
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(1, summary%max_total_time_rank)
      @assertEqual(0, summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(1, summary%entries(1)%max_inclusive_time_rank)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Comm_free(subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
   end subroutine test_mpi_summary_supports_consistent_split_communicators

   @test
   subroutine test_mpi_summary_defaults_to_world_when_comm_omitted(this)
      class(mpi_summary_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_world_timer(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(4, summary%num_ranks)
      @assertEqual(1, summary%num_entries)
      @assertEqual('world', trim(summary%entries(1)%name))
      call assert_real_close(summary%min_total_time, 4.0_wp)
      call assert_real_close(summary%avg_total_time, 5.5_wp)
      call assert_real_close(summary%max_total_time, 7.0_wp)
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(3, summary%max_total_time_rank)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 5.5_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 7.0_wp)
      @assertEqual(0, summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(3, summary%entries(1)%max_inclusive_time_rank)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_defaults_to_world_when_comm_omitted

   @test
   subroutine test_mpi_avg_call_count_is_bounded_on_odd_rank_subcomm(this)
      class(mpi_summary_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      type(ftimer_mpi_union_summary_t) :: union_summary
      type(MPI_F08_Comm) :: subcomm
      integer :: color
      integer :: id_hot
      integer :: ierr
      integer :: rank
      integer :: subrank
      integer(int64) :: boundary_count
      logical :: strict_avg_bounded
      logical :: union_avg_bounded

      rank = this%getProcessRank()
      if (rank < 3) then
         color = 0
      else
         color = 1
      end if

      call MPI_F08_Comm_split(MPI_F08_COMM_WORLD, color, rank, subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank < 3) then
         call MPI_F08_Comm_rank(subcomm, subrank, ierr)
         @assertEqual(MPI_F08_SUCCESS, ierr)

         boundary_count = huge(0_int64) - 6143_int64

         call timer%init(comm=subcomm, ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         call attach_mock_clock(timer)

         call timer%start("odd-wide-count", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 1.0_wp + real(subrank, wp)
         call timer%stop("odd-wide-count", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         id_hot = timer%lookup("odd-wide-count", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         call ftimer_test_set_call_count(timer, id_hot, 1, boundary_count, ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)

         call timer%mpi_summary(summary, ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         @assertEqual(3, summary%num_ranks)
         @assertEqual(1, summary%num_entries)
         @assertEqual(boundary_count, summary%entries(1)%min_call_count)
         @assertEqual(boundary_count, summary%entries(1)%max_call_count)
         strict_avg_bounded = summary%entries(1)%avg_call_count <= real(boundary_count, wp)
         @assertTrue(strict_avg_bounded)
         call assert_real_close(summary%entries(1)%avg_call_count, real(boundary_count, wp))

         call timer%mpi_union_summary(union_summary, ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         @assertEqual(3, union_summary%num_ranks)
         @assertEqual(1, union_summary%num_entries)
         @assertEqual(3, union_summary%entries(1)%participating_rank_count)
         @assertEqual(boundary_count, union_summary%entries(1)%min_call_count)
         @assertEqual(boundary_count, union_summary%entries(1)%max_call_count)
         union_avg_bounded = union_summary%entries(1)%avg_call_count <= real(boundary_count, wp)
         @assertTrue(union_avg_bounded)
         call assert_real_close(union_summary%entries(1)%avg_call_count, real(boundary_count, wp))

         call timer%finalize(ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end if

      call MPI_F08_Comm_free(subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
   end subroutine test_mpi_avg_call_count_is_bounded_on_odd_rank_subcomm

   @test
   subroutine test_mpi_summary_preserves_partial_tie_rank_attribution(this)
      class(mpi_summary_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_partial_tie_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(4, summary%num_ranks)
      @assertEqual(2, summary%num_entries)
      call assert_real_close(summary%min_total_time, 12.0_wp)
      call assert_real_close(summary%max_total_time, 13.0_wp)
      @assertEqual(1, summary%min_total_time_rank)
      @assertEqual(0, summary%max_total_time_rank)
      @assertEqual('Amin', trim(summary%entries(1)%name))
      @assertEqual('Bmax', trim(summary%entries(2)%name))
      call assert_real_close(summary%entries(1)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 7.0_wp)
      @assertEqual(1, summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(0, summary%entries(1)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 6.0_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 8.0_wp)
      @assertEqual(0, summary%entries(2)%min_inclusive_time_rank)
      @assertEqual(1, summary%entries(2)%max_inclusive_time_rank)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_preserves_partial_tie_rank_attribution

   @test
   subroutine test_procedural_mpi_summary_supports_split_communicators(this)
      class(mpi_summary_4pe_case), intent(inout) :: this
      type(ftimer_mpi_summary_t) :: summary
      integer :: color
      integer :: ierr
      integer :: rank
      type(MPI_F08_Comm) :: subcomm
      integer :: subrank

      rank = this%getProcessRank()
      color = rank/2
      call MPI_F08_Comm_split(MPI_F08_COMM_WORLD, color, rank, subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
      call MPI_F08_Comm_rank(subcomm, subrank, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call ftimer_init(comm=subcomm, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call build_split_comm_timer_procedural(color, subrank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call ftimer_mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, summary%num_ranks)
      @assertEqual(1, summary%num_entries)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 4.0_wp + real(color, wp))
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 5.0_wp + real(color, wp))
      call assert_real_close(summary%entries(1)%max_inclusive_time, 6.0_wp + real(color, wp))

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Comm_free(subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
   end subroutine test_procedural_mpi_summary_supports_split_communicators

   @test
   subroutine test_transitional_integer_comm_supports_split_communicators(this)
      class(mpi_summary_4pe_case), intent(inout) :: this
      type(ftimer_t) :: oop_timer
      type(ftimer_mpi_summary_t) :: oop_summary
      type(ftimer_mpi_summary_t) :: procedural_summary
      integer :: color
      integer :: ierr
      integer :: legacy_comm
      integer :: rank
      type(MPI_F08_Comm) :: subcomm
      integer :: subrank

      rank = this%getProcessRank()
      color = rank/2
      call MPI_F08_Comm_split(MPI_F08_COMM_WORLD, color, rank, subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
      call MPI_F08_Comm_rank(subcomm, subrank, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
      legacy_comm = subcomm%MPI_VAL

      call oop_timer%init(comm=legacy_comm, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(comm=legacy_comm, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call build_split_comm_timer(oop_timer, color, subrank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call build_split_comm_timer_procedural(color, subrank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%mpi_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_mpi_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_split_work_summary(oop_summary, color)
      call assert_split_work_summary(procedural_summary, color)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Comm_free(subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
   end subroutine test_transitional_integer_comm_supports_split_communicators

   @test
   subroutine test_mpi_union_summary_reduces_one_rank_and_subset_timers(this)
      class(mpi_summary_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: summary
      integer :: even_idx
      integer :: ierr
      integer :: rank
      integer :: single_idx

      rank = this%getProcessRank()
      fake_time = 0.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_sparse_union_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_union_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      even_idx = union_entry_index(summary, 'even_only')
      single_idx = union_entry_index(summary, 'rank_three')

      @assertEqual(4, summary%num_ranks)
      @assertEqual(2, summary%num_entries)
      @assertTrue(even_idx > 0)
      @assertTrue(single_idx > 0)
      call assert_real_close(summary%min_total_time, 8.0_wp)
      call assert_real_close(summary%avg_total_time, 8.0_wp)
      call assert_real_close(summary%max_total_time, 8.0_wp)
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(0, summary%max_total_time_rank)

      @assertEqual(2, summary%entries(even_idx)%participating_rank_count)
      call assert_real_close(summary%entries(even_idx)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(even_idx)%avg_inclusive_time, 5.0_wp)
      call assert_real_close(summary%entries(even_idx)%max_inclusive_time, 6.0_wp)
      @assertEqual(0, summary%entries(even_idx)%min_inclusive_time_rank)
      @assertEqual(2, summary%entries(even_idx)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(even_idx)%avg_pct_time, 62.5_wp)

      @assertEqual(1, summary%entries(single_idx)%participating_rank_count)
      call assert_real_close(summary%entries(single_idx)%min_inclusive_time, 7.0_wp)
      call assert_real_close(summary%entries(single_idx)%avg_inclusive_time, 7.0_wp)
      call assert_real_close(summary%entries(single_idx)%max_inclusive_time, 7.0_wp)
      @assertEqual(3, summary%entries(single_idx)%min_inclusive_time_rank)
      @assertEqual(3, summary%entries(single_idx)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(single_idx)%avg_pct_time, 87.5_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_reduces_one_rank_and_subset_timers

   @test
   subroutine test_proc_mpi_union_summary_mixes_common_sparse_timers(this)
      class(mpi_summary_4pe_case), intent(inout) :: this
      type(ftimer_mpi_union_summary_t) :: summary
      integer :: common_idx
      integer :: ierr
      integer :: rank
      integer :: sparse_idx

      rank = this%getProcessRank()
      fake_time = 0.0_wp
      call ftimer_default_instance%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_common_plus_rank_three_timer_procedural(rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call ftimer_mpi_union_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      common_idx = union_entry_index(summary, 'common')
      sparse_idx = union_entry_index(summary, 'rank_three')

      @assertEqual(4, summary%num_ranks)
      @assertEqual(2, summary%num_entries)
      @assertTrue(common_idx > 0)
      @assertTrue(sparse_idx > 0)
      call assert_real_close(summary%min_total_time, 4.0_wp)
      call assert_real_close(summary%avg_total_time, 4.75_wp)
      call assert_real_close(summary%max_total_time, 7.0_wp)
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(3, summary%max_total_time_rank)

      @assertEqual(4, summary%entries(common_idx)%participating_rank_count)
      call assert_real_close(summary%entries(common_idx)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(common_idx)%avg_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(common_idx)%max_inclusive_time, 4.0_wp)
      @assertEqual(0, summary%entries(common_idx)%min_inclusive_time_rank)
      @assertEqual(0, summary%entries(common_idx)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(common_idx)%avg_pct_time, 0.25_wp*(300.0_wp + 100.0_wp*4.0_wp/7.0_wp))

      @assertEqual(1, summary%entries(sparse_idx)%participating_rank_count)
      call assert_real_close(summary%entries(sparse_idx)%min_inclusive_time, 3.0_wp)
      call assert_real_close(summary%entries(sparse_idx)%avg_inclusive_time, 3.0_wp)
      call assert_real_close(summary%entries(sparse_idx)%max_inclusive_time, 3.0_wp)
      @assertEqual(3, summary%entries(sparse_idx)%min_inclusive_time_rank)
      @assertEqual(3, summary%entries(sparse_idx)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(sparse_idx)%avg_pct_time, 100.0_wp*3.0_wp/7.0_wp)

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_proc_mpi_union_summary_mixes_common_sparse_timers

   @test
   subroutine test_mpi_summary_reinit_omitted_comm_resets_to_world(this)
      class(mpi_summary_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: color
      integer :: ierr
      integer :: rank
      type(MPI_F08_Comm) :: subcomm
      integer :: subrank

      rank = this%getProcessRank()
      color = rank/2
      call MPI_F08_Comm_split(MPI_F08_COMM_WORLD, color, rank, subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
      call MPI_F08_Comm_rank(subcomm, subrank, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%init(comm=subcomm, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call build_split_comm_timer(timer, color, subrank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call assert_split_work_summary(summary, color)

      call timer%init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)
      call build_world_timer(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call assert_world_summary(summary)

      call ftimer_init(comm=subcomm, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)
      call build_split_comm_timer_procedural(color, subrank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call assert_split_work_summary(summary, color)

      call ftimer_init(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)
      call build_world_timer_procedural(rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call assert_world_summary(summary)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Comm_free(subcomm, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)
   end subroutine test_mpi_summary_reinit_omitted_comm_resets_to_world

   subroutine build_split_comm_timer(timer, color, subrank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: color
      integer, intent(in) :: subrank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("work", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 4.0_wp + real(color, wp) + 2.0_wp*real(subrank, wp)
      call timer%stop("work", ierr=ierr)
   end subroutine build_split_comm_timer

   subroutine build_world_timer(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("world", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 4.0_wp + real(rank, wp)
      call timer%stop("world", ierr=ierr)
   end subroutine build_world_timer

   subroutine build_world_timer_procedural(rank, ierr)
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call ftimer_start("world", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 4.0_wp + real(rank, wp)
      call ftimer_stop("world", ierr=ierr)
   end subroutine build_world_timer_procedural

   subroutine build_partial_tie_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr
      real(wp) :: amin_time
      real(wp) :: bmax_time

      amin_time = 0.0_wp
      bmax_time = 0.0_wp
      select case (rank)
      case (0)
         amin_time = 7.0_wp
         bmax_time = 6.0_wp
      case (1)
         amin_time = 4.0_wp
         bmax_time = 8.0_wp
      case (2)
         amin_time = 4.0_wp
         bmax_time = 8.0_wp
      case default
         amin_time = 6.0_wp
         bmax_time = 7.0_wp
      end select

      fake_time = 0.0_wp
      call timer%start("Amin", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = amin_time
      call timer%stop("Amin", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      call timer%start("Bmax", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = amin_time + bmax_time
      call timer%stop("Bmax", ierr=ierr)
   end subroutine build_partial_tie_timers

   subroutine build_split_comm_timer_procedural(color, subrank, ierr)
      integer, intent(in) :: color
      integer, intent(in) :: subrank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call ftimer_start("work", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 4.0_wp + real(color, wp) + 2.0_wp*real(subrank, wp)
      call ftimer_stop("work", ierr=ierr)
   end subroutine build_split_comm_timer_procedural

   subroutine build_sparse_union_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      ierr = FTIMER_SUCCESS
      if (mod(rank, 2) == 0) then
         fake_time = 0.0_wp
         call timer%start("even_only", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 4.0_wp + real(rank, wp)
         call timer%stop("even_only", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
      end if

      if (rank == 3) then
         fake_time = 0.0_wp
         call timer%start("rank_three", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 7.0_wp
         call timer%stop("rank_three", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
      end if

      fake_time = 8.0_wp
   end subroutine build_sparse_union_timers

   subroutine build_common_plus_rank_three_timer_procedural(rank, ierr)
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call ftimer_start("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 4.0_wp
      call ftimer_stop("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (rank == 3) then
         call ftimer_start("rank_three", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 7.0_wp
         call ftimer_stop("rank_three", ierr=ierr)
      end if
   end subroutine build_common_plus_rank_three_timer_procedural

   integer function union_entry_index(summary, name) result(idx)
      type(ftimer_mpi_union_summary_t), intent(in) :: summary
      character(len=*), intent(in) :: name
      integer :: i

      idx = 0
      do i = 1, summary%num_entries
         if (trim(summary%entries(i)%name) == name) then
            idx = i
            return
         end if
      end do
   end function union_entry_index

   subroutine assert_split_work_summary(summary, color)
      type(ftimer_mpi_summary_t), intent(in) :: summary
      integer, intent(in) :: color

      @assertEqual(2, summary%num_ranks)
      @assertEqual(1, summary%num_entries)
      @assertEqual('work', trim(summary%entries(1)%name))
      call assert_real_close(summary%min_total_time, 4.0_wp + real(color, wp))
      call assert_real_close(summary%avg_total_time, 5.0_wp + real(color, wp))
      call assert_real_close(summary%max_total_time, 6.0_wp + real(color, wp))
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(1, summary%max_total_time_rank)
      @assertEqual(0, summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(1, summary%entries(1)%max_inclusive_time_rank)
   end subroutine assert_split_work_summary

   subroutine assert_world_summary(summary)
      type(ftimer_mpi_summary_t), intent(in) :: summary

      @assertEqual(4, summary%num_ranks)
      @assertEqual(1, summary%num_entries)
      @assertEqual('world', trim(summary%entries(1)%name))
      call assert_real_close(summary%min_total_time, 4.0_wp)
      call assert_real_close(summary%avg_total_time, 5.5_wp)
      call assert_real_close(summary%max_total_time, 7.0_wp)
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(3, summary%max_total_time_rank)
      @assertEqual(0, summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(3, summary%entries(1)%max_inclusive_time_rank)
   end subroutine assert_world_summary

   subroutine assert_real_close(actual, expected)
      real(wp), intent(in) :: actual
      real(wp), intent(in) :: expected
      real(wp) :: diff

      diff = abs(actual - expected)
      @assertTrue(diff < 1.0e-12_wp)
   end subroutine assert_real_close

end module test_mpi_summary_4pe
