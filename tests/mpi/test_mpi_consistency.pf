module test_mpi_consistency
   use pfunit
   use mpi
   use ftimer_core, only: ftimer_t
   use ftimer_types, only: FTIMER_ERR_MPI_INCON, FTIMER_ERR_UNKNOWN, FTIMER_SUCCESS, ftimer_mpi_summary_t, wp
   use test_support, only: attach_mock_clock, begin_stderr_capture, end_stderr_capture, fake_time
   implicit none

   @testcase(npes=[2])
   type, extends(MpiTestCase) :: mpi_consistency_case
   end type mpi_consistency_case

contains

   @test
   subroutine test_mpi_summary_returns_no_global_result_when_contexts_differ(this)
      class(mpi_consistency_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      call attach_mock_clock(timer)

      call build_inconsistent_contexts(timer, this%getProcessRank(), ierr)
      @assertEqual(0, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(0, ierr)
   end subroutine test_mpi_summary_returns_no_global_result_when_contexts_differ

   @test
   subroutine test_mpi_summary_without_ierr_reports_disagreeing_ranks(this)
      class(mpi_consistency_case), intent(inout) :: this
      character(len=:), allocatable :: captured
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: capture_ierr
      integer :: flags(4)
      integer :: ierr
      integer :: rank
      integer :: saved_fd

      rank = this%getProcessRank()
      saved_fd = -1
      flags = 0

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      call attach_mock_clock(timer)

      call build_inconsistent_contexts(timer, rank, ierr)
      @assertEqual(0, ierr)

      if (rank == 0) then
         call begin_stderr_capture('test_mpi_descriptor_mismatch_stderr.txt', saved_fd, capture_ierr)
         @assertEqual(0, capture_ierr)
         call timer%mpi_summary(summary)
         call end_stderr_capture('test_mpi_descriptor_mismatch_stderr.txt', saved_fd, captured, capture_ierr)
         @assertEqual(0, capture_ierr)

         if (index(captured, 'rank 0') > 0) flags(1) = 1
         if (index(captured, 'ranks 1') > 0) flags(2) = 1
         if (index(captured, 'descriptor') > 0) flags(3) = 1
         if ((summary%num_ranks == 0) .and. (summary%num_entries == 0)) flags(4) = 1
      else
         call timer%mpi_summary(summary, ierr=ierr)
         @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      end if

      call MPI_Bcast(flags, size(flags), MPI_INTEGER, 0, MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))

      call timer%finalize(ierr=ierr)
      @assertEqual(0, ierr)
   end subroutine test_mpi_summary_without_ierr_reports_disagreeing_ranks

   @test
   subroutine test_mpi_summary_rejects_mpi_comm_null_before_collectives(this)
      class(mpi_consistency_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_NULL, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_single_local_timer(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_UNKNOWN, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_rejects_mpi_comm_null_before_collectives

   subroutine build_inconsistent_contexts(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp

      if (rank == 0) then
         call timer%start("outer", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 2.0_wp
         call timer%start("work", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 5.0_wp
         call timer%stop("work", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 7.0_wp
         call timer%stop("outer", ierr=ierr)
      else
         call timer%start("outer", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 2.0_wp
         call timer%stop("outer", ierr=ierr)
         if (ierr /= 0) return

         call timer%start("work", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 5.0_wp
         call timer%stop("work", ierr=ierr)
      end if
   end subroutine build_inconsistent_contexts

   subroutine build_single_local_timer(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("work", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 4.0_wp + real(rank, wp)
      call timer%stop("work", ierr=ierr)
   end subroutine build_single_local_timer

end module test_mpi_consistency
