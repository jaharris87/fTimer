module test_mpi_consistency
   use pfunit
   use mpi
   use ftimer_core, only: ftimer_t
   use ftimer_types, only: FTIMER_ERR_MPI_INCON, ftimer_summary_t, wp
   use test_support, only: attach_mock_clock, fake_time
   implicit none

   @testcase(npes=[2])
   type, extends(MpiTestCase) :: mpi_consistency_case
   end type mpi_consistency_case

contains

   @test
   subroutine test_mpi_summary_falls_back_to_local_only_when_contexts_differ(this)
      class(mpi_consistency_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_summary_t) :: summary
      integer :: ierr
      integer :: nprocs
      integer :: rank
      logical :: first_name_matches
      logical :: has_mpi_data
      logical :: second_name_matches

      rank = this%getProcessRank()
      nprocs = this%getNumProcesses()
      @assertEqual(2, nprocs)

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      call attach_mock_clock(timer)

      call build_inconsistent_contexts(timer, rank, ierr)
      @assertEqual(0, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      has_mpi_data = summary%has_mpi_data
      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertFalse(has_mpi_data)
      @assertEqual(2, summary%num_entries)

      first_name_matches = trim(summary%entries(1)%name) == 'outer'
      second_name_matches = trim(summary%entries(2)%name) == 'work'
      @assertTrue(first_name_matches)
      @assertTrue(second_name_matches)
      @assertEqual(-1.0_wp, summary%entries(1)%min_time)
      @assertEqual(-1.0_wp, summary%entries(1)%max_time)
      @assertEqual(-1.0_wp, summary%entries(1)%avg_across_ranks)
      @assertEqual(-1.0_wp, summary%entries(1)%imbalance)
      @assertEqual(-1.0_wp, summary%entries(2)%min_time)
      @assertEqual(-1.0_wp, summary%entries(2)%max_time)
      @assertEqual(-1.0_wp, summary%entries(2)%avg_across_ranks)
      @assertEqual(-1.0_wp, summary%entries(2)%imbalance)

      if (rank == 0) then
         @assertEqual(0, summary%entries(1)%depth)
         @assertEqual(1, summary%entries(2)%depth)
         @assertEqual(7.0_wp, summary%entries(1)%inclusive_time)
         @assertEqual(3.0_wp, summary%entries(2)%inclusive_time)
      else
         @assertEqual(0, summary%entries(1)%depth)
         @assertEqual(0, summary%entries(2)%depth)
         @assertEqual(2.0_wp, summary%entries(1)%inclusive_time)
         @assertEqual(3.0_wp, summary%entries(2)%inclusive_time)
      end if

      call timer%finalize(ierr=ierr)
      @assertEqual(0, ierr)
   end subroutine test_mpi_summary_falls_back_to_local_only_when_contexts_differ

   subroutine build_inconsistent_contexts(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp

      if (rank == 0) then
         call timer%start("outer", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 2.0_wp
         call timer%start("work", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 5.0_wp
         call timer%stop("work", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 7.0_wp
         call timer%stop("outer", ierr=ierr)
      else
         call timer%start("outer", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 2.0_wp
         call timer%stop("outer", ierr=ierr)
         if (ierr /= 0) return

         call timer%start("work", ierr=ierr)
         if (ierr /= 0) return

         fake_time = 5.0_wp
         call timer%stop("work", ierr=ierr)
      end if
   end subroutine build_inconsistent_contexts

end module test_mpi_consistency
