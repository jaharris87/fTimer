   @test
   subroutine test_mpi_summary_uses_canonical_order_for_consistent_timer_sets(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_reordered_top_level_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, summary%num_entries)
      @assertEqual('A', trim(summary%entries(1)%name))
      @assertEqual('B', trim(summary%entries(2)%name))
      call assert_real_close(summary%min_total_time, 12.0_wp)
      call assert_real_close(summary%avg_total_time, 14.0_wp)
      call assert_real_close(summary%max_total_time, 16.0_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 7.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 10.0_wp)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 6.0_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 7.0_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 8.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_uses_canonical_order_for_consistent_timer_sets

   @test
   subroutine test_mpi_summary_preserves_long_timer_names(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      character(len=:), allocatable :: printed
      character(len=*), parameter :: print_path = 'test_mpi_long_name_print_summary.txt'
      character(len=FTIMER_NAME_LEN + 32) :: root_name
      character(len=FTIMER_NAME_LEN + 48) :: child_name
      integer :: child_len
      integer :: expected_child_len
      integer :: expected_root_len
      integer :: flags(2)
      integer :: ierr
      integer :: rank
      integer :: root_len
      integer :: unit
      logical :: child_name_matches
      logical :: root_name_matches

      rank = this%getProcessRank()
      root_name = repeat('r', len(root_name))
      child_name = repeat('c', len(child_name))
      expected_root_len = len(root_name)
      expected_child_len = len(child_name)

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_long_named_timers(timer, this%getProcessRank(), root_name, child_name, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      if (ierr /= FTIMER_SUCCESS) return

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      root_len = len_trim(summary%entries(1)%name)
      child_len = len_trim(summary%entries(2)%name)
      root_name_matches = trim(summary%entries(1)%name) == root_name
      child_name_matches = trim(summary%entries(2)%name) == child_name

      @assertEqual(expected_root_len, root_len)
      @assertEqual(expected_child_len, child_len)
      @assertTrue(root_name_matches)
      @assertTrue(child_name_matches)
      @assertEqual(0, summary_parent_index(summary, 1))
      @assertEqual(1, summary_parent_index(summary, 2))

      flags = 0
      if (rank == 0) then
         call delete_if_exists(print_path)
         open (newunit=unit, file=print_path, status='replace', action='write', iostat=ierr)
         @assertEqual(0, ierr)
         call timer%print_mpi_summary(unit=unit, ierr=ierr)
         close (unit)
      else
         call timer%print_mpi_summary(ierr=ierr)
      end if
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         printed = read_file_text(print_path)
         if (index(printed, root_name) > 0) flags(1) = 1
         if (index(printed, child_name) > 0) flags(2) = 1
      end if
      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_preserves_long_timer_names

   @test
   subroutine test_mpi_summary_handles_nested_reordered_sets(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_reordered_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(4, summary%num_entries)
      @assertEqual('outer', trim(summary%entries(1)%name))
      @assertEqual('A', trim(summary%entries(2)%name))
      @assertEqual('B', trim(summary%entries(3)%name))
      @assertEqual('inner', trim(summary%entries(4)%name))
      @assertEqual(0, summary_parent_index(summary, 1))
      @assertEqual(1, summary_parent_index(summary, 2))
      @assertEqual(1, summary_parent_index(summary, 3))
      @assertEqual(3, summary_parent_index(summary, 4))
      call assert_real_close(summary%min_total_time, 10.0_wp)
      call assert_real_close(summary%avg_total_time, 11.5_wp)
      call assert_real_close(summary%max_total_time, 13.0_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(3)%avg_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(4)%avg_inclusive_time, 1.5_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_handles_nested_reordered_sets

   @test
   subroutine test_mpi_summary_rejects_active_timers_without_global_result(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      type(ftimer_mpi_union_summary_t) :: union_summary
      integer :: ierr

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      fake_time = 0.0_wp
      call timer%start("active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 3.0_wp + 2.0_wp*real(this%getProcessRank(), wp)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_ACTIVE, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%mpi_union_summary(union_summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_ACTIVE, ierr)
      @assertEqual(0, union_summary%num_ranks)
      @assertEqual(0, union_summary%num_entries)
      call assert_union_summary_empty(union_summary)

      fake_time = fake_time + 1.0_wp
      call timer%stop("active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_rejects_active_timers_without_global_result

   @test
   subroutine test_procedural_mpi_summary_matches_oop_api(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: oop_timer
      type(ftimer_mpi_summary_t) :: oop_summary
      type(ftimer_mpi_summary_t) :: procedural_summary
      integer :: ierr

      call oop_timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call build_nested_timers(oop_timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call build_nested_timers_procedural(this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%mpi_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_mpi_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_mpi_summary_matches_oop_api

   @test
   subroutine test_mpi_union_summary_matches_strict_for_identical_trees(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: oop_timer
      type(ftimer_mpi_summary_t) :: strict_summary
      type(ftimer_mpi_union_summary_t) :: oop_union_summary
      type(ftimer_mpi_union_summary_t) :: procedural_union_summary
      integer :: ierr

      call oop_timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call build_nested_timers(oop_timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%mpi_summary(strict_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, strict_summary%num_entries)

      call oop_timer%mpi_union_summary(oop_union_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call assert_union_summary_matches_strict(oop_union_summary, strict_summary)

      call ftimer_init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call build_nested_timers_procedural(this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call ftimer_mpi_union_summary(procedural_union_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call assert_union_summary_matches_strict(procedural_union_summary, strict_summary)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_matches_strict_for_identical_trees

   @test
   subroutine test_mpi_union_summary_sparse_input_is_not_strict_inconsistency(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_mpi_summary_t) :: strict_summary
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: union_summary
      integer :: ierr
      integer :: rank

      rank = this%getProcessRank()
      fake_time = 0.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) then
         fake_time = 0.0_wp
         call timer%start("rank_zero_only", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 2.0_wp
         call timer%stop("rank_zero_only", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      else
         fake_time = 2.0_wp
      end if

      call timer%mpi_summary(strict_summary, ierr=ierr)
      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, strict_summary%num_entries)

      call timer%mpi_union_summary(union_summary, ierr=ierr)

      @assertEqual(FTIMER_SUCCESS, ierr)
      @assertEqual(2, union_summary%num_ranks)
      @assertEqual(1, union_summary%num_entries)
      @assertEqual('rank_zero_only', trim(union_summary%entries(1)%name))
      @assertEqual(1, union_summary%entries(1)%participating_rank_count)
      call assert_real_close(union_summary%min_total_time, 2.0_wp)
      call assert_real_close(union_summary%avg_total_time, 2.0_wp)
      call assert_real_close(union_summary%max_total_time, 2.0_wp)
      @assertEqual(0, union_summary%min_total_time_rank)
      @assertEqual(0, union_summary%max_total_time_rank)
      call assert_real_close(union_summary%entries(1)%min_inclusive_time, 2.0_wp)
      call assert_real_close(union_summary%entries(1)%avg_inclusive_time, 2.0_wp)
      call assert_real_close(union_summary%entries(1)%max_inclusive_time, 2.0_wp)
      @assertEqual(0, union_summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(0, union_summary%entries(1)%max_inclusive_time_rank)
      call assert_real_close(union_summary%entries(1)%avg_self_time, 2.0_wp)
      @assertEqual(1, union_summary%entries(1)%min_call_count)
      @assertEqual(1, union_summary%entries(1)%max_call_count)
      call assert_real_close(union_summary%entries(1)%avg_call_count, 1.0_wp)
      call assert_real_close(union_summary%entries(1)%avg_pct_time, 100.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_sparse_input_is_not_strict_inconsistency

   @test
   subroutine test_mpi_union_summary_mixes_common_and_sparse_timers(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: union_summary
      integer :: common_idx
      integer :: ierr
      integer :: rank
      integer :: sparse_idx

      rank = this%getProcessRank()
      fake_time = 0.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_common_plus_sparse_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_union_summary(union_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      common_idx = union_entry_index(union_summary, 'common')
      sparse_idx = union_entry_index(union_summary, 'rank_zero')

      @assertEqual(2, union_summary%num_ranks)
      @assertEqual(2, union_summary%num_entries)
      @assertTrue(common_idx > 0)
      @assertTrue(sparse_idx > 0)
      call assert_real_close(union_summary%min_total_time, 6.0_wp)
      call assert_real_close(union_summary%avg_total_time, 6.5_wp)
      call assert_real_close(union_summary%max_total_time, 7.0_wp)
      @assertEqual(1, union_summary%min_total_time_rank)
      @assertEqual(0, union_summary%max_total_time_rank)
      @assertEqual(2, union_summary%entries(common_idx)%participating_rank_count)
      call assert_real_close(union_summary%entries(common_idx)%min_inclusive_time, 4.0_wp)
      call assert_real_close(union_summary%entries(common_idx)%avg_inclusive_time, 5.0_wp)
      call assert_real_close(union_summary%entries(common_idx)%max_inclusive_time, 6.0_wp)
      @assertEqual(0, union_summary%entries(common_idx)%min_inclusive_time_rank)
      @assertEqual(1, union_summary%entries(common_idx)%max_inclusive_time_rank)
      @assertEqual(1, union_summary%entries(sparse_idx)%participating_rank_count)
      call assert_real_close(union_summary%entries(sparse_idx)%min_inclusive_time, 3.0_wp)
      call assert_real_close(union_summary%entries(sparse_idx)%avg_inclusive_time, 3.0_wp)
      call assert_real_close(union_summary%entries(sparse_idx)%max_inclusive_time, 3.0_wp)
      @assertEqual(0, union_summary%entries(sparse_idx)%min_inclusive_time_rank)
      @assertEqual(0, union_summary%entries(sparse_idx)%max_inclusive_time_rank)
      call assert_real_close(union_summary%entries(sparse_idx)%avg_pct_time, 100.0_wp*3.0_wp/7.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_mixes_common_and_sparse_timers

   @test
   subroutine test_mpi_union_summary_preserves_sparse_tree_links(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_mpi_summary_t) :: strict_summary
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: union_summary
      integer :: child_idx
      integer :: ierr
      integer :: outer_idx
      integer :: rank

      rank = this%getProcessRank()
      fake_time = 0.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_nested_sparse_union_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(strict_summary, ierr=ierr)
      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)

      call timer%mpi_union_summary(union_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      outer_idx = union_entry_index(union_summary, 'outer')
      child_idx = union_entry_index(union_summary, 'inner_sparse')

      @assertEqual(2, union_summary%num_entries)
      @assertTrue(outer_idx > 0)
      @assertTrue(child_idx > 0)
      @assertEqual(0, union_summary%entries(outer_idx)%parent_id)
      @assertEqual(outer_idx, union_summary%entries(child_idx)%parent_id)
      @assertEqual(0, union_summary%entries(outer_idx)%depth)
      @assertEqual(1, union_summary%entries(child_idx)%depth)
      @assertEqual(2, union_summary%entries(outer_idx)%participating_rank_count)
      @assertEqual(1, union_summary%entries(child_idx)%participating_rank_count)
      call assert_real_close(union_summary%entries(outer_idx)%avg_inclusive_time, 4.5_wp)
      call assert_real_close(union_summary%entries(outer_idx)%avg_self_time, 3.5_wp)
      call assert_real_close(union_summary%entries(child_idx)%avg_inclusive_time, 2.0_wp)
      call assert_real_close(union_summary%entries(child_idx)%avg_self_time, 2.0_wp)
      @assertEqual(0, union_summary%entries(child_idx)%min_inclusive_time_rank)
      @assertEqual(0, union_summary%entries(child_idx)%max_inclusive_time_rank)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_preserves_sparse_tree_links

   @test
   subroutine test_mpi_union_summary_canonicalizes_sparse_paths(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: union_summary
      integer :: ierr
      integer :: rank

      rank = this%getProcessRank()
      fake_time = 0.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_rank_ordered_sparse_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_union_summary(union_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, union_summary%num_entries)
      @assertEqual('aaa_rank_one', trim(union_summary%entries(1)%name))
      @assertEqual('zzz_rank_zero', trim(union_summary%entries(2)%name))
      @assertEqual(1, union_summary%entries(1)%node_id)
      @assertEqual(2, union_summary%entries(2)%node_id)
      @assertEqual(0, union_summary%entries(1)%parent_id)
      @assertEqual(0, union_summary%entries(2)%parent_id)
      @assertEqual(1, union_summary%entries(1)%participating_rank_count)
      @assertEqual(1, union_summary%entries(2)%participating_rank_count)
      @assertEqual(1, union_summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(0, union_summary%entries(2)%min_inclusive_time_rank)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_canonicalizes_sparse_paths

   @test
   subroutine test_mpi_union_summary_uses_canonical_parent_ids(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: union_summary
      integer :: child_idx
      integer :: ierr
      integer :: outer_idx
      integer :: rank
      integer :: z_after_idx

      rank = this%getProcessRank()
      fake_time = 0.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_shifted_parent_sparse_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_union_summary(union_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      outer_idx = union_entry_index(union_summary, 'outer')
      child_idx = union_entry_index(union_summary, 'inner_sparse')
      z_after_idx = union_entry_index(union_summary, 'zzzzz')

      @assertEqual(3, union_summary%num_entries)
      @assertEqual(1, outer_idx)
      @assertEqual(2, child_idx)
      @assertEqual(3, z_after_idx)
      @assertEqual(0, union_summary%entries(outer_idx)%parent_id)
      @assertEqual(outer_idx, union_summary%entries(child_idx)%parent_id)
      @assertEqual(0, union_summary%entries(z_after_idx)%parent_id)
      @assertEqual(2, union_summary%entries(outer_idx)%participating_rank_count)
      @assertEqual(1, union_summary%entries(child_idx)%participating_rank_count)
      @assertEqual(1, union_summary%entries(z_after_idx)%participating_rank_count)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_uses_canonical_parent_ids

   @test
   subroutine test_mpi_union_summary_distinguishes_same_name_paths(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: union_summary
      integer :: ierr
      integer :: parent_a_idx
      integer :: parent_b_idx
      integer :: rank

      rank = this%getProcessRank()
      fake_time = 0.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_same_name_different_parent_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_union_summary(union_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      parent_a_idx = union_entry_index(union_summary, 'parent_a')
      parent_b_idx = union_entry_index(union_summary, 'parent_b')

      @assertEqual(4, union_summary%num_entries)
      @assertEqual(1, parent_a_idx)
      @assertEqual(3, parent_b_idx)
      @assertEqual('work', trim(union_summary%entries(2)%name))
      @assertEqual('work', trim(union_summary%entries(4)%name))
      @assertEqual(parent_a_idx, union_summary%entries(2)%parent_id)
      @assertEqual(parent_b_idx, union_summary%entries(4)%parent_id)
      @assertEqual(1, union_summary%entries(2)%participating_rank_count)
      @assertEqual(1, union_summary%entries(4)%participating_rank_count)
      @assertEqual(0, union_summary%entries(2)%min_inclusive_time_rank)
      @assertEqual(1, union_summary%entries(4)%min_inclusive_time_rank)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_distinguishes_same_name_paths

   @test
   subroutine test_mpi_union_summary_handles_empty_trees(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: union_summary
      integer :: ierr

      fake_time = 0.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 2.0_wp

      call timer%mpi_union_summary(union_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, union_summary%num_ranks)
      @assertEqual(0, union_summary%num_entries)
      call assert_real_close(union_summary%min_total_time, 2.0_wp)
      call assert_real_close(union_summary%avg_total_time, 2.0_wp)
      call assert_real_close(union_summary%max_total_time, 2.0_wp)
      @assertEqual(0, union_summary%min_total_time_rank)
      @assertEqual(0, union_summary%max_total_time_rank)
      @assertTrue(allocated(union_summary%entries))
      @assertEqual(0, size(union_summary%entries))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_handles_empty_trees

   @test
   subroutine test_transitional_integer_comm_compatibility(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: oop_timer
      type(ftimer_mpi_summary_t) :: oop_summary
      type(ftimer_mpi_summary_t) :: procedural_summary
      integer :: ierr
      integer :: legacy_comm

      legacy_comm = MPI_F08_COMM_WORLD%MPI_VAL

      call oop_timer%init(comm=legacy_comm, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(comm=legacy_comm, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call build_nested_timers(oop_timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call build_nested_timers_procedural(this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%mpi_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_mpi_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_transitional_integer_comm_compatibility

   @test
   subroutine test_mpi_print_summary_emits_global_report(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_metadata_t) :: metadata(3)
      character(len=:), allocatable :: printed
      character(len=*), parameter :: expected_header = &
                                     'Timer name  Min Incl (s)  Min Rank  Avg Incl (s)  Max Incl (s)  Max Rank'// &
                                     '   Imb.  Avg Self (s)    Avg Calls    Avg %'
      character(len=*), parameter :: expected_inner_row = &
                                     '  inner         4.000000         0      5.000000      6.000000'// &
                                     '         1   1.200      5.000000       1.000     41.43'
      character(len=*), parameter :: wrong_ratio_inner_row = &
                                     '  inner         4.000000         0      5.000000      6.000000'// &
                                     '         1   1.200      5.000000       1.000     41.67'
      character(len=*), parameter :: print_path = 'test_mpi_print_summary.txt'
      integer :: flags(15)
      integer :: ierr
      integer :: rank
      integer :: unit

      rank = this%getProcessRank()

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      metadata(1)%key = 'Job'
      metadata(1)%value = 'mpi-report'
      metadata(2)%value = 'orphan-mpi'
      metadata(3)%key = 'BlankValue'

      call build_nested_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) then
         call delete_if_exists(print_path)
         open (newunit=unit, file=print_path, status='replace', action='write', iostat=ierr)
         @assertEqual(0, ierr)
         call timer%print_mpi_summary(unit=unit, metadata=metadata, ierr=ierr)
         close (unit)
      else
         call timer%print_mpi_summary(metadata=metadata, ierr=ierr)
      end if
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      flags = 0
      if (rank == 0) then
         printed = read_file_text(print_path)
         if (index(printed, 'MPI ranks') > 0) flags(1) = 1
         if (index(printed, 'Avg Incl (s)') > 0) flags(2) = 1
         if (index(printed, 'mpi-report') > 0) flags(3) = 1
         if (index(printed, 'Avg %') > 0) flags(4) = 1
         if (index(printed, 'Min total rank') > 0) flags(5) = 1
         if (index(printed, 'Max total rank') > 0) flags(6) = 1
         if (index(printed, 'Min Rank') > 0) flags(7) = 1
         if (index(printed, 'abbreviated view of ftimer_mpi_summary_t') > 0) flags(8) = 1
         if (index(printed, 'Avg % is the arithmetic mean of rank-local % Total values') > 0) flags(9) = 1
         if (index(printed, 'not 100*Avg Incl/Avg total time') > 0) flags(10) = 1
         if (index(printed, expected_header) > 0) flags(11) = 1
         if (index(printed, expected_inner_row) > 0) flags(12) = 1
         if (index(printed, wrong_ratio_inner_row) == 0) flags(13) = 1
         if (index(printed, 'BlankValue') > 0) flags(14) = 1
         if (index(printed, 'orphan-mpi') == 0) flags(15) = 1
      end if
      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))
      @assertEqual(1, flags(9))
      @assertEqual(1, flags(10))
      @assertEqual(1, flags(11))
      @assertEqual(1, flags(12))
      @assertEqual(1, flags(13))
      @assertEqual(1, flags(14))
      @assertEqual(1, flags(15))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_print_summary_emits_global_report

   @test
   subroutine test_mpi_write_summary_formats_int64_call_count_average(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: printed
      character(len=*), parameter :: report_path = 'test_mpi_summary_int64_count_report.txt'
      integer :: flags(6)
      integer :: id_hot
      integer :: ierr
      integer :: max_rank
      integer :: min_rank
      integer :: rank
      integer(int64) :: high_count
      integer(int64) :: local_count
      integer(int64) :: low_count
      logical :: found
      real(wp) :: avg_calls
      real(wp) :: avg_incl
      real(wp) :: avg_pct
      real(wp) :: avg_self
      real(wp) :: expected_avg
      real(wp) :: imbalance
      real(wp) :: max_incl
      real(wp) :: min_incl

      rank = this%getProcessRank()
      flags = 0
      low_count = huge(0_int64)
      high_count = huge(0_int64)
      if (rank == 0) then
         local_count = low_count
      else
         local_count = high_count
      end if
      expected_avg = real(huge(0_int64) - 1023_int64, wp)

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call timer%start("wide-count-report", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 2.0_wp + real(rank, wp)
      call timer%stop("wide-count-report", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_hot = timer%lookup("wide-count-report", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_test_set_call_count(timer, id_hot, 1, local_count, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) call delete_if_exists(report_path)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_summary(report_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         printed = read_file_text(report_path)
         if (index(printed, 'Avg Calls') > 0) flags(1) = 1
         if (index(printed, '********') == 0) flags(2) = 1
         found = mpi_report_row_values(printed, 'wide-count-report', min_incl, min_rank, avg_incl, &
                                       max_incl, max_rank, imbalance, avg_self, avg_calls, avg_pct)
         if (found) flags(3) = 1
         if (avg_calls > 0.0_wp) flags(4) = 1
         if (real_rel_close(avg_calls, expected_avg)) flags(5) = 1
         if (max_rank == 1) flags(6) = 1
         call delete_if_exists(report_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_formats_int64_call_count_average

   @test
   subroutine test_mpi_union_write_summary_formats_int64_call_count_average(this)
      class(mpi_summary_case), intent(inout) :: this
