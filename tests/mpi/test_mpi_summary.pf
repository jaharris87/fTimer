   subroutine build_nested_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 2.0_wp + 2.0_wp*real(rank, wp)
      call timer%start("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 6.0_wp + 4.0_wp*real(rank, wp)
      call timer%stop("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 10.0_wp + 4.0_wp*real(rank, wp)
      call timer%stop("outer", ierr=ierr)
   end subroutine build_nested_timers

   subroutine build_tied_nested_timers(timer, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 2.0_wp
      call timer%start("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 5.0_wp
      call timer%stop("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 8.0_wp
      call timer%stop("outer", ierr=ierr)
   end subroutine build_tied_nested_timers

   subroutine build_repeated_timer(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr
      integer :: i
      integer :: repeat_count

      fake_time = 0.0_wp
      repeat_count = 1
      if (rank /= 0) repeat_count = 3

      do i = 1, repeat_count
         call timer%start("repeat", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = fake_time + 2.0_wp
         call timer%stop("repeat", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
      end do
   end subroutine build_repeated_timer

   subroutine build_large_timestamp_nested_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr
      real(wp), parameter :: base_time = 1.0e12_wp

      fake_time = base_time
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 1.25_wp + 0.25_wp*real(rank, wp)
      call timer%start("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 1.75_wp + 0.5_wp*real(rank, wp)
      call timer%stop("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 2.5_wp + real(rank, wp)
      call timer%stop("outer", ierr=ierr)
   end subroutine build_large_timestamp_nested_timers

   subroutine build_long_named_timers(timer, rank, root_name, child_name, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      character(len=*), intent(in) :: root_name
      character(len=*), intent(in) :: child_name
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start(root_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 1.0_wp + real(rank, wp)
      call timer%start(child_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 3.0_wp + real(rank, wp)
      call timer%stop(child_name, ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 5.0_wp + real(rank, wp)
      call timer%stop(root_name, ierr=ierr)
   end subroutine build_long_named_timers

   subroutine build_nested_timers_procedural(rank, ierr)
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call ftimer_start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 2.0_wp + 2.0_wp*real(rank, wp)
      call ftimer_start("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 6.0_wp + 4.0_wp*real(rank, wp)
      call ftimer_stop("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 10.0_wp + 4.0_wp*real(rank, wp)
      call ftimer_stop("outer", ierr=ierr)
   end subroutine build_nested_timers_procedural

   subroutine build_reordered_top_level_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp

      if (rank == 0) then
         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 4.0_wp
         call timer%stop("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 12.0_wp
         call timer%stop("B", ierr=ierr)
      else
         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 6.0_wp
         call timer%stop("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 16.0_wp
         call timer%stop("A", ierr=ierr)
      end if
   end subroutine build_reordered_top_level_timers

   subroutine build_reordered_nested_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (rank == 0) then
         fake_time = 1.0_wp
         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 3.0_wp
         call timer%stop("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 4.0_wp
         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 5.0_wp
         call timer%start("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 6.0_wp
         call timer%stop("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 8.0_wp
         call timer%stop("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 10.0_wp
         call timer%stop("outer", ierr=ierr)
      else
         fake_time = 1.0_wp
         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 2.0_wp
         call timer%start("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 4.0_wp
         call timer%stop("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 5.0_wp
         call timer%stop("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 6.0_wp
         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 12.0_wp
         call timer%stop("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 13.0_wp
         call timer%stop("outer", ierr=ierr)
      end if
   end subroutine build_reordered_nested_timers

   subroutine delete_if_exists(path)
      character(len=*), intent(in) :: path
      integer :: io
      integer :: unit

      open (newunit=unit, file=path, status='old', iostat=io)
      if (io == 0) close (unit, status='delete')
   end subroutine delete_if_exists

   subroutine write_raw_text_without_newline(path, text)
      character(len=*), intent(in) :: path
      character(len=*), intent(in) :: text
      integer :: io
      integer :: unit

      open (newunit=unit, file=path, status='replace', access='stream', form='unformatted', &
            action='write', iostat=io)
      @assertEqual(0, io)
      write (unit, iostat=io) text
      @assertEqual(0, io)
      close (unit)
   end subroutine write_raw_text_without_newline

   subroutine assert_real_close(actual, expected)
      real(wp), intent(in) :: actual
      real(wp), intent(in) :: expected
      real(wp) :: diff

      diff = abs(actual - expected)
      @assertTrue(diff < 1.0e-12_wp)
   end subroutine assert_real_close

   logical function csv_text_field_equals(line, column, expected) result(matches)
      character(len=*), intent(in) :: line
      integer, intent(in) :: column
      character(len=*), intent(in) :: expected
      character(len=:), allocatable :: actual

      actual = csv_field_value(line, column)
      matches = actual == expected
   end function csv_text_field_equals

   logical function csv_real_field_close(line, column, expected) result(matches)
      character(len=*), intent(in) :: line
      integer, intent(in) :: column
      real(wp), intent(in) :: expected
      character(len=:), allocatable :: field_text
      integer :: io
      real(wp) :: actual

      matches = .false.
      field_text = csv_field_value(line, column)
      if (len_trim(field_text) <= 0) return

      read (field_text, *, iostat=io) actual
      if (io /= 0) return

      matches = abs(actual - expected) < 1.0e-12_wp
   end function csv_real_field_close

   integer function count_csv_header_records(text, header) result(count)
      character(len=*), intent(in) :: text
      character(len=*), intent(in) :: header
      character(len=:), allocatable :: line
      integer :: i

      count = 0
      do i = 1, csv_record_count(text)
         line = csv_line_at(text, i)
         if (line == header) count = count + 1
      end do
   end function count_csv_header_records

   subroutine assert_summary_equal(lhs, rhs)
      type(ftimer_mpi_summary_t), intent(in) :: lhs
      type(ftimer_mpi_summary_t), intent(in) :: rhs
      integer :: i
      integer :: lhs_parent_idx
      integer :: rhs_parent_idx

      @assertEqual(rhs%num_ranks, lhs%num_ranks)
      @assertEqual(rhs%num_entries, lhs%num_entries)
      call assert_real_close(lhs%min_total_time, rhs%min_total_time)
      call assert_real_close(lhs%avg_total_time, rhs%avg_total_time)
      call assert_real_close(lhs%max_total_time, rhs%max_total_time)
      @assertEqual(rhs%min_total_time_rank, lhs%min_total_time_rank)
      @assertEqual(rhs%max_total_time_rank, lhs%max_total_time_rank)
      call assert_real_close(lhs%total_time_imbalance, rhs%total_time_imbalance)
      @assertTrue(summary_node_ids_unique(lhs))
      @assertTrue(summary_node_ids_unique(rhs))

      do i = 1, lhs%num_entries
         @assertEqual(trim(rhs%entries(i)%name), trim(lhs%entries(i)%name))
         @assertEqual(rhs%entries(i)%depth, lhs%entries(i)%depth)
         lhs_parent_idx = summary_parent_index(lhs, i)
         rhs_parent_idx = summary_parent_index(rhs, i)
         @assertEqual(rhs_parent_idx, lhs_parent_idx)
         call assert_real_close(lhs%entries(i)%min_inclusive_time, rhs%entries(i)%min_inclusive_time)
         call assert_real_close(lhs%entries(i)%avg_inclusive_time, rhs%entries(i)%avg_inclusive_time)
         call assert_real_close(lhs%entries(i)%max_inclusive_time, rhs%entries(i)%max_inclusive_time)
         @assertEqual(rhs%entries(i)%min_inclusive_time_rank, lhs%entries(i)%min_inclusive_time_rank)
         @assertEqual(rhs%entries(i)%max_inclusive_time_rank, lhs%entries(i)%max_inclusive_time_rank)
         call assert_real_close(lhs%entries(i)%inclusive_imbalance, rhs%entries(i)%inclusive_imbalance)
         call assert_real_close(lhs%entries(i)%min_self_time, rhs%entries(i)%min_self_time)
         call assert_real_close(lhs%entries(i)%max_self_time, rhs%entries(i)%max_self_time)
         call assert_real_close(lhs%entries(i)%avg_self_time, rhs%entries(i)%avg_self_time)
         call assert_real_close(lhs%entries(i)%self_imbalance, rhs%entries(i)%self_imbalance)
         @assertEqual(rhs%entries(i)%min_call_count, lhs%entries(i)%min_call_count)
         @assertEqual(rhs%entries(i)%max_call_count, lhs%entries(i)%max_call_count)
         call assert_real_close(lhs%entries(i)%avg_call_count, rhs%entries(i)%avg_call_count)
         call assert_real_close(lhs%entries(i)%min_pct_time, rhs%entries(i)%min_pct_time)
         call assert_real_close(lhs%entries(i)%max_pct_time, rhs%entries(i)%max_pct_time)
         call assert_real_close(lhs%entries(i)%avg_pct_time, rhs%entries(i)%avg_pct_time)
      end do
   end subroutine assert_summary_equal

end module test_mpi_summary
