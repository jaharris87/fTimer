module test_mpi_summary
   use pfunit
   use mpi
   use ftimer, only: ftimer_default_instance, ftimer_finalize, ftimer_init, ftimer_mpi_summary, &
                     ftimer_print_mpi_summary, ftimer_start, ftimer_stop
   use ftimer_core, only: ftimer_t
   use ftimer_types, only: FTIMER_ERR_ACTIVE, FTIMER_SUCCESS, ftimer_metadata_t, ftimer_mpi_summary_t, wp
   use test_support, only: attach_mock_clock, fake_time, read_file_text, summary_node_ids_unique, summary_parent_index
   implicit none

   @testcase(npes=[2])
   type, extends(MpiTestCase) :: mpi_summary_case
   end type mpi_summary_case

contains

   @test
   subroutine test_mpi_summary_reduces_nested_timer_statistics_on_all_ranks(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr
      integer :: nprocs

      nprocs = this%getNumProcesses()
      @assertEqual(2, nprocs)

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, summary%num_ranks)
      @assertEqual(2, summary%num_entries)
      @assertTrue(summary_node_ids_unique(summary))
      @assertEqual(0, summary_parent_index(summary, 1))
      @assertEqual(1, summary_parent_index(summary, 2))
      @assertEqual('outer', trim(summary%entries(1)%name))
      @assertEqual('inner', trim(summary%entries(2)%name))
      call assert_real_close(summary%min_total_time, 10.0_wp)
      call assert_real_close(summary%avg_total_time, 12.0_wp)
      call assert_real_close(summary%max_total_time, 14.0_wp)
      call assert_real_close(summary%total_time_imbalance, 14.0_wp/12.0_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 10.0_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 12.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 14.0_wp)
      call assert_real_close(summary%entries(1)%avg_self_time, 7.0_wp)
      call assert_real_close(summary%entries(1)%avg_call_count, 1.0_wp)
      call assert_real_close(summary%entries(1)%avg_pct_time, 100.0_wp)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 5.0_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 6.0_wp)
      call assert_real_close(summary%entries(2)%avg_self_time, 5.0_wp)
      call assert_real_close(summary%entries(2)%avg_call_count, 1.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_reduces_nested_timer_statistics_on_all_ranks

   @test
   subroutine test_mpi_summary_preserves_large_time_precision(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_large_timestamp_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_real_close(summary%min_total_time, 2.5_wp)
      call assert_real_close(summary%avg_total_time, 3.0_wp)
      call assert_real_close(summary%max_total_time, 3.5_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 2.5_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 3.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 3.5_wp)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 0.5_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 0.625_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 0.75_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_preserves_large_time_precision

   @test
   subroutine test_mpi_summary_uses_canonical_order_for_consistent_timer_sets(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_reordered_top_level_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, summary%num_entries)
      @assertEqual('A', trim(summary%entries(1)%name))
      @assertEqual('B', trim(summary%entries(2)%name))
      call assert_real_close(summary%min_total_time, 12.0_wp)
      call assert_real_close(summary%avg_total_time, 14.0_wp)
      call assert_real_close(summary%max_total_time, 16.0_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 7.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 10.0_wp)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 6.0_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 7.0_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 8.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_uses_canonical_order_for_consistent_timer_sets

   @test
   subroutine test_mpi_summary_handles_nested_reordered_sets(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_reordered_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(4, summary%num_entries)
      @assertEqual('outer', trim(summary%entries(1)%name))
      @assertEqual('A', trim(summary%entries(2)%name))
      @assertEqual('B', trim(summary%entries(3)%name))
      @assertEqual('inner', trim(summary%entries(4)%name))
      @assertEqual(0, summary_parent_index(summary, 1))
      @assertEqual(1, summary_parent_index(summary, 2))
      @assertEqual(1, summary_parent_index(summary, 3))
      @assertEqual(3, summary_parent_index(summary, 4))
      call assert_real_close(summary%min_total_time, 10.0_wp)
      call assert_real_close(summary%avg_total_time, 11.5_wp)
      call assert_real_close(summary%max_total_time, 13.0_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(3)%avg_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(4)%avg_inclusive_time, 1.5_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_handles_nested_reordered_sets

   @test
   subroutine test_mpi_summary_rejects_active_timers_without_global_result(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      fake_time = 0.0_wp
      call timer%start("active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 3.0_wp + 2.0_wp*real(this%getProcessRank(), wp)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_ACTIVE, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      fake_time = fake_time + 1.0_wp
      call timer%stop("active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_rejects_active_timers_without_global_result

   @test
   subroutine test_procedural_mpi_summary_matches_oop_api(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: oop_timer
      type(ftimer_mpi_summary_t) :: oop_summary
      type(ftimer_mpi_summary_t) :: procedural_summary
      integer :: ierr

      call oop_timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call build_nested_timers(oop_timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call build_nested_timers_procedural(this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%mpi_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_mpi_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_mpi_summary_matches_oop_api

   @test
   subroutine test_mpi_print_summary_emits_global_report(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_metadata_t) :: metadata(1)
      character(len=:), allocatable :: printed
      character(len=*), parameter :: print_path = 'test_mpi_print_summary.txt'
      integer :: ierr
      integer :: rank
      logical :: has_avg_column
      logical :: has_job_metadata
      logical :: has_pct_column
      logical :: has_rank_header
      integer :: unit

      rank = this%getProcessRank()

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      metadata(1)%key = 'Job'
      metadata(1)%value = 'mpi-report'

      call build_nested_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) then
         call delete_if_exists(print_path)
         open (newunit=unit, file=print_path, status='replace', action='write', iostat=ierr)
         @assertEqual(0, ierr)
         call timer%print_mpi_summary(unit=unit, metadata=metadata, ierr=ierr)
         close (unit)
      else
         call timer%print_mpi_summary(metadata=metadata, ierr=ierr)
      end if
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      printed = read_file_text(print_path)
      has_rank_header = index(printed, 'MPI ranks') > 0
      has_avg_column = index(printed, 'Avg Incl (s)') > 0
      has_job_metadata = index(printed, 'mpi-report') > 0
      has_pct_column = index(printed, 'Avg %') > 0
      @assertTrue(has_rank_header)
      @assertTrue(has_avg_column)
      @assertTrue(has_job_metadata)
      @assertTrue(has_pct_column)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_print_summary_emits_global_report

   subroutine build_nested_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 2.0_wp + 2.0_wp*real(rank, wp)
      call timer%start("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 6.0_wp + 4.0_wp*real(rank, wp)
      call timer%stop("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 10.0_wp + 4.0_wp*real(rank, wp)
      call timer%stop("outer", ierr=ierr)
   end subroutine build_nested_timers

   subroutine build_large_timestamp_nested_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr
      real(wp), parameter :: base_time = 1.0e12_wp

      fake_time = base_time
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 1.25_wp + 0.25_wp*real(rank, wp)
      call timer%start("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 1.75_wp + 0.5_wp*real(rank, wp)
      call timer%stop("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = base_time + 2.5_wp + real(rank, wp)
      call timer%stop("outer", ierr=ierr)
   end subroutine build_large_timestamp_nested_timers

   subroutine build_nested_timers_procedural(rank, ierr)
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call ftimer_start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 2.0_wp + 2.0_wp*real(rank, wp)
      call ftimer_start("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 6.0_wp + 4.0_wp*real(rank, wp)
      call ftimer_stop("inner", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 10.0_wp + 4.0_wp*real(rank, wp)
      call ftimer_stop("outer", ierr=ierr)
   end subroutine build_nested_timers_procedural

   subroutine build_reordered_top_level_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp

      if (rank == 0) then
         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 4.0_wp
         call timer%stop("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 12.0_wp
         call timer%stop("B", ierr=ierr)
      else
         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 6.0_wp
         call timer%stop("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 16.0_wp
         call timer%stop("A", ierr=ierr)
      end if
   end subroutine build_reordered_top_level_timers

   subroutine build_reordered_nested_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (rank == 0) then
         fake_time = 1.0_wp
         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 3.0_wp
         call timer%stop("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 4.0_wp
         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 5.0_wp
         call timer%start("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 6.0_wp
         call timer%stop("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 8.0_wp
         call timer%stop("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 10.0_wp
         call timer%stop("outer", ierr=ierr)
      else
         fake_time = 1.0_wp
         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 2.0_wp
         call timer%start("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 4.0_wp
         call timer%stop("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 5.0_wp
         call timer%stop("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 6.0_wp
         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 12.0_wp
         call timer%stop("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 13.0_wp
         call timer%stop("outer", ierr=ierr)
      end if
   end subroutine build_reordered_nested_timers

   subroutine delete_if_exists(path)
      character(len=*), intent(in) :: path
      integer :: io
      integer :: unit

      open (newunit=unit, file=path, status='old', iostat=io)
      if (io == 0) close (unit, status='delete')
   end subroutine delete_if_exists

   subroutine assert_real_close(actual, expected)
      real(wp), intent(in) :: actual
      real(wp), intent(in) :: expected
      real(wp) :: diff

      diff = abs(actual - expected)
      @assertTrue(diff < 1.0e-12_wp)
   end subroutine assert_real_close

   subroutine assert_summary_equal(lhs, rhs)
      type(ftimer_mpi_summary_t), intent(in) :: lhs
      type(ftimer_mpi_summary_t), intent(in) :: rhs
      integer :: i
      integer :: lhs_parent_idx
      integer :: rhs_parent_idx

      @assertEqual(rhs%num_ranks, lhs%num_ranks)
      @assertEqual(rhs%num_entries, lhs%num_entries)
      call assert_real_close(lhs%min_total_time, rhs%min_total_time)
      call assert_real_close(lhs%avg_total_time, rhs%avg_total_time)
      call assert_real_close(lhs%max_total_time, rhs%max_total_time)
      call assert_real_close(lhs%total_time_imbalance, rhs%total_time_imbalance)
      @assertTrue(summary_node_ids_unique(lhs))
      @assertTrue(summary_node_ids_unique(rhs))

      do i = 1, lhs%num_entries
         @assertEqual(trim(rhs%entries(i)%name), trim(lhs%entries(i)%name))
         @assertEqual(rhs%entries(i)%depth, lhs%entries(i)%depth)
         lhs_parent_idx = summary_parent_index(lhs, i)
         rhs_parent_idx = summary_parent_index(rhs, i)
         @assertEqual(rhs_parent_idx, lhs_parent_idx)
         call assert_real_close(lhs%entries(i)%min_inclusive_time, rhs%entries(i)%min_inclusive_time)
         call assert_real_close(lhs%entries(i)%avg_inclusive_time, rhs%entries(i)%avg_inclusive_time)
         call assert_real_close(lhs%entries(i)%max_inclusive_time, rhs%entries(i)%max_inclusive_time)
         call assert_real_close(lhs%entries(i)%inclusive_imbalance, rhs%entries(i)%inclusive_imbalance)
         call assert_real_close(lhs%entries(i)%avg_self_time, rhs%entries(i)%avg_self_time)
         @assertEqual(rhs%entries(i)%min_call_count, lhs%entries(i)%min_call_count)
         @assertEqual(rhs%entries(i)%max_call_count, lhs%entries(i)%max_call_count)
         call assert_real_close(lhs%entries(i)%avg_call_count, rhs%entries(i)%avg_call_count)
         call assert_real_close(lhs%entries(i)%avg_pct_time, rhs%entries(i)%avg_pct_time)
      end do
   end subroutine assert_summary_equal

end module test_mpi_summary
