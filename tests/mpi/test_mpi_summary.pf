   @test
   subroutine test_mpi_union_print_summary_syncs_io_error(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      integer :: ierr
      integer :: max_err
      integer :: min_err
      integer :: mpierr
      integer :: rank

      rank = this%getProcessRank()

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_common_plus_sparse_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) then
         call timer%print_mpi_union_summary(unit=-9876, ierr=ierr)
      else
         call timer%print_mpi_union_summary(ierr=ierr)
      end if
      @assertEqual(FTIMER_ERR_IO, ierr)

      call MPI_F08_Allreduce(ierr, min_err, 1, MPI_F08_INTEGER, MPI_F08_MIN, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)
      call MPI_F08_Allreduce(ierr, max_err, 1, MPI_F08_INTEGER, MPI_F08_MAX, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)

      @assertEqual(FTIMER_ERR_IO, min_err)
      @assertEqual(FTIMER_ERR_IO, max_err)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_print_summary_syncs_io_error

   @test
   subroutine test_mpi_union_print_summary_writes_root_unit_only(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: printed
      character(len=128) :: print_path
      integer :: ierr
      integer :: local_flag
      integer :: min_flag
      integer :: mpierr
      integer :: rank
      integer :: unit

      rank = this%getProcessRank()
      local_flag = 0
      write (print_path, '("test_mpi_union_print_unit_rank_",i0,".txt")') rank

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_common_plus_sparse_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call delete_if_exists(trim(print_path))
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      open (newunit=unit, file=trim(print_path), status='replace', action='write', iostat=ierr)
      @assertEqual(0, ierr)
      call timer%print_mpi_union_summary(unit=unit, ierr=ierr)
      close (unit)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      printed = read_file_text(trim(print_path))
      if (rank == 0) then
         if (index(printed, 'Sparse MPI union summary') > 0) local_flag = 1
      else
         if (len(printed) == 0) local_flag = 1
      end if

      call MPI_F08_Allreduce(local_flag, min_flag, 1, MPI_F08_INTEGER, MPI_F08_MIN, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)

      @assertEqual(1, min_flag)

      call delete_if_exists(trim(print_path))
      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_print_summary_writes_root_unit_only

   @test
   subroutine test_mpi_union_write_summary_preserves_nested_same_name_display(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: printed
      character(len=*), parameter :: report_path = 'test_mpi_union_same_name_report.txt'
      integer :: flags(17)
      integer :: ierr
      integer :: max_rank
      integer :: min_rank
      integer :: missing
      integer :: participating
      integer :: rank
      logical :: found
      real(wp) :: avg_calls
      real(wp) :: avg_incl
      real(wp) :: avg_pct
      real(wp) :: avg_self
      real(wp) :: imbalance
      real(wp) :: max_incl
      real(wp) :: min_incl

      rank = this%getProcessRank()
      flags = 0

      fake_time = 0.0_wp
      call timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_same_name_different_parent_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) call delete_if_exists(report_path)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_union_summary(report_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         printed = read_file_text(report_path)
         if (count_lines_with_prefix(printed, 'parent_a') == 1) flags(1) = 1
         if (count_lines_with_prefix(printed, 'parent_b') == 1) flags(2) = 1
         if (count_union_report_rows(printed, 'work') == 2) flags(3) = 1
         if (count_lines_with_prefix(printed, '  work') == 2) flags(4) = 1
         if (same_name_tree_rows_are_ordered(printed)) flags(5) = 1
         found = union_report_row_values_after_marker(printed, 'parent_a', 'work', participating, missing, &
                                                      min_incl, min_rank, avg_incl, max_incl, max_rank, &
                                                      imbalance, avg_self, avg_calls, avg_pct)
         if (found) flags(6) = 1
         if (participating == 1) flags(7) = 1
         if (missing == 1) flags(8) = 1
         if (min_rank == 0) flags(9) = 1
         if (max_rank == 0) flags(10) = 1
         if (real_close(avg_incl, 2.0_wp)) flags(11) = 1
         found = union_report_row_values_after_marker(printed, 'parent_b', 'work', participating, missing, &
                                                      min_incl, min_rank, avg_incl, max_incl, max_rank, &
                                                      imbalance, avg_self, avg_calls, avg_pct)
         if (found) flags(12) = 1
         if (participating == 1) flags(13) = 1
         if (missing == 1) flags(14) = 1
         if (min_rank == 1) flags(15) = 1
         if (max_rank == 1) flags(16) = 1
         if (real_close(avg_incl, 4.0_wp)) flags(17) = 1
         call delete_if_exists(report_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))
      @assertEqual(1, flags(9))
      @assertEqual(1, flags(10))
      @assertEqual(1, flags(11))
      @assertEqual(1, flags(12))
      @assertEqual(1, flags(13))
      @assertEqual(1, flags(14))
      @assertEqual(1, flags(15))
      @assertEqual(1, flags(16))
      @assertEqual(1, flags(17))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_write_summary_preserves_nested_same_name_display

   @test
   subroutine test_proc_union_write_forwards_append_metadata(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_metadata_t) :: metadata(1)
      character(len=:), allocatable :: procedural_text
      character(len=*), parameter :: procedural_path = 'test_mpi_union_procedural_append_report.txt'
      integer :: flags(4)
      integer :: ierr
      integer :: io
      integer :: rank
      integer :: unit

      rank = this%getProcessRank()
      flags = 0

      fake_time = 0.0_wp
      call ftimer_default_instance%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_common_plus_sparse_timers_procedural(rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      metadata(1)%key = 'Case'
      metadata(1)%value = 'procedure-metadata'

      if (rank == 0) then
         call delete_if_exists(procedural_path)
         open (newunit=unit, file=procedural_path, status='replace', action='write', iostat=io)
         @assertEqual(0, io)
         write (unit, '(a)', iostat=io) 'existing marker'
         @assertEqual(0, io)
         close (unit)
      end if
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call ftimer_write_mpi_union_summary(procedural_path, append=.true., metadata=metadata, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         procedural_text = read_file_text(procedural_path)
         if (index(procedural_text, 'existing marker') > 0) flags(1) = 1
         if (index(procedural_text, 'Case') > 0) flags(2) = 1
         if (index(procedural_text, 'procedure-metadata') > 0) flags(3) = 1
         if (index(procedural_text, 'rank_zero') > 0) flags(4) = 1
         call delete_if_exists(procedural_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_proc_union_write_forwards_append_metadata

   @test
   subroutine test_proc_union_print_emits_sparse_report(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_metadata_t) :: metadata(1)
      character(len=:), allocatable :: printed
      character(len=*), parameter :: print_path = 'test_mpi_union_procedural_print_report.txt'
      integer :: flags(8)
      integer :: ierr
      integer :: max_rank
      integer :: min_rank
      integer :: missing
      integer :: participating
      integer :: rank
      integer :: unit
      logical :: found
      real(wp) :: avg_calls
      real(wp) :: avg_incl
      real(wp) :: avg_pct
      real(wp) :: avg_self
      real(wp) :: imbalance
      real(wp) :: max_incl
      real(wp) :: min_incl

      rank = this%getProcessRank()
      flags = 0

      fake_time = 0.0_wp
      call ftimer_default_instance%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_common_plus_sparse_timers_procedural(rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      metadata(1)%key = 'Mode'
      metadata(1)%value = 'procedural-print'

      if (rank == 0) then
         call delete_if_exists(print_path)
         open (newunit=unit, file=print_path, status='replace', action='write', iostat=ierr)
         @assertEqual(0, ierr)
         call ftimer_print_mpi_union_summary(unit=unit, metadata=metadata, ierr=ierr)
         close (unit)
      else
         call ftimer_print_mpi_union_summary(metadata=metadata, ierr=ierr)
      end if
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         printed = read_file_text(print_path)
         if (index(printed, 'Sparse MPI union summary') > 0) flags(1) = 1
         if (index(printed, 'Mode') > 0) flags(2) = 1
         if (index(printed, 'procedural-print') > 0) flags(3) = 1
         if (index(printed, 'Participating') > 0) flags(4) = 1
         if (index(printed, 'Missing') > 0) flags(5) = 1
         found = union_report_row_values(printed, 'rank_zero', participating, missing, min_incl, min_rank, &
                                         avg_incl, max_incl, max_rank, imbalance, avg_self, avg_calls, avg_pct)
         if (found) flags(6) = 1
         if (participating == 1) flags(7) = 1
         if (missing == 1) flags(8) = 1
         call delete_if_exists(print_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))

      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_proc_union_print_emits_sparse_report

   @test
   subroutine test_procedural_mpi_union_write_summary_matches_oop_report(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: oop_timer
      character(len=:), allocatable :: oop_text
      character(len=:), allocatable :: procedural_text
      character(len=*), parameter :: oop_path = 'test_mpi_union_oop_report.txt'
      character(len=*), parameter :: procedural_path = 'test_mpi_union_procedural_report.txt'
      integer :: flags(2)
      integer :: ierr
      integer :: rank

      rank = this%getProcessRank()
      flags = 0

      fake_time = 0.0_wp
      call oop_timer%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call oop_timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call ftimer_default_instance%set_clock(mock_clock, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_common_plus_sparse_timers(oop_timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call build_common_plus_sparse_timers_procedural(rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) then
         call delete_if_exists(oop_path)
         call delete_if_exists(procedural_path)
      end if
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call oop_timer%write_mpi_union_summary(oop_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_write_mpi_union_summary(procedural_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         oop_text = read_file_text(oop_path)
         procedural_text = read_file_text(procedural_path)
         if (oop_text == procedural_text) flags(1) = 1
         if (index(procedural_text, 'rank_zero') > 0) flags(2) = 1
         call delete_if_exists(oop_path)
         call delete_if_exists(procedural_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_mpi_union_write_summary_matches_oop_report

   @test
   subroutine test_mpi_write_summary_csv_emits_parseable_global_records(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_metadata_t) :: metadata(1)
      character(len=:), allocatable :: csv_text
      character(len=:), allocatable :: field_text
      character(len=:), allocatable :: header
      character(len=:), allocatable :: inner_line
      character(len=:), allocatable :: metadata_line
      character(len=:), allocatable :: outer_line
      character(len=:), allocatable :: summary_line
      character(len=*), parameter :: csv_path = 'test_mpi_summary_export.csv'
      integer :: avg_inclusive_col
      integer :: avg_pct_col
      integer :: avg_self_col
      integer :: avg_total_col
      integer :: avg_call_count_col
      integer :: depth_col
      integer :: flags(52)
      integer :: ierr
      integer :: inclusive_imbalance_col
      integer :: max_inclusive_col
      integer :: max_pct_col
      integer :: max_rank_col
      integer :: max_self_col
      integer :: max_call_count_col
      integer :: min_inclusive_col
      integer :: min_pct_col
      integer :: min_rank_col
      integer :: min_self_col
      integer :: min_call_count_col
      integer :: min_total_col
      integer :: min_total_rank_col
      integer :: name_col
      integer :: node_col
      integer :: num_entries_col
      integer :: num_ranks_col
      integer :: max_total_col
      integer :: max_total_rank_col
      integer :: parent_col
      integer :: rank
      integer :: record_type_col
      integer :: self_imbalance_col
      integer :: summary_kind_col
      integer :: total_imbalance_col
      integer :: unit
      integer :: io

      rank = this%getProcessRank()
      flags = 0

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      metadata(1)%key = 'Job'
      metadata(1)%value = 'mpi, "csv"'

      if (rank == 0) call delete_if_exists(csv_path)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, metadata=metadata, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         csv_text = read_file_text(csv_path)
         if (csv_record_count(csv_text) == 5) flags(1) = 1

         header = csv_line_at(csv_text, 1)
         summary_line = csv_line_at(csv_text, 2)
         metadata_line = csv_line_at(csv_text, 3)
         outer_line = csv_line_at(csv_text, 4)
         inner_line = csv_line_at(csv_text, 5)

         record_type_col = csv_column_index(header, 'record_type')
         summary_kind_col = csv_column_index(header, 'summary_kind')
         num_entries_col = csv_column_index(header, 'num_entries')
         num_ranks_col = csv_column_index(header, 'num_ranks')
         min_total_col = csv_column_index(header, 'min_total_time')
         avg_total_col = csv_column_index(header, 'avg_total_time')
         max_total_col = csv_column_index(header, 'max_total_time')
         min_total_rank_col = csv_column_index(header, 'min_total_time_rank')
         max_total_rank_col = csv_column_index(header, 'max_total_time_rank')
         total_imbalance_col = csv_column_index(header, 'total_time_imbalance')
         node_col = csv_column_index(header, 'node_id')
         parent_col = csv_column_index(header, 'parent_id')
         depth_col = csv_column_index(header, 'depth')
         name_col = csv_column_index(header, 'name')
         min_inclusive_col = csv_column_index(header, 'min_inclusive_time')
         avg_inclusive_col = csv_column_index(header, 'avg_inclusive_time')
         max_inclusive_col = csv_column_index(header, 'max_inclusive_time')
         min_rank_col = csv_column_index(header, 'min_inclusive_time_rank')
         max_rank_col = csv_column_index(header, 'max_inclusive_time_rank')
         inclusive_imbalance_col = csv_column_index(header, 'inclusive_imbalance')
         min_self_col = csv_column_index(header, 'min_self_time')
         avg_self_col = csv_column_index(header, 'avg_self_time')
         max_self_col = csv_column_index(header, 'max_self_time')
         self_imbalance_col = csv_column_index(header, 'self_imbalance')
         min_call_count_col = csv_column_index(header, 'min_call_count')
         avg_call_count_col = csv_column_index(header, 'avg_call_count')
         max_call_count_col = csv_column_index(header, 'max_call_count')
         min_pct_col = csv_column_index(header, 'min_pct_time')
         avg_pct_col = csv_column_index(header, 'avg_pct_time')
         max_pct_col = csv_column_index(header, 'max_pct_time')

         if (record_type_col > 0) flags(2) = 1
         if (csv_text_field_equals(summary_line, summary_kind_col, 'mpi')) flags(3) = 1
         if (csv_text_field_equals(summary_line, record_type_col, 'summary')) flags(4) = 1
         if (csv_text_field_equals(summary_line, num_ranks_col, '2')) flags(5) = 1
         if (csv_text_field_equals(summary_line, num_entries_col, '2')) flags(6) = 1
         if (csv_real_field_close(summary_line, min_total_col, 10.0_wp)) flags(7) = 1
         if (csv_real_field_close(summary_line, avg_total_col, 12.0_wp)) flags(8) = 1
         if (csv_real_field_close(summary_line, max_total_col, 14.0_wp)) flags(9) = 1
         if (csv_text_field_equals(summary_line, min_total_rank_col, '0')) flags(10) = 1
         if (csv_text_field_equals(summary_line, max_total_rank_col, '1')) flags(11) = 1
         if (csv_real_field_close(summary_line, total_imbalance_col, 14.0_wp/12.0_wp)) flags(12) = 1

         if (csv_text_field_equals(metadata_line, summary_kind_col, 'mpi')) flags(44) = 1
         if (csv_text_field_equals(metadata_line, record_type_col, 'metadata')) flags(45) = 1
         field_text = csv_field_value(metadata_line, csv_column_index(header, 'value'))
         if (field_text == 'mpi, "csv"') flags(13) = 1

         if (csv_text_field_equals(outer_line, summary_kind_col, 'mpi')) flags(46) = 1
         if (csv_text_field_equals(outer_line, record_type_col, 'entry')) flags(47) = 1
         if (csv_text_field_equals(outer_line, name_col, 'outer')) flags(14) = 1
         if (csv_text_field_equals(outer_line, node_col, '1')) flags(15) = 1
         if (csv_text_field_equals(outer_line, parent_col, '0')) flags(16) = 1
         if (csv_text_field_equals(outer_line, depth_col, '0')) flags(48) = 1
         if (csv_real_field_close(outer_line, min_inclusive_col, 10.0_wp)) flags(17) = 1
         if (csv_real_field_close(outer_line, avg_inclusive_col, 12.0_wp)) flags(18) = 1
         if (csv_real_field_close(outer_line, max_inclusive_col, 14.0_wp)) flags(19) = 1
         if (csv_real_field_close(outer_line, inclusive_imbalance_col, 14.0_wp/12.0_wp)) flags(20) = 1
         if (csv_real_field_close(outer_line, min_self_col, 6.0_wp)) flags(21) = 1
         if (csv_real_field_close(outer_line, avg_self_col, 7.0_wp)) flags(22) = 1
         if (csv_real_field_close(outer_line, max_self_col, 8.0_wp)) flags(23) = 1
         if (csv_real_field_close(outer_line, self_imbalance_col, 8.0_wp/7.0_wp)) flags(24) = 1
         if (csv_text_field_equals(outer_line, min_call_count_col, '1')) flags(25) = 1
         if (csv_real_field_close(outer_line, avg_call_count_col, 1.0_wp)) flags(26) = 1
         if (csv_text_field_equals(outer_line, max_call_count_col, '1')) flags(27) = 1
         if (csv_real_field_close(outer_line, min_pct_col, 100.0_wp)) flags(28) = 1
         if (csv_real_field_close(outer_line, avg_pct_col, 100.0_wp)) flags(29) = 1
         if (csv_real_field_close(outer_line, max_pct_col, 100.0_wp)) flags(30) = 1

         if (csv_text_field_equals(inner_line, summary_kind_col, 'mpi')) flags(49) = 1
         if (csv_text_field_equals(inner_line, record_type_col, 'entry')) flags(50) = 1
         if (csv_text_field_equals(inner_line, name_col, 'inner')) flags(51) = 1
         if (csv_text_field_equals(inner_line, parent_col, '1')) flags(31) = 1
         if (csv_text_field_equals(inner_line, depth_col, '1')) flags(52) = 1
         if (csv_text_field_equals(inner_line, min_rank_col, '0')) flags(32) = 1
         if (csv_text_field_equals(inner_line, max_rank_col, '1')) flags(33) = 1
         if (csv_real_field_close(inner_line, min_self_col, 4.0_wp)) flags(34) = 1
         if (csv_real_field_close(inner_line, avg_self_col, 5.0_wp)) flags(35) = 1
         if (csv_real_field_close(inner_line, max_self_col, 6.0_wp)) flags(36) = 1
         if (csv_real_field_close(inner_line, self_imbalance_col, 6.0_wp/5.0_wp)) flags(37) = 1
         if (csv_text_field_equals(inner_line, min_call_count_col, '1')) flags(38) = 1
         if (csv_real_field_close(inner_line, avg_call_count_col, 1.0_wp)) flags(39) = 1
         if (csv_text_field_equals(inner_line, max_call_count_col, '1')) flags(40) = 1
         if (csv_real_field_close(inner_line, min_pct_col, 40.0_wp)) flags(41) = 1
         if (csv_real_field_close(inner_line, avg_pct_col, 0.5_wp*(40.0_wp + 100.0_wp*6.0_wp/14.0_wp))) flags(42) = 1
         if (csv_real_field_close(inner_line, max_pct_col, 100.0_wp*6.0_wp/14.0_wp)) flags(43) = 1

         open (newunit=unit, file=csv_path, status='old', iostat=io)
         if (io == 0) close (unit, status='delete')
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))
      @assertEqual(1, flags(9))
      @assertEqual(1, flags(10))
      @assertEqual(1, flags(11))
      @assertEqual(1, flags(12))
      @assertEqual(1, flags(13))
      @assertEqual(1, flags(14))
      @assertEqual(1, flags(15))
      @assertEqual(1, flags(16))
      @assertEqual(1, flags(17))
      @assertEqual(1, flags(18))
      @assertEqual(1, flags(19))
      @assertEqual(1, flags(20))
      @assertEqual(1, flags(21))
      @assertEqual(1, flags(22))
      @assertEqual(1, flags(23))
      @assertEqual(1, flags(24))
      @assertEqual(1, flags(25))
      @assertEqual(1, flags(26))
      @assertEqual(1, flags(27))
      @assertEqual(1, flags(28))
      @assertEqual(1, flags(29))
      @assertEqual(1, flags(30))
      @assertEqual(1, flags(31))
      @assertEqual(1, flags(32))
      @assertEqual(1, flags(33))
      @assertEqual(1, flags(34))
      @assertEqual(1, flags(35))
      @assertEqual(1, flags(36))
      @assertEqual(1, flags(37))
      @assertEqual(1, flags(38))
      @assertEqual(1, flags(39))
      @assertEqual(1, flags(40))
      @assertEqual(1, flags(41))
      @assertEqual(1, flags(42))
      @assertEqual(1, flags(43))
      @assertEqual(1, flags(44))
      @assertEqual(1, flags(45))
      @assertEqual(1, flags(46))
      @assertEqual(1, flags(47))
      @assertEqual(1, flags(48))
      @assertEqual(1, flags(49))
      @assertEqual(1, flags(50))
      @assertEqual(1, flags(51))
      @assertEqual(1, flags(52))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_csv_emits_parseable_global_records

   @test
   subroutine test_mpi_write_summary_csv_exports_call_count_extrema(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: csv_text
      character(len=:), allocatable :: entry_line
      character(len=:), allocatable :: header
      character(len=:), allocatable :: summary_line
      character(len=*), parameter :: csv_path = 'test_mpi_summary_call_extrema_export.csv'
      integer :: avg_call_count_col
      integer :: flags(10)
      integer :: ierr
      integer :: max_call_count_col
      integer :: min_call_count_col
      integer :: name_col
      integer :: num_entries_col
      integer :: rank
      integer :: record_type_col
      integer :: summary_kind_col

      rank = this%getProcessRank()
      flags = 0

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_repeated_timer(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) call delete_if_exists(csv_path)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         csv_text = read_file_text(csv_path)
         if (csv_record_count(csv_text) == 3) flags(1) = 1

         header = csv_line_at(csv_text, 1)
         summary_line = csv_line_at(csv_text, 2)
         entry_line = csv_line_at(csv_text, 3)

         summary_kind_col = csv_column_index(header, 'summary_kind')
         record_type_col = csv_column_index(header, 'record_type')
         num_entries_col = csv_column_index(header, 'num_entries')
         name_col = csv_column_index(header, 'name')
         min_call_count_col = csv_column_index(header, 'min_call_count')
         avg_call_count_col = csv_column_index(header, 'avg_call_count')
         max_call_count_col = csv_column_index(header, 'max_call_count')

         if (csv_text_field_equals(summary_line, summary_kind_col, 'mpi')) flags(2) = 1
         if (csv_text_field_equals(summary_line, record_type_col, 'summary')) flags(3) = 1
         if (csv_text_field_equals(summary_line, num_entries_col, '1')) flags(4) = 1
         if (csv_text_field_equals(entry_line, summary_kind_col, 'mpi')) flags(5) = 1
         if (csv_text_field_equals(entry_line, record_type_col, 'entry')) flags(6) = 1
         if (csv_text_field_equals(entry_line, name_col, 'repeat')) flags(7) = 1
         if (csv_text_field_equals(entry_line, min_call_count_col, '1')) flags(8) = 1
         if (csv_real_field_close(entry_line, avg_call_count_col, 2.0_wp)) flags(9) = 1
         if (csv_text_field_equals(entry_line, max_call_count_col, '3')) flags(10) = 1

         call delete_if_exists(csv_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))
      @assertEqual(1, flags(9))
      @assertEqual(1, flags(10))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_csv_exports_call_count_extrema

   @test
   subroutine test_mpi_write_summary_csv_exports_int64_call_count_extrema(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: csv_text
      character(len=:), allocatable :: entry_line
      character(len=:), allocatable :: field_text
      character(len=:), allocatable :: header
      character(len=:), allocatable :: summary_line
      character(len=*), parameter :: csv_path = 'test_mpi_summary_int64_call_extrema_export.csv'
      character(len=32) :: expected_max_text
      character(len=32) :: expected_min_text
      integer :: avg_call_count_col
      integer :: avg_io
      integer :: flags(13)
      integer :: format_version_col
      integer :: id_hot
      integer :: ierr
      integer :: max_call_count_col
      integer :: min_call_count_col
      integer :: rank
      integer(int64) :: base_count
      integer(int64) :: local_count
      real(wp) :: avg_count_value

      rank = this%getProcessRank()
      flags = 0
      base_count = huge(0_int64) - 1_int64
      local_count = base_count + int(rank, int64)
      write (expected_min_text, '(i0)') base_count
      write (expected_max_text, '(i0)') base_count + 1_int64

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call timer%start("wide-count-csv", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 2.0_wp + real(rank, wp)
      call timer%stop("wide-count-csv", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_hot = timer%lookup("wide-count-csv", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_test_set_call_count(timer, id_hot, 1, local_count, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) call delete_if_exists(csv_path)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         csv_text = read_file_text(csv_path)
         if (csv_record_count(csv_text) == 3) flags(1) = 1

         header = csv_line_at(csv_text, 1)
         summary_line = csv_line_at(csv_text, 2)
         entry_line = csv_line_at(csv_text, 3)
         format_version_col = csv_column_index(header, 'format_version')
         min_call_count_col = csv_column_index(header, 'min_call_count')
         avg_call_count_col = csv_column_index(header, 'avg_call_count')
         max_call_count_col = csv_column_index(header, 'max_call_count')

         if (csv_text_field_equals(entry_line, min_call_count_col, trim(expected_min_text))) flags(2) = 1
         if (csv_decimal_field_not_above_int64(entry_line, avg_call_count_col, base_count + 1_int64)) flags(3) = 1
         if (csv_text_field_equals(entry_line, max_call_count_col, trim(expected_max_text))) flags(4) = 1
         if (min_call_count_col > 0) flags(5) = 1
         if (max_call_count_col > 0) flags(6) = 1
         if (csv_text_field_equals(summary_line, format_version_col, '2')) flags(7) = 1
         if (csv_text_field_equals(entry_line, format_version_col, '2')) flags(8) = 1
         if (avg_call_count_col > 0) flags(9) = 1
         field_text = csv_field_value(entry_line, avg_call_count_col)
         if (index(field_text, '*') == 0) flags(10) = 1
         read (field_text, *, iostat=avg_io) avg_count_value
         if (avg_io == 0) flags(11) = 1
         if ((avg_io == 0) .and. (avg_count_value > 0.0_wp)) flags(12) = 1
         if ((avg_io == 0) .and. &
             real_rel_close(avg_count_value, real(huge(0_int64) - 1023_int64, wp))) flags(13) = 1

         call delete_if_exists(csv_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))
      @assertEqual(1, flags(9))
      @assertEqual(1, flags(10))
      @assertEqual(1, flags(11))
      @assertEqual(1, flags(12))
      @assertEqual(1, flags(13))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_csv_exports_int64_call_count_extrema

   @test
   subroutine test_mpi_write_summary_csv_appends_without_duplicate_header(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: csv_text
      character(len=:), allocatable :: header
      character(len=*), parameter :: csv_path = 'test_mpi_summary_append_export.csv'
      integer :: flags(2)
      integer :: ierr
      integer :: rank

      rank = this%getProcessRank()
      flags = 0

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) call delete_if_exists(csv_path)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%write_mpi_summary_csv(csv_path, append=.true., ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         csv_text = read_file_text(csv_path)
         header = csv_line_at(csv_text, 1)
         if (csv_record_count(csv_text) == 7) flags(1) = 1
         if (count_csv_header_records(csv_text, header) == 1) flags(2) = 1
         call delete_if_exists(csv_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_csv_appends_without_duplicate_header

   @test
   subroutine test_mpi_write_summary_csv_rejects_unterminated_append_target(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: csv_text
      character(len=:), allocatable :: header
      character(len=*), parameter :: csv_path = 'test_mpi_summary_unterminated_append.csv'
      integer :: ierr
      integer :: max_err
      integer :: min_err
      integer :: mpierr
      integer :: rank

      rank = this%getProcessRank()

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) call delete_if_exists(csv_path)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         csv_text = read_file_text(csv_path)
         header = csv_line_at(csv_text, 1)
         call write_raw_text_without_newline(csv_path, header)
      end if
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, append=.true., ierr=ierr)
      @assertEqual(FTIMER_ERR_IO, ierr)

      call MPI_F08_Allreduce(ierr, min_err, 1, MPI_F08_INTEGER, MPI_F08_MIN, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)
      call MPI_F08_Allreduce(ierr, max_err, 1, MPI_F08_INTEGER, MPI_F08_MAX, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)

      @assertEqual(FTIMER_ERR_IO, min_err)
      @assertEqual(FTIMER_ERR_IO, max_err)

      if (rank == 0) call delete_if_exists(csv_path)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_csv_rejects_unterminated_append_target

   @test
