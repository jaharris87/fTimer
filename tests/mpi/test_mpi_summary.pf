      integer :: id_hot
      integer :: ierr
      integer :: max_rank
      integer :: min_rank
      integer :: missing
      integer :: participating
      integer :: rank
      integer(int64) :: high_count
      integer(int64) :: local_count
      integer(int64) :: low_count
      logical :: found
      real(wp) :: avg_calls
      real(wp) :: avg_incl
      real(wp) :: avg_pct
      real(wp) :: avg_self
      real(wp) :: expected_avg
      real(wp) :: imbalance
      real(wp) :: max_incl
      real(wp) :: min_incl

      rank = this%getProcessRank()
      flags = 0
      low_count = huge(0_int64)
      high_count = huge(0_int64)
      if (rank == 0) then
         local_count = low_count
      else
         local_count = high_count
      end if
      expected_avg = real(huge(0_int64) - 1023_int64, wp)

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call timer%start("union-wide-report", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 3.0_wp + real(rank, wp)
      call timer%stop("union-wide-report", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_hot = timer%lookup("union-wide-report", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_test_set_call_count(timer, id_hot, 1, local_count, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) call delete_if_exists(report_path)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_union_summary(report_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         printed = read_file_text(report_path)
         if (index(printed, 'Sparse MPI union summary') > 0) flags(1) = 1
         if (index(printed, '********') == 0) flags(2) = 1
         found = union_report_row_values(printed, 'union-wide-report', participating, missing, min_incl, min_rank, &
                                         avg_incl, max_incl, max_rank, imbalance, avg_self, avg_calls, avg_pct)
         if (found) flags(3) = 1
         if (participating == 2) flags(4) = 1
         if (missing == 0) flags(5) = 1
         if (avg_calls > 0.0_wp) flags(6) = 1
         if (real_rel_close(avg_calls, expected_avg)) flags(7) = 1
         call delete_if_exists(report_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_write_summary_formats_int64_call_count_average

   @test
   subroutine test_mpi_union_write_summary_reports_sparse_participation(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: printed
      character(len=*), parameter :: strict_path = 'test_mpi_sparse_strict_report.txt'
      character(len=*), parameter :: union_path = 'test_mpi_union_report.txt'
      integer :: flags(19)
      integer :: ierr
      integer :: max_rank
      integer :: min_rank
      integer :: missing
      integer :: participating
      integer :: rank
      logical :: found
      logical :: strict_exists
      real(wp) :: avg_calls
      real(wp) :: avg_incl
      real(wp) :: avg_pct
      real(wp) :: avg_self
      real(wp) :: imbalance
      real(wp) :: max_incl
      real(wp) :: min_incl

      rank = this%getProcessRank()
      flags = 0

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_common_plus_sparse_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) then
         call delete_if_exists(strict_path)
         call delete_if_exists(union_path)
      end if
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_summary(strict_path, ierr=ierr)
      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)

      call timer%write_mpi_union_summary(union_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         inquire (file=strict_path, exist=strict_exists)
         if (.not. strict_exists) flags(1) = 1

         printed = read_file_text(union_path)
         if (index(printed, 'Sparse MPI union summary') > 0) flags(2) = 1
         if (index(printed, 'participating ranks only') > 0) flags(3) = 1
         if (index(printed, 'missing ranks are not zero-filled') > 0) flags(4) = 1
         if (index(printed, 'Participating') > 0) flags(5) = 1
         if (index(printed, 'Missing') > 0) flags(6) = 1

         found = union_report_row_values(printed, 'common', participating, missing, min_incl, min_rank, &
                                         avg_incl, max_incl, max_rank, imbalance, avg_self, avg_calls, avg_pct)
         if (found) flags(7) = 1
         if (participating == 2) flags(8) = 1
         if (missing == 0) flags(9) = 1
         if (real_close(avg_incl, 5.0_wp)) flags(10) = 1

         found = union_report_row_values(printed, 'rank_zero', participating, missing, min_incl, min_rank, &
                                         avg_incl, max_incl, max_rank, imbalance, avg_self, avg_calls, avg_pct)
         if (found) flags(11) = 1
         if (participating == 1) flags(12) = 1
         if (missing == 1) flags(13) = 1
         if (real_close(min_incl, 3.0_wp)) flags(14) = 1
         if (real_close(avg_incl, 3.0_wp)) flags(15) = 1
         if (real_close(max_incl, 3.0_wp)) flags(16) = 1
         if (min_rank == 0) flags(17) = 1
         if (max_rank == 0) flags(18) = 1
         if (real_close(avg_pct, 42.86_wp)) flags(19) = 1

         call delete_if_exists(union_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))
      @assertEqual(1, flags(9))
      @assertEqual(1, flags(10))
      @assertEqual(1, flags(11))
      @assertEqual(1, flags(12))
      @assertEqual(1, flags(13))
      @assertEqual(1, flags(14))
      @assertEqual(1, flags(15))
      @assertEqual(1, flags(16))
      @assertEqual(1, flags(17))
      @assertEqual(1, flags(18))
      @assertEqual(1, flags(19))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_write_summary_reports_sparse_participation

   @test
   subroutine test_mpi_union_write_summary_replaces_existing_file(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: printed
      character(len=*), parameter :: report_path = 'test_mpi_union_replace_report.txt'
      integer :: flags(3)
      integer :: ierr
      integer :: io
      integer :: rank
      integer :: unit

      rank = this%getProcessRank()
      flags = 0

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_common_plus_sparse_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) then
         call delete_if_exists(report_path)
         open (newunit=unit, file=report_path, status='replace', action='write', iostat=io)
         @assertEqual(0, io)
         write (unit, '(a)', iostat=io) 'stale sentinel'
         @assertEqual(0, io)
         close (unit)
      end if
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_union_summary(report_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      if (rank == 0) then
         printed = read_file_text(report_path)
         if (index(printed, 'stale sentinel') == 0) flags(1) = 1
         if (count_lines_with_prefix(printed, 'Sparse MPI union summary') == 1) flags(2) = 1
         if (index(printed, 'rank_zero') > 0) flags(3) = 1
         call delete_if_exists(report_path)
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_write_summary_replaces_existing_file

