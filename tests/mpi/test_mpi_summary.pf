module test_mpi_summary
   use pfunit
   use, intrinsic :: iso_fortran_env, only: int64
   use mpi_f08, only: MPI_F08_Allreduce => MPI_Allreduce, MPI_F08_Barrier => MPI_Barrier, &
                      MPI_F08_Bcast => MPI_Bcast, MPI_F08_Comm => MPI_Comm, &
                      MPI_F08_COMM_NULL => MPI_COMM_NULL, MPI_F08_COMM_WORLD => MPI_COMM_WORLD, &
                      MPI_F08_Comm_free => MPI_Comm_free, MPI_F08_Comm_rank => MPI_Comm_rank, &
                      MPI_F08_Comm_split => MPI_Comm_split, MPI_F08_INTEGER => MPI_INTEGER, &
                      MPI_F08_MAX => MPI_MAX, MPI_F08_MIN => MPI_MIN, MPI_F08_SUCCESS => MPI_SUCCESS, &
                      MPI_F08_SUM => MPI_SUM
   use ftimer, only: ftimer_default_instance, ftimer_finalize, ftimer_init, ftimer_mpi_summary, &
                     ftimer_mpi_union_summary, ftimer_print_mpi_summary, ftimer_start, ftimer_stop, &
                     ftimer_print_mpi_union_summary, ftimer_write_mpi_union_summary
   use ftimer_core, only: ftimer_t, ftimer_test_set_call_count
   use ftimer_types, only: FTIMER_ERR_ACTIVE, FTIMER_ERR_IO, FTIMER_ERR_MPI_INCON, FTIMER_NAME_LEN, &
                           FTIMER_SUCCESS, ftimer_metadata_t, ftimer_mpi_summary_t, &
                           ftimer_mpi_union_summary_t, wp
   use test_support, only: attach_mock_clock, csv_column_index, csv_field_value, csv_line_at, csv_record_count, &
                           fake_time, mock_clock, read_file_text, summary_node_ids_unique, summary_parent_index
   implicit none

   @testcase(npes=[2])
   type, extends(MpiTestCase) :: mpi_summary_case
   end type mpi_summary_case

contains

   @test
   subroutine test_mpi_summary_reduces_nested_timer_statistics_on_all_ranks(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr
      integer :: nprocs

      nprocs = this%getNumProcesses()
      @assertEqual(2, nprocs)

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, summary%num_ranks)
      @assertEqual(2, summary%num_entries)
      @assertTrue(summary_node_ids_unique(summary))
      @assertEqual(0, summary_parent_index(summary, 1))
      @assertEqual(1, summary_parent_index(summary, 2))
      @assertEqual('outer', trim(summary%entries(1)%name))
      @assertEqual('inner', trim(summary%entries(2)%name))
      call assert_real_close(summary%min_total_time, 10.0_wp)
      call assert_real_close(summary%avg_total_time, 12.0_wp)
      call assert_real_close(summary%max_total_time, 14.0_wp)
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(1, summary%max_total_time_rank)
      call assert_real_close(summary%total_time_imbalance, 14.0_wp/12.0_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 10.0_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 12.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 14.0_wp)
      @assertEqual(0, summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(1, summary%entries(1)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(1)%inclusive_imbalance, 14.0_wp/12.0_wp)
      call assert_real_close(summary%entries(1)%min_self_time, 6.0_wp)
      call assert_real_close(summary%entries(1)%max_self_time, 8.0_wp)
      call assert_real_close(summary%entries(1)%avg_self_time, 7.0_wp)
      call assert_real_close(summary%entries(1)%self_imbalance, 8.0_wp/7.0_wp)
      call assert_real_close(summary%entries(1)%avg_call_count, 1.0_wp)
      call assert_real_close(summary%entries(1)%avg_pct_time, 100.0_wp)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 5.0_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 6.0_wp)
      @assertEqual(0, summary%entries(2)%min_inclusive_time_rank)
      @assertEqual(1, summary%entries(2)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(2)%inclusive_imbalance, 6.0_wp/5.0_wp)
      call assert_real_close(summary%entries(2)%min_pct_time, 40.0_wp)
      call assert_real_close(summary%entries(2)%max_pct_time, 100.0_wp*6.0_wp/14.0_wp)
      call assert_real_close(summary%entries(2)%avg_pct_time, 0.5_wp*(40.0_wp + 100.0_wp*6.0_wp/14.0_wp))
      call assert_real_close(summary%entries(2)%min_self_time, 4.0_wp)
      call assert_real_close(summary%entries(2)%max_self_time, 6.0_wp)
      call assert_real_close(summary%entries(2)%avg_self_time, 5.0_wp)
      call assert_real_close(summary%entries(2)%self_imbalance, 6.0_wp/5.0_wp)
      call assert_real_close(summary%entries(2)%avg_call_count, 1.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_reduces_nested_timer_statistics_on_all_ranks

   @test
   subroutine test_mpi_summary_prefers_lowest_rank_when_extrema_tie(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_tied_nested_timers(timer, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_real_close(summary%min_total_time, 8.0_wp)
      call assert_real_close(summary%max_total_time, 8.0_wp)
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(0, summary%max_total_time_rank)
      @assertEqual(2, summary%num_entries)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 8.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 8.0_wp)
      @assertEqual(0, summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(0, summary%entries(1)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 3.0_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 3.0_wp)
      @assertEqual(0, summary%entries(2)%min_inclusive_time_rank)
      @assertEqual(0, summary%entries(2)%max_inclusive_time_rank)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_prefers_lowest_rank_when_extrema_tie

   @test
   subroutine test_mpi_summary_preserves_large_time_precision(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_large_timestamp_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_real_close(summary%min_total_time, 2.5_wp)
      call assert_real_close(summary%avg_total_time, 3.0_wp)
      call assert_real_close(summary%max_total_time, 3.5_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 2.5_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 3.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 3.5_wp)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 0.5_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 0.625_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 0.75_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_preserves_large_time_precision

   @test
   subroutine test_mpi_summary_reduces_call_extrema(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_repeated_timer(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(1, summary%num_entries)
      @assertEqual('repeat', trim(summary%entries(1)%name))
      call assert_real_close(summary%min_total_time, 2.0_wp)
      call assert_real_close(summary%avg_total_time, 4.0_wp)
      call assert_real_close(summary%max_total_time, 6.0_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 2.0_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 6.0_wp)
      call assert_real_close(summary%entries(1)%inclusive_imbalance, 1.5_wp)
      @assertEqual(1, summary%entries(1)%min_call_count)
      @assertEqual(3, summary%entries(1)%max_call_count)
      call assert_real_close(summary%entries(1)%avg_call_count, 2.0_wp)
      call assert_real_close(summary%entries(1)%avg_pct_time, 100.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_reduces_call_extrema

   @test
   subroutine test_mpi_summary_reduces_int64_call_extrema(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: id_hot
      integer :: ierr
      integer :: rank
      integer(int64) :: high_count
      integer(int64) :: local_count
      integer(int64) :: low_count
      logical :: avg_count_matches
      logical :: avg_count_not_above_max
      logical :: avg_count_positive
      logical :: max_count_matches
      logical :: min_count_matches
      real(wp) :: expected_avg

      rank = this%getProcessRank()
      low_count = huge(0_int64) - 1024_int64
      high_count = huge(0_int64) - 512_int64
      expected_avg = real(huge(0_int64) - 2047_int64, wp)
      if (rank == 0) then
         local_count = low_count
      else
         local_count = high_count
      end if

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call timer%start("wide-count", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp + real(rank, wp)
      call timer%stop("wide-count", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_hot = timer%lookup("wide-count", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_test_set_call_count(timer, id_hot, 1, local_count, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(1, summary%num_entries)
      min_count_matches = summary%entries(1)%min_call_count == low_count
      max_count_matches = summary%entries(1)%max_call_count == high_count
      avg_count_matches = real_rel_close(summary%entries(1)%avg_call_count, expected_avg)
      avg_count_positive = summary%entries(1)%avg_call_count > 0.0_wp
      avg_count_not_above_max = fixed_decimal_real_not_above_int64(summary%entries(1)%avg_call_count, high_count)
      @assertTrue(min_count_matches)
      @assertTrue(max_count_matches)
      @assertTrue(avg_count_matches)
      @assertTrue(avg_count_positive)
      @assertTrue(avg_count_not_above_max)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_reduces_int64_call_extrema

   @test
   subroutine test_mpi_summary_bounds_avg_call_count_at_int64_limit(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: id_hot
      integer :: ierr
      integer(int64) :: boundary_count
      logical :: avg_count_matches
      logical :: avg_count_not_above_max
      logical :: max_count_matches
      logical :: min_count_matches
      real(wp) :: expected_avg

      boundary_count = huge(0_int64)
      expected_avg = real(huge(0_int64) - 1023_int64, wp)

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call timer%start("wide-count-boundary", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp
      call timer%stop("wide-count-boundary", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_hot = timer%lookup("wide-count-boundary", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_test_set_call_count(timer, id_hot, 1, boundary_count, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(1, summary%num_entries)
      min_count_matches = summary%entries(1)%min_call_count == boundary_count
      max_count_matches = summary%entries(1)%max_call_count == boundary_count
      avg_count_matches = real_rel_close(summary%entries(1)%avg_call_count, expected_avg)
      avg_count_not_above_max = fixed_decimal_real_not_above_int64(summary%entries(1)%avg_call_count, &
                                                                   boundary_count)
      @assertTrue(min_count_matches)
      @assertTrue(max_count_matches)
      @assertTrue(avg_count_matches)
      @assertTrue(avg_count_not_above_max)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_bounds_avg_call_count_at_int64_limit

   @test
   subroutine test_mpi_union_summary_preserves_sparse_int64_call_count(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: summary
      integer :: id_hot
      integer :: ierr
      integer :: rank
      integer(int64) :: big_count
      logical :: max_count_matches
      logical :: min_count_matches

      rank = this%getProcessRank()
      big_count = int(huge(0), int64) + 17_int64

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      if (rank == 0) then
         call timer%start("rank-zero-only", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) error stop 1
         fake_time = 3.0_wp
         call timer%stop("rank-zero-only", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) error stop 2

         id_hot = timer%lookup("rank-zero-only", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) error stop 3
         call ftimer_test_set_call_count(timer, id_hot, 1, big_count, ierr)
         if (ierr /= FTIMER_SUCCESS) error stop 4
      end if

      call timer%mpi_union_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(1, summary%num_entries)
      @assertEqual(1, summary%entries(1)%participating_rank_count)
      min_count_matches = summary%entries(1)%min_call_count == big_count
      max_count_matches = summary%entries(1)%max_call_count == big_count
      @assertTrue(min_count_matches)
      @assertTrue(max_count_matches)
      call assert_real_close(summary%entries(1)%avg_call_count, real(big_count, wp))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_preserves_sparse_int64_call_count

   @test
   subroutine test_mpi_union_summary_avoids_int64_avg_sum_overflow(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_union_summary_t) :: summary
      integer :: id_hot
      integer :: ierr
      integer :: rank
      integer(int64) :: high_count
      integer(int64) :: local_count
      integer(int64) :: low_count
      logical :: avg_count_matches
      logical :: avg_count_not_above_max
      logical :: avg_count_positive
      logical :: max_count_matches
      logical :: min_count_matches
      real(wp) :: expected_avg

      rank = this%getProcessRank()
      low_count = huge(0_int64) - 2048_int64
      high_count = huge(0_int64) - 1024_int64
      expected_avg = real(huge(0_int64) - 2047_int64, wp)
      if (rank == 0) then
         local_count = low_count
      else
         local_count = high_count
      end if

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call timer%start("union-wide-count", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 1.0_wp + real(rank, wp)
      call timer%stop("union-wide-count", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      id_hot = timer%lookup("union-wide-count", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_test_set_call_count(timer, id_hot, 1, local_count, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_union_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(1, summary%num_entries)
      @assertEqual(2, summary%entries(1)%participating_rank_count)
      min_count_matches = summary%entries(1)%min_call_count == low_count
      max_count_matches = summary%entries(1)%max_call_count == high_count
      avg_count_matches = real_rel_close(summary%entries(1)%avg_call_count, expected_avg)
      avg_count_positive = summary%entries(1)%avg_call_count > 0.0_wp
      avg_count_not_above_max = fixed_decimal_real_not_above_int64(summary%entries(1)%avg_call_count, high_count)
      @assertTrue(min_count_matches)
      @assertTrue(max_count_matches)
      @assertTrue(avg_count_matches)
      @assertTrue(avg_count_positive)
      @assertTrue(avg_count_not_above_max)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_summary_avoids_int64_avg_sum_overflow

