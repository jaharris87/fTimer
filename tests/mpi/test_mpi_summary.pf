   subroutine build_reordered_nested_timers(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (rank == 0) then
         fake_time = 1.0_wp
         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 3.0_wp
         call timer%stop("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 4.0_wp
         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 5.0_wp
         call timer%start("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 6.0_wp
         call timer%stop("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 8.0_wp
         call timer%stop("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 10.0_wp
         call timer%stop("outer", ierr=ierr)
      else
         fake_time = 1.0_wp
         call timer%start("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 2.0_wp
         call timer%start("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 4.0_wp
         call timer%stop("inner", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 5.0_wp
         call timer%stop("B", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 6.0_wp
         call timer%start("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return
         fake_time = 12.0_wp
         call timer%stop("A", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 13.0_wp
         call timer%stop("outer", ierr=ierr)
      end if
   end subroutine build_reordered_nested_timers

   subroutine delete_if_exists(path)
      character(len=*), intent(in) :: path
      integer :: io
      integer :: unit

      open (newunit=unit, file=path, status='old', iostat=io)
      if (io == 0) close (unit, status='delete')
   end subroutine delete_if_exists

   subroutine write_raw_text_without_newline(path, text)
      character(len=*), intent(in) :: path
      character(len=*), intent(in) :: text
      integer :: io
      integer :: unit

      open (newunit=unit, file=path, status='replace', access='stream', form='unformatted', &
            action='write', iostat=io)
      @assertEqual(0, io)
      write (unit, iostat=io) text
      @assertEqual(0, io)
      close (unit)
   end subroutine write_raw_text_without_newline

   subroutine assert_real_close(actual, expected)
      real(wp), intent(in) :: actual
      real(wp), intent(in) :: expected
      real(wp) :: diff

      diff = abs(actual - expected)
      @assertTrue(diff < 1.0e-12_wp)
   end subroutine assert_real_close

   logical function real_close(actual, expected) result(matches)
      real(wp), intent(in) :: actual
      real(wp), intent(in) :: expected

      matches = abs(actual - expected) < 1.0e-12_wp
   end function real_close

   logical function real_rel_close(actual, expected) result(matches)
      real(wp), intent(in) :: actual
      real(wp), intent(in) :: expected
      real(wp) :: diff
      real(wp) :: tolerance

      diff = abs(actual - expected)
      tolerance = max(1.0e-12_wp, abs(expected)*1.0e-12_wp)
      matches = diff < tolerance
   end function real_rel_close

   logical function fixed_decimal_real_not_above_int64(value, limit) result(matches)
      real(wp), intent(in) :: value
      integer(int64), intent(in) :: limit
      character(len=96) :: value_text

      write (value_text, '(f0.3)') value
      matches = decimal_field_not_above_int64(value_text, limit)
   end function fixed_decimal_real_not_above_int64

   logical function csv_decimal_field_not_above_int64(line, column, limit) result(matches)
      character(len=*), intent(in) :: line
      integer, intent(in) :: column
      integer(int64), intent(in) :: limit
      character(len=:), allocatable :: field_text

      field_text = csv_field_value(line, column)
      matches = decimal_field_not_above_int64(field_text, limit)
   end function csv_decimal_field_not_above_int64

   logical function decimal_field_not_above_int64(field_text, limit) result(matches)
      character(len=*), intent(in) :: field_text
      integer(int64), intent(in) :: limit
      character(len=32) :: limit_text
      character(len=:), allocatable :: integer_part
      integer :: decimal_pos

      decimal_pos = index(field_text, '.')
      if (decimal_pos > 1) then
         integer_part = field_text(1:decimal_pos - 1)
      else
         integer_part = trim(field_text)
      end if

      write (limit_text, '(i0)') limit
      if (.not. decimal_integer_text_is_digits(trim(integer_part))) then
         matches = .false.
         return
      end if
      matches = decimal_integer_text_leq(trim(integer_part), trim(limit_text))
   end function decimal_field_not_above_int64

   logical function decimal_integer_text_is_digits(text) result(matches)
      character(len=*), intent(in) :: text
      integer :: i
      integer :: text_len

      text_len = len_trim(text)
      matches = text_len > 0
      do i = 1, text_len
         if ((text(i:i) < '0') .or. (text(i:i) > '9')) then
            matches = .false.
            return
         end if
      end do
   end function decimal_integer_text_is_digits

   logical function decimal_integer_text_leq(lhs, rhs) result(matches)
      character(len=*), intent(in) :: lhs
      character(len=*), intent(in) :: rhs
      integer :: lhs_len
      integer :: rhs_len

      lhs_len = len_trim(lhs)
      rhs_len = len_trim(rhs)
      if (lhs_len <= 0) then
         matches = .false.
      else if (lhs_len < rhs_len) then
         matches = .true.
      else if (lhs_len > rhs_len) then
         matches = .false.
      else
         matches = lhs(1:lhs_len) <= rhs(1:rhs_len)
      end if
   end function decimal_integer_text_leq

   logical function mpi_report_row_values(text, timer_name, min_incl, min_rank, avg_incl, max_incl, max_rank, &
                                          imbalance, avg_self, avg_calls, avg_pct) result(found)
      character(len=*), intent(in) :: text
      character(len=*), intent(in) :: timer_name
      real(wp), intent(out) :: min_incl
      integer, intent(out) :: min_rank
      real(wp), intent(out) :: avg_incl
      real(wp), intent(out) :: max_incl
      integer, intent(out) :: max_rank
      real(wp), intent(out) :: imbalance
      real(wp), intent(out) :: avg_self
      real(wp), intent(out) :: avg_calls
      real(wp), intent(out) :: avg_pct
      character(len=:), allocatable :: line
      character(len=128) :: row_name
      integer :: io
      integer :: line_end
      integer :: line_start
      integer :: next_newline

      found = .false.
      min_incl = -1.0_wp
      min_rank = -1
      avg_incl = -1.0_wp
      max_incl = -1.0_wp
      max_rank = -1
      imbalance = -1.0_wp
      avg_self = -1.0_wp
      avg_calls = -1.0_wp
      avg_pct = -1.0_wp

      line_start = 1
      do while (line_start <= len(text))
         next_newline = index(text(line_start:), new_line('a'))
         if (next_newline <= 0) then
            line_end = len(text)
         else
            line_end = line_start + next_newline - 2
         end if

         if (line_end >= line_start) then
            line = text(line_start:line_end)
            if (index(line, trim(timer_name)) > 0) then
               row_name = ''
               read (line, *, iostat=io) row_name, min_incl, min_rank, avg_incl, max_incl, max_rank, &
                  imbalance, avg_self, avg_calls, avg_pct
               if ((io == 0) .and. (trim(row_name) == trim(timer_name))) then
                  found = .true.
                  return
               end if
            end if
         end if

         if (next_newline <= 0) exit
         line_start = line_end + 2
      end do
   end function mpi_report_row_values

   logical function union_report_row_values(text, timer_name, participating, missing, min_incl, min_rank, &
                                            avg_incl, max_incl, max_rank, imbalance, avg_self, avg_calls, avg_pct) &
      result(found)
      character(len=*), intent(in) :: text
      character(len=*), intent(in) :: timer_name
      integer, intent(out) :: participating
      integer, intent(out) :: missing
      real(wp), intent(out) :: min_incl
      integer, intent(out) :: min_rank
      real(wp), intent(out) :: avg_incl
      real(wp), intent(out) :: max_incl
      integer, intent(out) :: max_rank
      real(wp), intent(out) :: imbalance
      real(wp), intent(out) :: avg_self
      real(wp), intent(out) :: avg_calls
      real(wp), intent(out) :: avg_pct
      character(len=:), allocatable :: line
      character(len=128) :: row_name
      integer :: io
      integer :: line_end
      integer :: line_start
      integer :: next_newline

      found = .false.
      participating = -1
      missing = -1
      min_incl = -1.0_wp
      min_rank = -1
      avg_incl = -1.0_wp
      max_incl = -1.0_wp
      max_rank = -1
      imbalance = -1.0_wp
      avg_self = -1.0_wp
      avg_calls = -1.0_wp
      avg_pct = -1.0_wp

      line_start = 1
      do while (line_start <= len(text))
         next_newline = index(text(line_start:), new_line('a'))
         if (next_newline <= 0) then
            line_end = len(text)
         else
            line_end = line_start + next_newline - 2
         end if

         if (line_end >= line_start) then
            line = text(line_start:line_end)
            if (index(line, trim(timer_name)) > 0) then
               row_name = ''
               read (line, *, iostat=io) row_name, participating, missing, min_incl, min_rank, avg_incl, &
                  max_incl, max_rank, imbalance, avg_self, avg_calls, avg_pct
               if ((io == 0) .and. (trim(row_name) == trim(timer_name))) then
                  found = .true.
                  return
               end if
            end if
         end if

         if (next_newline <= 0) exit
         line_start = line_end + 2
      end do
   end function union_report_row_values

   logical function union_report_row_values_after_marker(text, marker, timer_name, participating, missing, min_incl, &
                                                         min_rank, avg_incl, max_incl, max_rank, imbalance, avg_self, &
                                                         avg_calls, avg_pct) result(found)
      character(len=*), intent(in) :: text
      character(len=*), intent(in) :: marker
      character(len=*), intent(in) :: timer_name
      integer, intent(out) :: participating
      integer, intent(out) :: missing
      real(wp), intent(out) :: min_incl
      integer, intent(out) :: min_rank
      real(wp), intent(out) :: avg_incl
      real(wp), intent(out) :: max_incl
      integer, intent(out) :: max_rank
      real(wp), intent(out) :: imbalance
      real(wp), intent(out) :: avg_self
      real(wp), intent(out) :: avg_calls
      real(wp), intent(out) :: avg_pct
      integer :: marker_pos
      integer :: search_start

      found = .false.
      participating = -1
      missing = -1
      min_incl = -1.0_wp
      min_rank = -1
      avg_incl = -1.0_wp
      max_incl = -1.0_wp
      max_rank = -1
      imbalance = -1.0_wp
      avg_self = -1.0_wp
      avg_calls = -1.0_wp
      avg_pct = -1.0_wp

      marker_pos = index(text, trim(marker))
      if (marker_pos <= 0) return

      search_start = marker_pos + len_trim(marker)
      if (search_start > len(text)) return

      found = union_report_row_values(text(search_start:), timer_name, participating, missing, min_incl, min_rank, &
                                      avg_incl, max_incl, max_rank, imbalance, avg_self, avg_calls, avg_pct)
   end function union_report_row_values_after_marker

   integer function count_union_report_rows(text, timer_name) result(count)
      character(len=*), intent(in) :: text
      character(len=*), intent(in) :: timer_name
      character(len=:), allocatable :: line
      character(len=128) :: row_name
      integer :: io
      integer :: line_end
      integer :: line_start
      integer :: next_newline

      count = 0
      line_start = 1
      do while (line_start <= len(text))
         next_newline = index(text(line_start:), new_line('a'))
         if (next_newline <= 0) then
            line_end = len(text)
         else
            line_end = line_start + next_newline - 2
         end if

         if (line_end >= line_start) then
            line = text(line_start:line_end)
            row_name = ''
            read (line, *, iostat=io) row_name
            if ((io == 0) .and. (trim(row_name) == trim(timer_name))) count = count + 1
         end if

         if (next_newline <= 0) exit
         line_start = line_end + 2
      end do
   end function count_union_report_rows

   integer function count_lines_with_prefix(text, prefix) result(count)
      character(len=*), intent(in) :: text
      character(len=*), intent(in) :: prefix
      character(len=:), allocatable :: line
      integer :: line_end
      integer :: line_start
      integer :: next_newline

      count = 0
      line_start = 1
      do while (line_start <= len(text))
         next_newline = index(text(line_start:), new_line('a'))
         if (next_newline <= 0) then
            line_end = len(text)
         else
            line_end = line_start + next_newline - 2
         end if

         if (line_end >= line_start) then
            line = text(line_start:line_end)
            if (len(line) >= len(prefix)) then
               if (line(1:len(prefix)) == prefix) count = count + 1
            end if
         end if

         if (next_newline <= 0) exit
         line_start = line_end + 2
      end do
   end function count_lines_with_prefix

   logical function same_name_tree_rows_are_ordered(text) result(matches)
      character(len=*), intent(in) :: text
      character(len=1) :: nl
      integer :: first_work_pos
      integer :: parent_a_pos
      integer :: parent_b_pos
      integer :: second_work_pos
      integer :: search_start

      matches = .false.
      nl = new_line('a')

      parent_a_pos = index(text, nl//'parent_a')
      if (parent_a_pos <= 0) return

      search_start = parent_a_pos + 1
      first_work_pos = index(text(search_start:), nl//'  work')
      if (first_work_pos <= 0) return

      search_start = search_start + first_work_pos
      parent_b_pos = index(text(search_start:), nl//'parent_b')
      if (parent_b_pos <= 0) return

      search_start = search_start + parent_b_pos
      second_work_pos = index(text(search_start:), nl//'  work')
      matches = second_work_pos > 0
   end function same_name_tree_rows_are_ordered

   logical function csv_text_field_equals(line, column, expected) result(matches)
      character(len=*), intent(in) :: line
      integer, intent(in) :: column
      character(len=*), intent(in) :: expected
      character(len=:), allocatable :: actual

      actual = csv_field_value(line, column)
      matches = actual == expected
   end function csv_text_field_equals

   logical function csv_real_field_close(line, column, expected) result(matches)
      character(len=*), intent(in) :: line
      integer, intent(in) :: column
      real(wp), intent(in) :: expected
      character(len=:), allocatable :: field_text
      integer :: io
      real(wp) :: actual

      matches = .false.
      field_text = csv_field_value(line, column)
      if (len_trim(field_text) <= 0) return

      read (field_text, *, iostat=io) actual
      if (io /= 0) return

      matches = abs(actual - expected) < 1.0e-12_wp
   end function csv_real_field_close

   integer function count_csv_header_records(text, header) result(count)
      character(len=*), intent(in) :: text
      character(len=*), intent(in) :: header
      character(len=:), allocatable :: line
      integer :: i

      count = 0
      do i = 1, csv_record_count(text)
         line = csv_line_at(text, i)
         if (line == header) count = count + 1
      end do
   end function count_csv_header_records

   subroutine assert_summary_equal(lhs, rhs)
      type(ftimer_mpi_summary_t), intent(in) :: lhs
      type(ftimer_mpi_summary_t), intent(in) :: rhs
      integer :: i
      integer :: lhs_parent_idx
      integer :: rhs_parent_idx

      @assertEqual(rhs%num_ranks, lhs%num_ranks)
      @assertEqual(rhs%num_entries, lhs%num_entries)
      call assert_real_close(lhs%min_total_time, rhs%min_total_time)
      call assert_real_close(lhs%avg_total_time, rhs%avg_total_time)
      call assert_real_close(lhs%max_total_time, rhs%max_total_time)
      @assertEqual(rhs%min_total_time_rank, lhs%min_total_time_rank)
      @assertEqual(rhs%max_total_time_rank, lhs%max_total_time_rank)
      call assert_real_close(lhs%total_time_imbalance, rhs%total_time_imbalance)
      @assertTrue(summary_node_ids_unique(lhs))
      @assertTrue(summary_node_ids_unique(rhs))

      do i = 1, lhs%num_entries
         @assertEqual(trim(rhs%entries(i)%name), trim(lhs%entries(i)%name))
         @assertEqual(rhs%entries(i)%depth, lhs%entries(i)%depth)
         lhs_parent_idx = summary_parent_index(lhs, i)
         rhs_parent_idx = summary_parent_index(rhs, i)
         @assertEqual(rhs_parent_idx, lhs_parent_idx)
         call assert_real_close(lhs%entries(i)%min_inclusive_time, rhs%entries(i)%min_inclusive_time)
         call assert_real_close(lhs%entries(i)%avg_inclusive_time, rhs%entries(i)%avg_inclusive_time)
         call assert_real_close(lhs%entries(i)%max_inclusive_time, rhs%entries(i)%max_inclusive_time)
         @assertEqual(rhs%entries(i)%min_inclusive_time_rank, lhs%entries(i)%min_inclusive_time_rank)
         @assertEqual(rhs%entries(i)%max_inclusive_time_rank, lhs%entries(i)%max_inclusive_time_rank)
         call assert_real_close(lhs%entries(i)%inclusive_imbalance, rhs%entries(i)%inclusive_imbalance)
         call assert_real_close(lhs%entries(i)%min_self_time, rhs%entries(i)%min_self_time)
         call assert_real_close(lhs%entries(i)%max_self_time, rhs%entries(i)%max_self_time)
         call assert_real_close(lhs%entries(i)%avg_self_time, rhs%entries(i)%avg_self_time)
         call assert_real_close(lhs%entries(i)%self_imbalance, rhs%entries(i)%self_imbalance)
         @assertEqual(rhs%entries(i)%min_call_count, lhs%entries(i)%min_call_count)
         @assertEqual(rhs%entries(i)%max_call_count, lhs%entries(i)%max_call_count)
         call assert_real_close(lhs%entries(i)%avg_call_count, rhs%entries(i)%avg_call_count)
         call assert_real_close(lhs%entries(i)%min_pct_time, rhs%entries(i)%min_pct_time)
         call assert_real_close(lhs%entries(i)%max_pct_time, rhs%entries(i)%max_pct_time)
         call assert_real_close(lhs%entries(i)%avg_pct_time, rhs%entries(i)%avg_pct_time)
      end do
   end subroutine assert_summary_equal

   subroutine assert_union_summary_matches_strict(union_summary, strict_summary)
      type(ftimer_mpi_union_summary_t), intent(in) :: union_summary
      type(ftimer_mpi_summary_t), intent(in) :: strict_summary
      integer :: i
      integer :: strict_rank
      integer :: union_rank

      @assertEqual(strict_summary%num_ranks, union_summary%num_ranks)
      @assertEqual(strict_summary%num_entries, union_summary%num_entries)
      call assert_real_close(union_summary%min_total_time, strict_summary%min_total_time)
      call assert_real_close(union_summary%avg_total_time, strict_summary%avg_total_time)
      call assert_real_close(union_summary%max_total_time, strict_summary%max_total_time)
      @assertEqual(strict_summary%min_total_time_rank, union_summary%min_total_time_rank)
      @assertEqual(strict_summary%max_total_time_rank, union_summary%max_total_time_rank)
      call assert_real_close(union_summary%total_time_imbalance, strict_summary%total_time_imbalance)

      do i = 1, union_summary%num_entries
         @assertEqual(trim(strict_summary%entries(i)%name), trim(union_summary%entries(i)%name))
         @assertEqual(strict_summary%entries(i)%depth, union_summary%entries(i)%depth)
         @assertEqual(strict_summary%entries(i)%node_id, union_summary%entries(i)%node_id)
         @assertEqual(strict_summary%entries(i)%parent_id, union_summary%entries(i)%parent_id)
         @assertEqual(strict_summary%num_ranks, union_summary%entries(i)%participating_rank_count)
         call assert_real_close(union_summary%entries(i)%min_inclusive_time, &
                                strict_summary%entries(i)%min_inclusive_time)
         call assert_real_close(union_summary%entries(i)%avg_inclusive_time, &
                                strict_summary%entries(i)%avg_inclusive_time)
         call assert_real_close(union_summary%entries(i)%max_inclusive_time, &
                                strict_summary%entries(i)%max_inclusive_time)
         strict_rank = strict_summary%entries(i)%min_inclusive_time_rank
         union_rank = union_summary%entries(i)%min_inclusive_time_rank
         @assertEqual(strict_rank, union_rank)
         strict_rank = strict_summary%entries(i)%max_inclusive_time_rank
         union_rank = union_summary%entries(i)%max_inclusive_time_rank
         @assertEqual(strict_rank, union_rank)
         call assert_real_close(union_summary%entries(i)%inclusive_imbalance, &
                                strict_summary%entries(i)%inclusive_imbalance)
         call assert_real_close(union_summary%entries(i)%min_self_time, strict_summary%entries(i)%min_self_time)
         call assert_real_close(union_summary%entries(i)%avg_self_time, strict_summary%entries(i)%avg_self_time)
         call assert_real_close(union_summary%entries(i)%max_self_time, strict_summary%entries(i)%max_self_time)
         call assert_real_close(union_summary%entries(i)%self_imbalance, strict_summary%entries(i)%self_imbalance)
         @assertEqual(strict_summary%entries(i)%min_call_count, union_summary%entries(i)%min_call_count)
         @assertEqual(strict_summary%entries(i)%max_call_count, union_summary%entries(i)%max_call_count)
         call assert_real_close(union_summary%entries(i)%avg_call_count, strict_summary%entries(i)%avg_call_count)
         call assert_real_close(union_summary%entries(i)%min_pct_time, strict_summary%entries(i)%min_pct_time)
         call assert_real_close(union_summary%entries(i)%avg_pct_time, strict_summary%entries(i)%avg_pct_time)
         call assert_real_close(union_summary%entries(i)%max_pct_time, strict_summary%entries(i)%max_pct_time)
      end do
   end subroutine assert_union_summary_matches_strict

   integer function union_entry_index(summary, name) result(idx)
      type(ftimer_mpi_union_summary_t), intent(in) :: summary
      character(len=*), intent(in) :: name
      integer :: i

      idx = 0
      do i = 1, summary%num_entries
         if (trim(summary%entries(i)%name) == name) then
            idx = i
            return
         end if
      end do
   end function union_entry_index

   subroutine assert_union_summary_empty(summary)
      type(ftimer_mpi_union_summary_t), intent(in) :: summary
      logical :: entries_allocated

      entries_allocated = allocated(summary%entries)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)
      @assertEqual(0.0_wp, summary%min_total_time)
      @assertEqual(0.0_wp, summary%max_total_time)
      @assertEqual(0.0_wp, summary%avg_total_time)
      @assertEqual(-1, summary%min_total_time_rank)
      @assertEqual(-1, summary%max_total_time_rank)
      @assertEqual(1.0_wp, summary%total_time_imbalance)
      @assertFalse(entries_allocated)
   end subroutine assert_union_summary_empty

end module test_mpi_summary
