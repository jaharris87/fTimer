module test_mpi_summary
   use pfunit
   use mpi
   use ftimer, only: ftimer_default_instance, ftimer_finalize, ftimer_init, ftimer_mpi_summary, &
                     ftimer_print_mpi_summary, ftimer_start, ftimer_stop
   use ftimer_core, only: ftimer_t
   use ftimer_types, only: FTIMER_ERR_ACTIVE, FTIMER_ERR_IO, FTIMER_NAME_LEN, FTIMER_SUCCESS, ftimer_metadata_t, &
                           ftimer_mpi_summary_t, wp
   use test_support, only: attach_mock_clock, csv_column_index, csv_field_value, csv_line_at, csv_record_count, &
                           fake_time, read_file_text, summary_node_ids_unique, summary_parent_index
   implicit none

   @testcase(npes=[2])
   type, extends(MpiTestCase) :: mpi_summary_case
   end type mpi_summary_case

contains

   @test
   subroutine test_mpi_summary_reduces_nested_timer_statistics_on_all_ranks(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr
      integer :: nprocs

      nprocs = this%getNumProcesses()
      @assertEqual(2, nprocs)

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, summary%num_ranks)
      @assertEqual(2, summary%num_entries)
      @assertTrue(summary_node_ids_unique(summary))
      @assertEqual(0, summary_parent_index(summary, 1))
      @assertEqual(1, summary_parent_index(summary, 2))
      @assertEqual('outer', trim(summary%entries(1)%name))
      @assertEqual('inner', trim(summary%entries(2)%name))
      call assert_real_close(summary%min_total_time, 10.0_wp)
      call assert_real_close(summary%avg_total_time, 12.0_wp)
      call assert_real_close(summary%max_total_time, 14.0_wp)
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(1, summary%max_total_time_rank)
      call assert_real_close(summary%total_time_imbalance, 14.0_wp/12.0_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 10.0_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 12.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 14.0_wp)
      @assertEqual(0, summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(1, summary%entries(1)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(1)%inclusive_imbalance, 14.0_wp/12.0_wp)
      call assert_real_close(summary%entries(1)%min_self_time, 6.0_wp)
      call assert_real_close(summary%entries(1)%max_self_time, 8.0_wp)
      call assert_real_close(summary%entries(1)%avg_self_time, 7.0_wp)
      call assert_real_close(summary%entries(1)%self_imbalance, 8.0_wp/7.0_wp)
      call assert_real_close(summary%entries(1)%avg_call_count, 1.0_wp)
      call assert_real_close(summary%entries(1)%avg_pct_time, 100.0_wp)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 5.0_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 6.0_wp)
      @assertEqual(0, summary%entries(2)%min_inclusive_time_rank)
      @assertEqual(1, summary%entries(2)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(2)%inclusive_imbalance, 6.0_wp/5.0_wp)
      call assert_real_close(summary%entries(2)%min_pct_time, 40.0_wp)
      call assert_real_close(summary%entries(2)%max_pct_time, 100.0_wp*6.0_wp/14.0_wp)
      call assert_real_close(summary%entries(2)%avg_pct_time, 0.5_wp*(40.0_wp + 100.0_wp*6.0_wp/14.0_wp))
      call assert_real_close(summary%entries(2)%min_self_time, 4.0_wp)
      call assert_real_close(summary%entries(2)%max_self_time, 6.0_wp)
      call assert_real_close(summary%entries(2)%avg_self_time, 5.0_wp)
      call assert_real_close(summary%entries(2)%self_imbalance, 6.0_wp/5.0_wp)
      call assert_real_close(summary%entries(2)%avg_call_count, 1.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_reduces_nested_timer_statistics_on_all_ranks

   @test
   subroutine test_mpi_summary_prefers_lowest_rank_when_extrema_tie(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_tied_nested_timers(timer, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_real_close(summary%min_total_time, 8.0_wp)
      call assert_real_close(summary%max_total_time, 8.0_wp)
      @assertEqual(0, summary%min_total_time_rank)
      @assertEqual(0, summary%max_total_time_rank)
      @assertEqual(2, summary%num_entries)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 8.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 8.0_wp)
      @assertEqual(0, summary%entries(1)%min_inclusive_time_rank)
      @assertEqual(0, summary%entries(1)%max_inclusive_time_rank)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 3.0_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 3.0_wp)
      @assertEqual(0, summary%entries(2)%min_inclusive_time_rank)
      @assertEqual(0, summary%entries(2)%max_inclusive_time_rank)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_prefers_lowest_rank_when_extrema_tie

   @test
   subroutine test_mpi_summary_preserves_large_time_precision(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_large_timestamp_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_real_close(summary%min_total_time, 2.5_wp)
      call assert_real_close(summary%avg_total_time, 3.0_wp)
      call assert_real_close(summary%max_total_time, 3.5_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 2.5_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 3.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 3.5_wp)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 0.5_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 0.625_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 0.75_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_preserves_large_time_precision

   @test
   subroutine test_mpi_summary_reduces_call_extrema(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_repeated_timer(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(1, summary%num_entries)
      @assertEqual('repeat', trim(summary%entries(1)%name))
      call assert_real_close(summary%min_total_time, 2.0_wp)
      call assert_real_close(summary%avg_total_time, 4.0_wp)
      call assert_real_close(summary%max_total_time, 6.0_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 2.0_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 6.0_wp)
      call assert_real_close(summary%entries(1)%inclusive_imbalance, 1.5_wp)
      @assertEqual(1, summary%entries(1)%min_call_count)
      @assertEqual(3, summary%entries(1)%max_call_count)
      call assert_real_close(summary%entries(1)%avg_call_count, 2.0_wp)
      call assert_real_close(summary%entries(1)%avg_pct_time, 100.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_reduces_call_extrema

   @test
   subroutine test_mpi_summary_uses_canonical_order_for_consistent_timer_sets(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_reordered_top_level_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(2, summary%num_entries)
      @assertEqual('A', trim(summary%entries(1)%name))
      @assertEqual('B', trim(summary%entries(2)%name))
      call assert_real_close(summary%min_total_time, 12.0_wp)
      call assert_real_close(summary%avg_total_time, 14.0_wp)
      call assert_real_close(summary%max_total_time, 16.0_wp)
      call assert_real_close(summary%entries(1)%min_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(1)%avg_inclusive_time, 7.0_wp)
      call assert_real_close(summary%entries(1)%max_inclusive_time, 10.0_wp)
      call assert_real_close(summary%entries(2)%min_inclusive_time, 6.0_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 7.0_wp)
      call assert_real_close(summary%entries(2)%max_inclusive_time, 8.0_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_uses_canonical_order_for_consistent_timer_sets

   @test
   subroutine test_mpi_summary_preserves_long_timer_names(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      character(len=:), allocatable :: printed
      character(len=*), parameter :: print_path = 'test_mpi_long_name_print_summary.txt'
      character(len=FTIMER_NAME_LEN + 32) :: root_name
      character(len=FTIMER_NAME_LEN + 48) :: child_name
      integer :: child_len
      integer :: expected_child_len
      integer :: expected_root_len
      integer :: flags(2)
      integer :: ierr
      integer :: rank
      integer :: root_len
      integer :: unit
      logical :: child_name_matches
      logical :: root_name_matches

      rank = this%getProcessRank()
      root_name = repeat('r', len(root_name))
      child_name = repeat('c', len(child_name))
      expected_root_len = len(root_name)
      expected_child_len = len(child_name)

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_long_named_timers(timer, this%getProcessRank(), root_name, child_name, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      if (ierr /= FTIMER_SUCCESS) return

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      root_len = len_trim(summary%entries(1)%name)
      child_len = len_trim(summary%entries(2)%name)
      root_name_matches = trim(summary%entries(1)%name) == root_name
      child_name_matches = trim(summary%entries(2)%name) == child_name

      @assertEqual(expected_root_len, root_len)
      @assertEqual(expected_child_len, child_len)
      @assertTrue(root_name_matches)
      @assertTrue(child_name_matches)
      @assertEqual(0, summary_parent_index(summary, 1))
      @assertEqual(1, summary_parent_index(summary, 2))

      flags = 0
      if (rank == 0) then
         call delete_if_exists(print_path)
         open (newunit=unit, file=print_path, status='replace', action='write', iostat=ierr)
         @assertEqual(0, ierr)
         call timer%print_mpi_summary(unit=unit, ierr=ierr)
         close (unit)
      else
         call timer%print_mpi_summary(ierr=ierr)
      end if
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      if (rank == 0) then
         printed = read_file_text(print_path)
         if (index(printed, root_name) > 0) flags(1) = 1
         if (index(printed, child_name) > 0) flags(2) = 1
      end if
      call MPI_Bcast(flags, size(flags), MPI_INTEGER, 0, MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_preserves_long_timer_names

   @test
   subroutine test_mpi_summary_handles_nested_reordered_sets(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_reordered_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      @assertEqual(4, summary%num_entries)
      @assertEqual('outer', trim(summary%entries(1)%name))
      @assertEqual('A', trim(summary%entries(2)%name))
      @assertEqual('B', trim(summary%entries(3)%name))
      @assertEqual('inner', trim(summary%entries(4)%name))
      @assertEqual(0, summary_parent_index(summary, 1))
      @assertEqual(1, summary_parent_index(summary, 2))
      @assertEqual(1, summary_parent_index(summary, 3))
      @assertEqual(3, summary_parent_index(summary, 4))
      call assert_real_close(summary%min_total_time, 10.0_wp)
      call assert_real_close(summary%avg_total_time, 11.5_wp)
      call assert_real_close(summary%max_total_time, 13.0_wp)
      call assert_real_close(summary%entries(2)%avg_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(3)%avg_inclusive_time, 4.0_wp)
      call assert_real_close(summary%entries(4)%avg_inclusive_time, 1.5_wp)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_handles_nested_reordered_sets

   @test
   subroutine test_mpi_summary_rejects_active_timers_without_global_result(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      fake_time = 0.0_wp
      call timer%start("active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 3.0_wp + 2.0_wp*real(this%getProcessRank(), wp)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_ACTIVE, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      fake_time = fake_time + 1.0_wp
      call timer%stop("active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_rejects_active_timers_without_global_result

   @test
   subroutine test_procedural_mpi_summary_matches_oop_api(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: oop_timer
      type(ftimer_mpi_summary_t) :: oop_summary
      type(ftimer_mpi_summary_t) :: procedural_summary
      integer :: ierr

      call oop_timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(oop_timer)

      call ftimer_init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(ftimer_default_instance)

      call build_nested_timers(oop_timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call build_nested_timers_procedural(this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call oop_timer%mpi_summary(oop_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_mpi_summary(procedural_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call assert_summary_equal(procedural_summary, oop_summary)

      call oop_timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call ftimer_finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_procedural_mpi_summary_matches_oop_api

   @test
   subroutine test_mpi_print_summary_emits_global_report(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_metadata_t) :: metadata(3)
      character(len=:), allocatable :: printed
      character(len=*), parameter :: expected_header = &
                                     'Timer name  Min Incl (s)  Min Rank  Avg Incl (s)  Max Incl (s)  Max Rank'// &
                                     '   Imb.  Avg Self (s)    Avg Calls    Avg %'
      character(len=*), parameter :: expected_inner_row = &
                                     '  inner         4.000000         0      5.000000      6.000000'// &
                                     '         1   1.200      5.000000       1.000     41.43'
      character(len=*), parameter :: wrong_ratio_inner_row = &
                                     '  inner         4.000000         0      5.000000      6.000000'// &
                                     '         1   1.200      5.000000       1.000     41.67'
      character(len=*), parameter :: print_path = 'test_mpi_print_summary.txt'
      integer :: flags(15)
      integer :: ierr
      integer :: rank
      integer :: unit

      rank = this%getProcessRank()

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      metadata(1)%key = 'Job'
      metadata(1)%value = 'mpi-report'
      metadata(2)%value = 'orphan-mpi'
      metadata(3)%key = 'BlankValue'

      call build_nested_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) then
         call delete_if_exists(print_path)
         open (newunit=unit, file=print_path, status='replace', action='write', iostat=ierr)
         @assertEqual(0, ierr)
         call timer%print_mpi_summary(unit=unit, metadata=metadata, ierr=ierr)
         close (unit)
      else
         call timer%print_mpi_summary(metadata=metadata, ierr=ierr)
      end if
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      flags = 0
      if (rank == 0) then
         printed = read_file_text(print_path)
         if (index(printed, 'MPI ranks') > 0) flags(1) = 1
         if (index(printed, 'Avg Incl (s)') > 0) flags(2) = 1
         if (index(printed, 'mpi-report') > 0) flags(3) = 1
         if (index(printed, 'Avg %') > 0) flags(4) = 1
         if (index(printed, 'Min total rank') > 0) flags(5) = 1
         if (index(printed, 'Max total rank') > 0) flags(6) = 1
         if (index(printed, 'Min Rank') > 0) flags(7) = 1
         if (index(printed, 'abbreviated view of ftimer_mpi_summary_t') > 0) flags(8) = 1
         if (index(printed, 'Avg % is the arithmetic mean of rank-local % Total values') > 0) flags(9) = 1
         if (index(printed, 'not 100*Avg Incl/Avg total time') > 0) flags(10) = 1
         if (index(printed, expected_header) > 0) flags(11) = 1
         if (index(printed, expected_inner_row) > 0) flags(12) = 1
         if (index(printed, wrong_ratio_inner_row) == 0) flags(13) = 1
         if (index(printed, 'BlankValue') > 0) flags(14) = 1
         if (index(printed, 'orphan-mpi') == 0) flags(15) = 1
      end if
      call MPI_Bcast(flags, size(flags), MPI_INTEGER, 0, MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))
      @assertEqual(1, flags(9))
      @assertEqual(1, flags(10))
      @assertEqual(1, flags(11))
      @assertEqual(1, flags(12))
      @assertEqual(1, flags(13))
      @assertEqual(1, flags(14))
      @assertEqual(1, flags(15))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_print_summary_emits_global_report

   @test
   subroutine test_mpi_write_summary_csv_emits_parseable_global_records(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_metadata_t) :: metadata(1)
      character(len=:), allocatable :: csv_text
      character(len=:), allocatable :: field_text
      character(len=:), allocatable :: header
      character(len=:), allocatable :: inner_line
      character(len=:), allocatable :: metadata_line
      character(len=:), allocatable :: outer_line
      character(len=:), allocatable :: summary_line
      character(len=*), parameter :: csv_path = 'test_mpi_summary_export.csv'
      integer :: avg_inclusive_col
      integer :: avg_pct_col
      integer :: avg_self_col
      integer :: avg_total_col
      integer :: avg_call_count_col
      integer :: flags(43)
      integer :: ierr
      integer :: inclusive_imbalance_col
      integer :: max_inclusive_col
      integer :: max_pct_col
      integer :: max_rank_col
      integer :: max_self_col
      integer :: max_call_count_col
      integer :: min_inclusive_col
      integer :: min_pct_col
      integer :: min_rank_col
      integer :: min_self_col
      integer :: min_call_count_col
      integer :: min_total_col
      integer :: min_total_rank_col
      integer :: name_col
      integer :: node_col
      integer :: num_entries_col
      integer :: num_ranks_col
      integer :: max_total_col
      integer :: max_total_rank_col
      integer :: parent_col
      integer :: rank
      integer :: record_type_col
      integer :: self_imbalance_col
      integer :: summary_kind_col
      integer :: total_imbalance_col
      integer :: unit
      integer :: io

      rank = this%getProcessRank()
      flags = 0

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      metadata(1)%key = 'Job'
      metadata(1)%value = 'mpi, "csv"'

      if (rank == 0) call delete_if_exists(csv_path)
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, metadata=metadata, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      if (rank == 0) then
         csv_text = read_file_text(csv_path)
         if (csv_record_count(csv_text) == 5) flags(1) = 1

         header = csv_line_at(csv_text, 1)
         summary_line = csv_line_at(csv_text, 2)
         metadata_line = csv_line_at(csv_text, 3)
         outer_line = csv_line_at(csv_text, 4)
         inner_line = csv_line_at(csv_text, 5)

         record_type_col = csv_column_index(header, 'record_type')
         summary_kind_col = csv_column_index(header, 'summary_kind')
         num_entries_col = csv_column_index(header, 'num_entries')
         num_ranks_col = csv_column_index(header, 'num_ranks')
         min_total_col = csv_column_index(header, 'min_total_time')
         avg_total_col = csv_column_index(header, 'avg_total_time')
         max_total_col = csv_column_index(header, 'max_total_time')
         min_total_rank_col = csv_column_index(header, 'min_total_time_rank')
         max_total_rank_col = csv_column_index(header, 'max_total_time_rank')
         total_imbalance_col = csv_column_index(header, 'total_time_imbalance')
         node_col = csv_column_index(header, 'node_id')
         parent_col = csv_column_index(header, 'parent_id')
         name_col = csv_column_index(header, 'name')
         min_inclusive_col = csv_column_index(header, 'min_inclusive_time')
         avg_inclusive_col = csv_column_index(header, 'avg_inclusive_time')
         max_inclusive_col = csv_column_index(header, 'max_inclusive_time')
         min_rank_col = csv_column_index(header, 'min_inclusive_time_rank')
         max_rank_col = csv_column_index(header, 'max_inclusive_time_rank')
         inclusive_imbalance_col = csv_column_index(header, 'inclusive_imbalance')
         min_self_col = csv_column_index(header, 'min_self_time')
         avg_self_col = csv_column_index(header, 'avg_self_time')
         max_self_col = csv_column_index(header, 'max_self_time')
         self_imbalance_col = csv_column_index(header, 'self_imbalance')
         min_call_count_col = csv_column_index(header, 'min_call_count')
         avg_call_count_col = csv_column_index(header, 'avg_call_count')
         max_call_count_col = csv_column_index(header, 'max_call_count')
         min_pct_col = csv_column_index(header, 'min_pct_time')
         avg_pct_col = csv_column_index(header, 'avg_pct_time')
         max_pct_col = csv_column_index(header, 'max_pct_time')

         if (record_type_col > 0) flags(2) = 1
         if (csv_text_field_equals(summary_line, summary_kind_col, 'mpi')) flags(3) = 1
         if (csv_text_field_equals(summary_line, record_type_col, 'summary')) flags(4) = 1
         if (csv_text_field_equals(summary_line, num_ranks_col, '2')) flags(5) = 1
         if (csv_text_field_equals(summary_line, num_entries_col, '2')) flags(6) = 1
         if (csv_real_field_close(summary_line, min_total_col, 10.0_wp)) flags(7) = 1
         if (csv_real_field_close(summary_line, avg_total_col, 12.0_wp)) flags(8) = 1
         if (csv_real_field_close(summary_line, max_total_col, 14.0_wp)) flags(9) = 1
         if (csv_text_field_equals(summary_line, min_total_rank_col, '0')) flags(10) = 1
         if (csv_text_field_equals(summary_line, max_total_rank_col, '1')) flags(11) = 1
         if (csv_real_field_close(summary_line, total_imbalance_col, 14.0_wp/12.0_wp)) flags(12) = 1

         field_text = csv_field_value(metadata_line, csv_column_index(header, 'value'))
         if (field_text == 'mpi, "csv"') flags(13) = 1

         if (csv_text_field_equals(outer_line, name_col, 'outer')) flags(14) = 1
         if (csv_text_field_equals(outer_line, node_col, '1')) flags(15) = 1
         if (csv_text_field_equals(outer_line, parent_col, '0')) flags(16) = 1
         if (csv_real_field_close(outer_line, min_inclusive_col, 10.0_wp)) flags(17) = 1
         if (csv_real_field_close(outer_line, avg_inclusive_col, 12.0_wp)) flags(18) = 1
         if (csv_real_field_close(outer_line, max_inclusive_col, 14.0_wp)) flags(19) = 1
         if (csv_real_field_close(outer_line, inclusive_imbalance_col, 14.0_wp/12.0_wp)) flags(20) = 1
         if (csv_real_field_close(outer_line, min_self_col, 6.0_wp)) flags(21) = 1
         if (csv_real_field_close(outer_line, avg_self_col, 7.0_wp)) flags(22) = 1
         if (csv_real_field_close(outer_line, max_self_col, 8.0_wp)) flags(23) = 1
         if (csv_real_field_close(outer_line, self_imbalance_col, 8.0_wp/7.0_wp)) flags(24) = 1
         if (csv_text_field_equals(outer_line, min_call_count_col, '1')) flags(25) = 1
         if (csv_real_field_close(outer_line, avg_call_count_col, 1.0_wp)) flags(26) = 1
         if (csv_text_field_equals(outer_line, max_call_count_col, '1')) flags(27) = 1
         if (csv_real_field_close(outer_line, min_pct_col, 100.0_wp)) flags(28) = 1
         if (csv_real_field_close(outer_line, avg_pct_col, 100.0_wp)) flags(29) = 1
         if (csv_real_field_close(outer_line, max_pct_col, 100.0_wp)) flags(30) = 1

         if (csv_text_field_equals(inner_line, parent_col, '1')) flags(31) = 1
         if (csv_text_field_equals(inner_line, min_rank_col, '0')) flags(32) = 1
         if (csv_text_field_equals(inner_line, max_rank_col, '1')) flags(33) = 1
         if (csv_real_field_close(inner_line, min_self_col, 4.0_wp)) flags(34) = 1
         if (csv_real_field_close(inner_line, avg_self_col, 5.0_wp)) flags(35) = 1
         if (csv_real_field_close(inner_line, max_self_col, 6.0_wp)) flags(36) = 1
         if (csv_real_field_close(inner_line, self_imbalance_col, 6.0_wp/5.0_wp)) flags(37) = 1
         if (csv_text_field_equals(inner_line, min_call_count_col, '1')) flags(38) = 1
         if (csv_real_field_close(inner_line, avg_call_count_col, 1.0_wp)) flags(39) = 1
         if (csv_text_field_equals(inner_line, max_call_count_col, '1')) flags(40) = 1
         if (csv_real_field_close(inner_line, min_pct_col, 40.0_wp)) flags(41) = 1
         if (csv_real_field_close(inner_line, avg_pct_col, 0.5_wp*(40.0_wp + 100.0_wp*6.0_wp/14.0_wp))) flags(42) = 1
         if (csv_real_field_close(inner_line, max_pct_col, 100.0_wp*6.0_wp/14.0_wp)) flags(43) = 1

         open (newunit=unit, file=csv_path, status='old', iostat=io)
         if (io == 0) close (unit, status='delete')
      end if

      call MPI_Bcast(flags, size(flags), MPI_INTEGER, 0, MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))
      @assertEqual(1, flags(9))
      @assertEqual(1, flags(10))
      @assertEqual(1, flags(11))
      @assertEqual(1, flags(12))
      @assertEqual(1, flags(13))
      @assertEqual(1, flags(14))
      @assertEqual(1, flags(15))
      @assertEqual(1, flags(16))
      @assertEqual(1, flags(17))
      @assertEqual(1, flags(18))
      @assertEqual(1, flags(19))
      @assertEqual(1, flags(20))
      @assertEqual(1, flags(21))
      @assertEqual(1, flags(22))
      @assertEqual(1, flags(23))
      @assertEqual(1, flags(24))
      @assertEqual(1, flags(25))
      @assertEqual(1, flags(26))
      @assertEqual(1, flags(27))
      @assertEqual(1, flags(28))
      @assertEqual(1, flags(29))
      @assertEqual(1, flags(30))
      @assertEqual(1, flags(31))
      @assertEqual(1, flags(32))
      @assertEqual(1, flags(33))
      @assertEqual(1, flags(34))
      @assertEqual(1, flags(35))
      @assertEqual(1, flags(36))
      @assertEqual(1, flags(37))
      @assertEqual(1, flags(38))
      @assertEqual(1, flags(39))
      @assertEqual(1, flags(40))
      @assertEqual(1, flags(41))
      @assertEqual(1, flags(42))
      @assertEqual(1, flags(43))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_csv_emits_parseable_global_records

   @test
   subroutine test_mpi_write_summary_csv_appends_without_duplicate_header(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: csv_text
      character(len=:), allocatable :: header
      character(len=*), parameter :: csv_path = 'test_mpi_summary_append_export.csv'
      integer :: flags(2)
      integer :: ierr
      integer :: rank

      rank = this%getProcessRank()
      flags = 0

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) call delete_if_exists(csv_path)
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%write_mpi_summary_csv(csv_path, append=.true., ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      if (rank == 0) then
         csv_text = read_file_text(csv_path)
         header = csv_line_at(csv_text, 1)
         if (csv_record_count(csv_text) == 7) flags(1) = 1
         if (count_csv_header_records(csv_text, header) == 1) flags(2) = 1
         call delete_if_exists(csv_path)
      end if

      call MPI_Bcast(flags, size(flags), MPI_INTEGER, 0, MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_csv_appends_without_duplicate_header

   @test
   subroutine test_mpi_write_summary_csv_rejects_unterminated_append_target(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: csv_text
      character(len=:), allocatable :: header
      character(len=*), parameter :: csv_path = 'test_mpi_summary_unterminated_append.csv'
      integer :: ierr
      integer :: max_err
      integer :: min_err
      integer :: mpierr
      integer :: rank

      rank = this%getProcessRank()

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) call delete_if_exists(csv_path)
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      if (rank == 0) then
         csv_text = read_file_text(csv_path)
         header = csv_line_at(csv_text, 1)
         call write_raw_text_without_newline(csv_path, header)
      end if
      call MPI_Barrier(MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      call timer%write_mpi_summary_csv(csv_path, append=.true., ierr=ierr)
      @assertEqual(FTIMER_ERR_IO, ierr)

      call MPI_Allreduce(ierr, min_err, 1, MPI_INTEGER, MPI_MIN, MPI_COMM_WORLD, mpierr)
      @assertEqual(MPI_SUCCESS, mpierr)
      call MPI_Allreduce(ierr, max_err, 1, MPI_INTEGER, MPI_MAX, MPI_COMM_WORLD, mpierr)
      @assertEqual(MPI_SUCCESS, mpierr)

      @assertEqual(FTIMER_ERR_IO, min_err)
      @assertEqual(FTIMER_ERR_IO, max_err)

      if (rank == 0) call delete_if_exists(csv_path)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_csv_rejects_unterminated_append_target

   @test
   subroutine test_mpi_write_summary_syncs_io_error(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      integer :: ierr
      integer :: max_err
      integer :: min_err
      integer :: mpierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_nested_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%write_mpi_summary('/no_such_dir/test_mpi_summary.txt', ierr=ierr)
      @assertEqual(FTIMER_ERR_IO, ierr)

      call MPI_Allreduce(ierr, min_err, 1, MPI_INTEGER, MPI_MIN, MPI_COMM_WORLD, mpierr)
      @assertEqual(MPI_SUCCESS, mpierr)
      call MPI_Allreduce(ierr, max_err, 1, MPI_INTEGER, MPI_MAX, MPI_COMM_WORLD, mpierr)
      @assertEqual(MPI_SUCCESS, mpierr)

      @assertEqual(FTIMER_ERR_IO, min_err)
      @assertEqual(FTIMER_ERR_IO, max_err)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_write_summary_syncs_io_error

