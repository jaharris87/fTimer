      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))
      @assertEqual(1, flags(7))
      @assertEqual(1, flags(8))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_print_summary_counts_zero_elapsed_present_timer

   @test
   subroutine test_mpi_union_write_summary_syncs_io_error(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      integer :: ierr
      integer :: max_err
      integer :: min_err
      integer :: mpierr

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_common_plus_sparse_timers(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%write_mpi_union_summary('/no_such_dir/test_mpi_union_summary.txt', ierr=ierr)
      @assertEqual(FTIMER_ERR_IO, ierr)

      call MPI_F08_Allreduce(ierr, min_err, 1, MPI_F08_INTEGER, MPI_F08_MIN, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)
      call MPI_F08_Allreduce(ierr, max_err, 1, MPI_F08_INTEGER, MPI_F08_MAX, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)

      @assertEqual(FTIMER_ERR_IO, min_err)
      @assertEqual(FTIMER_ERR_IO, max_err)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_write_summary_syncs_io_error

   @test
   subroutine test_mpi_union_report_apis_reject_active_timers(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=*), parameter :: report_path = 'test_mpi_union_active_report.txt'
      integer :: flags(1)
      integer :: ierr
      integer :: max_err
      integer :: min_err
      integer :: mpierr
      integer :: rank
      logical :: report_exists

      rank = this%getProcessRank()
      flags = 0

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      fake_time = 0.0_wp
      call timer%start("active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      fake_time = 3.0_wp + real(rank, wp)

      call timer%print_mpi_union_summary(ierr=ierr)
      @assertEqual(FTIMER_ERR_ACTIVE, ierr)

      call MPI_F08_Allreduce(ierr, min_err, 1, MPI_F08_INTEGER, MPI_F08_MIN, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)
      call MPI_F08_Allreduce(ierr, max_err, 1, MPI_F08_INTEGER, MPI_F08_MAX, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)

      @assertEqual(FTIMER_ERR_ACTIVE, min_err)
      @assertEqual(FTIMER_ERR_ACTIVE, max_err)

      if (rank == 0) call delete_if_exists(report_path)
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_union_summary(report_path, ierr=ierr)
      @assertEqual(FTIMER_ERR_ACTIVE, ierr)

      call MPI_F08_Allreduce(ierr, min_err, 1, MPI_F08_INTEGER, MPI_F08_MIN, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)
      call MPI_F08_Allreduce(ierr, max_err, 1, MPI_F08_INTEGER, MPI_F08_MAX, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)

      @assertEqual(FTIMER_ERR_ACTIVE, min_err)
      @assertEqual(FTIMER_ERR_ACTIVE, max_err)

      if (rank == 0) then
         inquire (file=report_path, exist=report_exists)
         if (.not. report_exists) flags(1) = 1
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))

      fake_time = fake_time + 1.0_wp
      call timer%stop("active", ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_report_apis_reject_active_timers

   @test
   subroutine test_mpi_union_reports_reject_nonroot_active_timer(this)
      class(mpi_summary_case), intent(inout) :: this
      type(ftimer_t) :: timer
      character(len=:), allocatable :: printed
      character(len=*), parameter :: print_path = 'test_mpi_union_nonroot_active_print.txt'
      character(len=*), parameter :: write_path = 'test_mpi_union_nonroot_active_write.txt'
      integer :: flags(2)
      integer :: ierr
      integer :: max_err
      integer :: min_err
      integer :: mpierr
      integer :: rank
      integer :: unit
      logical :: report_exists

      rank = this%getProcessRank()
      flags = 0

      call timer%init(comm=MPI_F08_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      fake_time = 0.0_wp
      if (rank /= 0) then
         call timer%start("nonroot_active", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
         fake_time = 3.0_wp
      end if

      if (rank == 0) then
         call delete_if_exists(print_path)
         open (newunit=unit, file=print_path, status='replace', action='write', iostat=ierr)
         @assertEqual(0, ierr)
         call timer%print_mpi_union_summary(unit=unit, ierr=ierr)
         close (unit)
      else
         call timer%print_mpi_union_summary(ierr=ierr)
      end if
      @assertEqual(FTIMER_ERR_ACTIVE, ierr)

      call MPI_F08_Allreduce(ierr, min_err, 1, MPI_F08_INTEGER, MPI_F08_MIN, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)
      call MPI_F08_Allreduce(ierr, max_err, 1, MPI_F08_INTEGER, MPI_F08_MAX, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)

      @assertEqual(FTIMER_ERR_ACTIVE, min_err)
      @assertEqual(FTIMER_ERR_ACTIVE, max_err)

      if (rank == 0) then
         printed = read_file_text(print_path)
         if (len(printed) == 0) flags(1) = 1
         call delete_if_exists(print_path)
         call delete_if_exists(write_path)
      end if
      call MPI_F08_Barrier(MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      call timer%write_mpi_union_summary(write_path, ierr=ierr)
      @assertEqual(FTIMER_ERR_ACTIVE, ierr)

      call MPI_F08_Allreduce(ierr, min_err, 1, MPI_F08_INTEGER, MPI_F08_MIN, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)
      call MPI_F08_Allreduce(ierr, max_err, 1, MPI_F08_INTEGER, MPI_F08_MAX, MPI_F08_COMM_WORLD, mpierr)
      @assertEqual(MPI_F08_SUCCESS, mpierr)

      @assertEqual(FTIMER_ERR_ACTIVE, min_err)
      @assertEqual(FTIMER_ERR_ACTIVE, max_err)

      if (rank == 0) then
         inquire (file=write_path, exist=report_exists)
         if (.not. report_exists) flags(2) = 1
      end if

      call MPI_F08_Bcast(flags, size(flags), MPI_F08_INTEGER, 0, MPI_F08_COMM_WORLD, ierr)
      @assertEqual(MPI_F08_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))

      if (rank /= 0) then
         fake_time = fake_time + 1.0_wp
         call timer%stop("nonroot_active", ierr=ierr)
         @assertEqual(FTIMER_SUCCESS, ierr)
      end if
      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_union_reports_reject_nonroot_active_timer

