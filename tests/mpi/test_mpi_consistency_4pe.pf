module test_mpi_consistency_4pe
   use pfunit
   use mpi
   use ftimer_core, only: ftimer_t
   use ftimer_mpi, only: build_mpi_summary
   use ftimer_types, only: FTIMER_ERR_MPI_INCON, FTIMER_SUCCESS, ftimer_mpi_summary_t, ftimer_summary_t, wp
   use test_support, only: attach_mock_clock, begin_stderr_capture, end_stderr_capture, fake_time
   implicit none

   @testcase(npes=[4])
   type, extends(MpiTestCase) :: mpi_consistency_4pe_case
   end type mpi_consistency_4pe_case

contains

   @test
   subroutine test_mpi_summary_no_global_result_for_extra_timers(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_extra_timer_mismatch(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_no_global_result_for_extra_timers

   @test
   subroutine test_mpi_summary_no_global_result_for_missing_timers(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_missing_timer_mismatch(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_no_global_result_for_missing_timers

   @test
   subroutine test_mpi_summary_no_global_result_for_name_mismatch(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_renamed_timer_mismatch(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_no_global_result_for_name_mismatch

   @test
   subroutine test_mpi_summary_no_global_result_for_hierarchy_mismatch(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_four_rank_hierarchy_mismatch(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_no_global_result_for_hierarchy_mismatch

   @test
   subroutine test_mpi_summary_reports_all_disagreeing_ranks_on_mismatch(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      character(len=:), allocatable :: captured
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: capture_ierr
      integer :: flags(4)
      integer :: ierr
      integer :: rank
      integer :: saved_fd

      rank = this%getProcessRank()
      saved_fd = -1
      flags = 0

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_four_rank_hierarchy_mismatch(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (rank == 0) then
         call begin_stderr_capture('test_mpi_descriptor_mismatch_4pe_stderr.txt', saved_fd, capture_ierr)
         @assertEqual(0, capture_ierr)
         call timer%mpi_summary(summary)
         call end_stderr_capture('test_mpi_descriptor_mismatch_4pe_stderr.txt', saved_fd, captured, capture_ierr)
         @assertEqual(0, capture_ierr)

         if (index(captured, 'rank 0') > 0) flags(1) = 1
         if (index(captured, 'ranks 1, 3') > 0) flags(2) = 1
         if (index(captured, 'descriptor') > 0) flags(3) = 1
         if ((summary%num_ranks == 0) .and. (summary%num_entries == 0)) flags(4) = 1
      else
         call timer%mpi_summary(summary, ierr=ierr)
         @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      end if

      call MPI_Bcast(flags, size(flags), MPI_INTEGER, 0, MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_reports_all_disagreeing_ranks_on_mismatch

   @test
   subroutine test_mpi_summary_reports_split_comm_disagreeing_ranks(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      character(len=:), allocatable :: captured
      character(len=96) :: capture_path
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: capture_ierr
      integer :: color
      integer :: comm_rank
      integer :: global_flags(5)
      integer :: ierr
      integer :: rank
      integer :: root_flags(5)
      integer :: saved_fd
      integer :: split_comm

      rank = this%getProcessRank()
      color = rank/2
      saved_fd = -1
      root_flags = 0

      call MPI_Comm_split(MPI_COMM_WORLD, color, rank, split_comm, ierr)
      @assertEqual(MPI_SUCCESS, ierr)
      call MPI_Comm_rank(split_comm, comm_rank, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      call timer%init(comm=split_comm, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_four_rank_hierarchy_mismatch(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      if (comm_rank == 0) then
         write (capture_path, '(a,i0,a)') 'test_mpi_descriptor_split_mismatch_rank', rank, '.txt'
         call begin_stderr_capture(trim(capture_path), saved_fd, capture_ierr)
         @assertEqual(0, capture_ierr)
         call timer%mpi_summary(summary)
         call end_stderr_capture(trim(capture_path), saved_fd, captured, capture_ierr)
         @assertEqual(0, capture_ierr)

         if (index(captured, 'rank 0') > 0) root_flags(1) = 1
         if (index(captured, 'ranks 1') > 0) root_flags(2) = 1
         if (index(captured, 'descriptor') > 0) root_flags(3) = 1
         if ((summary%num_ranks == 0) .and. (summary%num_entries == 0)) root_flags(4) = 1
         if (index(captured, 'ranks 1,') == 0) root_flags(5) = 1
      else
         call timer%mpi_summary(summary, ierr=ierr)
         @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      end if

      call MPI_Allreduce(root_flags, global_flags, size(root_flags), MPI_INTEGER, MPI_SUM, MPI_COMM_WORLD, ierr)
      @assertEqual(MPI_SUCCESS, ierr)

      @assertEqual(2, global_flags(1))
      @assertEqual(2, global_flags(2))
      @assertEqual(2, global_flags(3))
      @assertEqual(2, global_flags(4))
      @assertEqual(2, global_flags(5))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call MPI_Comm_free(split_comm, ierr)
      @assertEqual(MPI_SUCCESS, ierr)
   end subroutine test_mpi_summary_reports_split_comm_disagreeing_ranks

   @test
   subroutine test_mpi_summary_marks_truncated_rank_diagnostic(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      character(len=96) :: diagnostic
      character(len=140) :: partial_diagnostic
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: mpi_summary
      type(ftimer_summary_t) :: local_summary
      integer :: flags(6)
      integer :: ierr
      integer :: partial_status
      integer :: rank
      integer :: status

      rank = this%getProcessRank()
      flags = 0
      diagnostic = ''
      partial_diagnostic = ''

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_extra_timer_mismatch(timer, rank, ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%get_summary(local_summary, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call build_mpi_summary(local_summary, MPI_COMM_WORLD, mpi_summary, status, diagnostic)
      call build_mpi_summary(local_summary, MPI_COMM_WORLD, mpi_summary, partial_status, partial_diagnostic)

      if ((status == FTIMER_ERR_MPI_INCON) .and. (partial_status == FTIMER_ERR_MPI_INCON)) flags(1) = 1
      if (index(diagnostic, 'truncated') > 0) flags(2) = 1
      if ((mpi_summary%num_ranks == 0) .and. (mpi_summary%num_entries == 0)) flags(3) = 1
      if (index(partial_diagnostic, 'ranks 1') > 0) flags(4) = 1
      if (index(partial_diagnostic, '...') > 0) flags(5) = 1
      if (index(partial_diagnostic, 'truncated') == 0) flags(6) = 1

      @assertEqual(1, flags(1))
      @assertEqual(1, flags(2))
      @assertEqual(1, flags(3))
      @assertEqual(1, flags(4))
      @assertEqual(1, flags(5))
      @assertEqual(1, flags(6))

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_marks_truncated_rank_diagnostic

   subroutine build_extra_timer_mismatch(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 2.0_wp + real(rank, wp)
      call timer%stop("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (rank == 0) then
         fake_time = 3.0_wp
         call timer%start("extra", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 6.0_wp
         call timer%stop("extra", ierr=ierr)
      end if
   end subroutine build_extra_timer_mismatch

   subroutine build_missing_timer_mismatch(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 1.0_wp + real(rank, wp)
      call timer%stop("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (rank /= 0) then
         fake_time = 2.0_wp + real(rank, wp)
         call timer%start("late", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 4.0_wp + real(rank, wp)
         call timer%stop("late", ierr=ierr)
      end if
   end subroutine build_missing_timer_mismatch

   subroutine build_renamed_timer_mismatch(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      if (mod(rank, 2) == 0) then
         call timer%start("alpha", ierr=ierr)
      else
         call timer%start("beta", ierr=ierr)
      end if
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 5.0_wp + real(rank, wp)
      if (mod(rank, 2) == 0) then
         call timer%stop("alpha", ierr=ierr)
      else
         call timer%stop("beta", ierr=ierr)
      end if
   end subroutine build_renamed_timer_mismatch

   subroutine build_four_rank_hierarchy_mismatch(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (mod(rank, 2) == 0) then
         fake_time = 2.0_wp + real(rank, wp)
         call timer%start("work", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 5.0_wp + real(rank, wp)
         call timer%stop("work", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 7.0_wp + real(rank, wp)
         call timer%stop("outer", ierr=ierr)
      else
         fake_time = 2.0_wp + real(rank, wp)
         call timer%stop("outer", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         call timer%start("work", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 6.0_wp + real(rank, wp)
         call timer%stop("work", ierr=ierr)
      end if
   end subroutine build_four_rank_hierarchy_mismatch

end module test_mpi_consistency_4pe
