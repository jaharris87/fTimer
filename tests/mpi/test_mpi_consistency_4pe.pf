module test_mpi_consistency_4pe
   use pfunit
   use mpi
   use ftimer_core, only: ftimer_t
   use ftimer_types, only: FTIMER_ERR_MPI_INCON, FTIMER_SUCCESS, ftimer_mpi_summary_t, wp
   use test_support, only: attach_mock_clock, fake_time
   implicit none

   @testcase(npes=[4])
   type, extends(MpiTestCase) :: mpi_consistency_4pe_case
   end type mpi_consistency_4pe_case

contains

   @test
   subroutine test_mpi_summary_no_global_result_for_extra_timers(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_extra_timer_mismatch(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_no_global_result_for_extra_timers

   @test
   subroutine test_mpi_summary_no_global_result_for_missing_timers(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_missing_timer_mismatch(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_no_global_result_for_missing_timers

   @test
   subroutine test_mpi_summary_no_global_result_for_name_mismatch(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_renamed_timer_mismatch(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_no_global_result_for_name_mismatch

   @test
   subroutine test_mpi_summary_no_global_result_for_hierarchy_mismatch(this)
      class(mpi_consistency_4pe_case), intent(inout) :: this
      type(ftimer_t) :: timer
      type(ftimer_mpi_summary_t) :: summary
      integer :: ierr

      call timer%init(comm=MPI_COMM_WORLD, ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
      call attach_mock_clock(timer)

      call build_four_rank_hierarchy_mismatch(timer, this%getProcessRank(), ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)

      call timer%mpi_summary(summary, ierr=ierr)

      @assertEqual(FTIMER_ERR_MPI_INCON, ierr)
      @assertEqual(0, summary%num_ranks)
      @assertEqual(0, summary%num_entries)

      call timer%finalize(ierr=ierr)
      @assertEqual(FTIMER_SUCCESS, ierr)
   end subroutine test_mpi_summary_no_global_result_for_hierarchy_mismatch

   subroutine build_extra_timer_mismatch(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 2.0_wp + real(rank, wp)
      call timer%stop("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (rank == 0) then
         fake_time = 3.0_wp
         call timer%start("extra", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 6.0_wp
         call timer%stop("extra", ierr=ierr)
      end if
   end subroutine build_extra_timer_mismatch

   subroutine build_missing_timer_mismatch(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 1.0_wp + real(rank, wp)
      call timer%stop("common", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (rank /= 0) then
         fake_time = 2.0_wp + real(rank, wp)
         call timer%start("late", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 4.0_wp + real(rank, wp)
         call timer%stop("late", ierr=ierr)
      end if
   end subroutine build_missing_timer_mismatch

   subroutine build_renamed_timer_mismatch(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      if (mod(rank, 2) == 0) then
         call timer%start("alpha", ierr=ierr)
      else
         call timer%start("beta", ierr=ierr)
      end if
      if (ierr /= FTIMER_SUCCESS) return

      fake_time = 5.0_wp + real(rank, wp)
      if (mod(rank, 2) == 0) then
         call timer%stop("alpha", ierr=ierr)
      else
         call timer%stop("beta", ierr=ierr)
      end if
   end subroutine build_renamed_timer_mismatch

   subroutine build_four_rank_hierarchy_mismatch(timer, rank, ierr)
      class(ftimer_t), intent(inout) :: timer
      integer, intent(in) :: rank
      integer, intent(out) :: ierr

      fake_time = 0.0_wp
      call timer%start("outer", ierr=ierr)
      if (ierr /= FTIMER_SUCCESS) return

      if (mod(rank, 2) == 0) then
         fake_time = 2.0_wp + real(rank, wp)
         call timer%start("work", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 5.0_wp + real(rank, wp)
         call timer%stop("work", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 7.0_wp + real(rank, wp)
         call timer%stop("outer", ierr=ierr)
      else
         fake_time = 2.0_wp + real(rank, wp)
         call timer%stop("outer", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         call timer%start("work", ierr=ierr)
         if (ierr /= FTIMER_SUCCESS) return

         fake_time = 6.0_wp + real(rank, wp)
         call timer%stop("work", ierr=ierr)
      end if
   end subroutine build_four_rank_hierarchy_mismatch

end module test_mpi_consistency_4pe
